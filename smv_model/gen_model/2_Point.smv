		seg15.occUp = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		seg15.occUp = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		seg15.occUp = TAILOCC : FREE;

		TRUE : seg15.occUp;
	esac;

	-- seg14
	next(seg14.occDown) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg14.occDown = FREE & seg15.occDown in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg14.occDown = FREE & seg14.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg14.occDown = FREE & seg14.mode != AVAILABLE
		& seg15.occDown = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg14.occDown = FREE & seg14.mode != AVAILABLE
		& seg15.occDown = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg14.occDown = FREE & seg14.mode != AVAILABLE
		& seg15.occDown = TAILOCC
		: ERROROCC;

		-- train collects here if head present and signal is STOP
		seg14.occDown = HEADOCC & signal7.ACT = STOP : COMPLETETRAINOCC;

		-- ERROROCC if train head present and signal is GO
		seg14.occDown = HEADOCC & signal7.ACT = GO : ERROROCC;

		-- train stays here and signal is STOP
		seg14.occDown = COMPLETETRAINOCC & signal7.ACT = STOP : COMPLETETRAINOCC;

		-- ERROROCC if train in COMPLETETRAINOCC and signal is GO
		seg14.occDown = COMPLETETRAINOCC & signal7.ACT = GO : ERROROCC;

		-- ERROROCC if train tail is present
		seg14.occDown = TAILOCC : ERROROCC;

		TRUE : seg14.occDown;
	esac;

	next(seg14.occUp) := case
		-- stays FREE as no train can enter from out of bounds
		seg14.occUp = FREE : FREE;

		-- ERROROCC if head of a train is here, as the tail has no previous segment
		seg14.occUp = HEADOCC : ERROROCC;

		-- stays COMPLETETRAINOCC if the segment is not in USED mode
		seg14.occUp = COMPLETETRAINOCC & seg14.mode != USED : COMPLETETRAINOCC;

		-- train moves on with head if train is present
		seg14.occUp = COMPLETETRAINOCC & seg14.mode = USED : TAILOCC;

		-- train tail leaves if tail is present
		seg14.occUp = TAILOCC : FREE;

		TRUE : seg14.occUp;
	esac;

	-- POINTS OCCUPANCY NEXT --
	-- point1
	next(point1.occSNR) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		point1.occSNR = FREE & seg5.occDown in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		point1.occSNR = FREE & point1.mode = AVAILABLE : FREE;

		-- train blocked at signal STOP regardless of predecessor state
		point1.occSNR = FREE & point1.mode != AVAILABLE & point1.ACT != INTERMEDIATE
		& seg5.occDown in {HEADOCC, COMPLETETRAINOCC} & signal3.ACT = STOP
		: FREE;

		-- non-deterministic head entry if previous segment has head and signal is GO
		point1.occSNR = FREE & point1.mode != AVAILABLE & point1.ACT != INTERMEDIATE
		& seg5.occDown = HEADOCC & signal3.ACT = GO
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train and signal is GO
		point1.occSNR = FREE & point1.mode != AVAILABLE & point1.ACT != INTERMEDIATE
		& seg5.occDown = COMPLETETRAINOCC & signal3.ACT = GO
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		-- and signal is GO
		point1.occSNR = FREE & point1.mode != AVAILABLE & point1.ACT != INTERMEDIATE
		& seg5.occDown = TAILOCC & signal3.ACT = GO
		: ERROROCC;

		-- ERROROCC if train present and aspect is INTERMEDIATE
		point1.occSNR != FREE & point1.ACT = INTERMEDIATE : ERROROCC;

		-- train head leaves or train collects here if head present
		point1.occSNR = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		point1.occSNR = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		point1.occSNR = TAILOCC : FREE;

		TRUE : point1.occSNR;
	esac;

	next(point1.occNS) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		point1.occNS = FREE & seg3.occUp in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		point1.occNS = FREE & point1.mode = AVAILABLE : FREE;

		-- train blocked at signal STOP regardless of predecessor state
		point1.occNS = FREE & point1.mode != AVAILABLE & point1.ACT = NORMAL
		& seg3.occUp in {HEADOCC, COMPLETETRAINOCC} & signal2.ACT = STOP
		: FREE;

		-- non-deterministic head entry if previous segment has head and signal is GO
		point1.occNS = FREE & point1.mode != AVAILABLE & point1.ACT = NORMAL
		& seg3.occUp = HEADOCC & signal2.ACT = GO
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train and signal is GO
		point1.occNS = FREE & point1.mode != AVAILABLE & point1.ACT = NORMAL
		& seg3.occUp = COMPLETETRAINOCC & signal2.ACT = GO
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		-- and signal is GO
		point1.occNS = FREE & point1.mode != AVAILABLE & point1.ACT = NORMAL
		& seg3.occUp = TAILOCC & signal2.ACT = GO
		: ERROROCC;

		-- ERROROCC if train present and aspect is INTERMEDIATE
		point1.occNS != FREE & point1.ACT = INTERMEDIATE : ERROROCC;

		-- train head leaves or train collects here if head present
		point1.occNS = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		point1.occNS = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		point1.occNS = TAILOCC : FREE;

		TRUE : point1.occNS;
	esac;

	next(point1.occRS) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		point1.occRS = FREE & seg16.occUp in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		point1.occRS = FREE & point1.mode = AVAILABLE : FREE;

		-- train blocked at signal STOP regardless of predecessor state
		point1.occRS = FREE & point1.mode != AVAILABLE & point1.ACT = REVERSE
		& seg16.occUp in {HEADOCC, COMPLETETRAINOCC} & signal8.ACT = STOP
		: FREE;

		-- non-deterministic head entry if previous segment has head and signal is GO
		point1.occRS = FREE & point1.mode != AVAILABLE & point1.ACT = REVERSE
		& seg16.occUp = HEADOCC & signal8.ACT = GO
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train and signal is GO
		point1.occRS = FREE & point1.mode != AVAILABLE & point1.ACT = REVERSE
		& seg16.occUp = COMPLETETRAINOCC & signal8.ACT = GO
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		-- and signal is GO
		point1.occRS = FREE & point1.mode != AVAILABLE & point1.ACT = REVERSE
		& seg16.occUp = TAILOCC & signal8.ACT = GO
		: ERROROCC;

		-- ERROROCC if train present and aspect is INTERMEDIATE
		point1.occRS != FREE & point1.ACT = INTERMEDIATE : ERROROCC;

		-- train head leaves or train collects here if head present
		point1.occRS = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		point1.occRS = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		point1.occRS = TAILOCC : FREE;

		TRUE : point1.occRS;
	esac;


-- Train Movement --
INVAR
	(seg5.occUp = HEADOCC -> (seg6.occUp != HEADOCC))
	& (seg5.occUp = COMPLETETRAINOCC -> (seg6.occUp != HEADOCC))
	& (seg5.occUp = TAILOCC -> (seg6.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg5.occDown = HEADOCC -> (seg6.occDown in {TAILOCC, ERROROCC} & point1.occSNR != HEADOCC))
	& (seg5.occDown = COMPLETETRAINOCC -> (seg6.occDown != TAILOCC & point1.occSNR != HEADOCC))
	& (seg5.occDown = TAILOCC -> (seg6.occDown != TAILOCC & point1.occSNR in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg6.occUp = HEADOCC -> (seg5.occUp in {TAILOCC, ERROROCC} & seg7.occUp != HEADOCC))
	& (seg6.occUp = COMPLETETRAINOCC -> (seg5.occUp != TAILOCC & seg7.occUp != HEADOCC))
	& (seg6.occUp = TAILOCC -> (seg5.occUp != TAILOCC & seg7.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg6.occDown = HEADOCC -> (seg7.occDown in {TAILOCC, ERROROCC} & seg5.occDown != HEADOCC))
	& (seg6.occDown = COMPLETETRAINOCC -> (seg7.occDown != TAILOCC & seg5.occDown != HEADOCC))
	& (seg6.occDown = TAILOCC -> (seg7.occDown != TAILOCC & seg5.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg7.occUp = HEADOCC -> (seg6.occUp in {TAILOCC, ERROROCC}))
	& (seg7.occUp = COMPLETETRAINOCC -> (seg6.occUp != TAILOCC))
	& (seg7.occUp = TAILOCC -> (seg6.occUp != TAILOCC))
	& (seg7.occDown = HEADOCC -> (seg6.occDown != HEADOCC))
	& (seg7.occDown = COMPLETETRAINOCC -> (seg6.occDown != HEADOCC))
	& (seg7.occDown = TAILOCC -> (seg6.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg3.occUp = HEADOCC -> (seg2.occUp in {TAILOCC, ERROROCC} & point1.occNS != HEADOCC))
	& (seg3.occUp = COMPLETETRAINOCC -> (seg2.occUp != TAILOCC & point1.occNS != HEADOCC))
	& (seg3.occUp = TAILOCC -> (seg2.occUp != TAILOCC & point1.occNS in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg3.occDown = HEADOCC -> (point1.occSNR in {TAILOCC, ERROROCC} & seg2.occDown != HEADOCC))
	& (seg3.occDown = COMPLETETRAINOCC -> (point1.occSNR != TAILOCC & seg2.occDown != HEADOCC))
	& (seg3.occDown = TAILOCC -> (point1.occSNR != TAILOCC & seg2.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg2.occUp = HEADOCC -> (seg1.occUp in {TAILOCC, ERROROCC} & seg3.occUp != HEADOCC))
	& (seg2.occUp = COMPLETETRAINOCC -> (seg1.occUp != TAILOCC & seg3.occUp != HEADOCC))
	& (seg2.occUp = TAILOCC -> (seg1.occUp != TAILOCC & seg3.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg2.occDown = HEADOCC -> (seg3.occDown in {TAILOCC, ERROROCC} & seg1.occDown != HEADOCC))
	& (seg2.occDown = COMPLETETRAINOCC -> (seg3.occDown != TAILOCC & seg1.occDown != HEADOCC))
	& (seg2.occDown = TAILOCC -> (seg3.occDown != TAILOCC & seg1.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg1.occUp = HEADOCC -> (seg2.occUp != HEADOCC))
	& (seg1.occUp = COMPLETETRAINOCC -> (seg2.occUp != HEADOCC))
	& (seg1.occUp = TAILOCC -> (seg2.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg1.occDown = HEADOCC -> (seg2.occDown in {TAILOCC, ERROROCC}))
	& (seg1.occDown = COMPLETETRAINOCC -> (seg2.occDown != TAILOCC))
	& (seg1.occDown = TAILOCC -> (seg2.occDown != TAILOCC))
	& (seg16.occUp = HEADOCC -> (seg15.occUp in {TAILOCC, ERROROCC} & point1.occRS != HEADOCC))
	& (seg16.occUp = COMPLETETRAINOCC -> (seg15.occUp != TAILOCC & point1.occRS != HEADOCC))
	& (seg16.occUp = TAILOCC -> (seg15.occUp != TAILOCC & point1.occRS in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg16.occDown = HEADOCC -> (point1.occSNR in {TAILOCC, ERROROCC} & seg15.occDown != HEADOCC))
	& (seg16.occDown = COMPLETETRAINOCC -> (point1.occSNR != TAILOCC & seg15.occDown != HEADOCC))
	& (seg16.occDown = TAILOCC -> (point1.occSNR != TAILOCC & seg15.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg15.occUp = HEADOCC -> (seg14.occUp in {TAILOCC, ERROROCC} & seg16.occUp != HEADOCC))
	& (seg15.occUp = COMPLETETRAINOCC -> (seg14.occUp != TAILOCC & seg16.occUp != HEADOCC))
	& (seg15.occUp = TAILOCC -> (seg14.occUp != TAILOCC & seg16.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg15.occDown = HEADOCC -> (seg16.occDown in {TAILOCC, ERROROCC} & seg14.occDown != HEADOCC))
	& (seg15.occDown = COMPLETETRAINOCC -> (seg16.occDown != TAILOCC & seg14.occDown != HEADOCC))
	& (seg15.occDown = TAILOCC -> (seg16.occDown != TAILOCC & seg14.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg14.occUp = HEADOCC -> (seg15.occUp != HEADOCC))
	& (seg14.occUp = COMPLETETRAINOCC -> (seg15.occUp != HEADOCC))
	& (seg14.occUp = TAILOCC -> (seg15.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg14.occDown = HEADOCC -> (seg15.occDown in {TAILOCC, ERROROCC}))
	& (seg14.occDown = COMPLETETRAINOCC -> (seg15.occDown != TAILOCC))
	& (seg14.occDown = TAILOCC -> (seg15.occDown != TAILOCC))
	& (point1.occSNR = HEADOCC -> (seg5.occDown in {TAILOCC, ERROROCC} & seg3.occDown != HEADOCC & seg16.occDown != HEADOCC))
	& (point1.occSNR = COMPLETETRAINOCC -> (seg5.occDown != TAILOCC & seg3.occDown != HEADOCC & seg16.occDown != HEADOCC))
	& (point1.occSNR = TAILOCC -> (seg5.occDown != TAILOCC & (seg3.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC} | seg16.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC})))
	& (point1.occNS = HEADOCC -> (seg3.occUp in {TAILOCC, ERROROCC} & seg5.occUp != HEADOCC))
	& (point1.occNS = COMPLETETRAINOCC -> (seg3.occUp != TAILOCC & seg5.occUp != HEADOCC))
	& (point1.occNS = TAILOCC -> (seg3.occUp != TAILOCC & seg5.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (point1.occRS = HEADOCC -> (seg16.occUp in {TAILOCC, ERROROCC} & seg5.occUp != HEADOCC))
	& (point1.occRS = COMPLETETRAINOCC -> (seg16.occUp != TAILOCC & seg5.occUp != HEADOCC))
	& (point1.occRS = TAILOCC -> (seg16.occUp != TAILOCC & seg5.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))

-- Train Occupancy Error --
INVARSPEC
	NAME NoOccUpErrors := !(
		seg5.occUp = ERROROCC
		| seg6.occUp = ERROROCC
		| seg7.occUp = ERROROCC
		| seg3.occUp = ERROROCC
		| seg2.occUp = ERROROCC
		| seg1.occUp = ERROROCC
		| seg16.occUp = ERROROCC
		| seg15.occUp = ERROROCC
		| seg14.occUp = ERROROCC
	);

INVARSPEC
	NAME NoOccDownErrors := !(
		seg5.occDown = ERROROCC
		| seg6.occDown = ERROROCC
		| seg7.occDown = ERROROCC
		| seg3.occDown = ERROROCC
		| seg2.occDown = ERROROCC
		| seg1.occDown = ERROROCC
		| seg16.occDown = ERROROCC
		| seg15.occDown = ERROROCC
		| seg14.occDown = ERROROCC
	);

INVARSPEC
	NAME NoOccPointErrors := !(
		point1.occSNR = ERROROCC
		| point1.occRS = ERROROCC
		| point1.occNS = ERROROCC
	);


-- Safety Invariants --
INVARSPEC
	NAME NoHeadToHeadSegmentCollisions := (
		(seg5.occDown != FREE -> seg5.occUp = FREE) & (seg5.occUp != FREE -> seg5.occDown = FREE)
		& (seg6.occDown != FREE -> seg6.occUp = FREE) & (seg6.occUp != FREE -> seg6.occDown = FREE)
		& (seg7.occDown != FREE -> seg7.occUp = FREE) & (seg7.occUp != FREE -> seg7.occDown = FREE)
		& (seg3.occDown != FREE -> seg3.occUp = FREE) & (seg3.occUp != FREE -> seg3.occDown = FREE)
		& (seg2.occDown != FREE -> seg2.occUp = FREE) & (seg2.occUp != FREE -> seg2.occDown = FREE)
		& (seg1.occDown != FREE -> seg1.occUp = FREE) & (seg1.occUp != FREE -> seg1.occDown = FREE)
		& (seg16.occDown != FREE -> seg16.occUp = FREE) & (seg16.occUp != FREE -> seg16.occDown = FREE)
		& (seg15.occDown != FREE -> seg15.occUp = FREE) & (seg15.occUp != FREE -> seg15.occDown = FREE)
		& (seg14.occDown != FREE -> seg14.occUp = FREE) & (seg14.occUp != FREE -> seg14.occDown = FREE)
	);

INVARSPEC
	NAME NoHeadToHeadPointCollisions := (
		(point1.occSNR != FREE -> (point1.occNS = FREE & point1.occRS = FREE))
        & (point1.occNS != FREE -> (point1.occSNR = FREE & point1.occRS = FREE))
        & (point1.occRS != FREE -> (point1.occSNR = FREE & point1.occNS = FREE))
	);

INVARSPEC
	NAME NoHeadToTailCollisionsDown := (
		(seg5.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg6.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg6.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg7.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg3.occDown in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point1.occNS in {COMPLETETRAINOCC, HEADOCC})
			| point1.ACT != NORMAL
		)
		& (seg2.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg3.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg1.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg2.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg16.occDown in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point1.occRS in {COMPLETETRAINOCC, HEADOCC})
			| point1.ACT != REVERSE
		)
		& (seg15.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg16.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg14.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg15.occDown in {HEADOCC, COMPLETETRAINOCC})
	);
INVARSPEC
	NAME NoHeadToTailCollisionsUp := (
		(seg5.occUp in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point1.occSNR in {COMPLETETRAINOCC, HEADOCC})
			| point1.ACT = INTERMEDIATE
		)
		& (seg6.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg5.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg7.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg6.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg3.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg2.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg2.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg1.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg16.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg15.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg15.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg14.occUp in {HEADOCC, COMPLETETRAINOCC})
	);

INVARSPEC
	NAME NoPointDerailments := (
		(
			(point1.occNS != FREE -> point1.ACT = NORMAL)
            & (point1.occRS != FREE -> point1.ACT = REVERSE)
            & (point1.occSNR != FREE -> point1.ACT != INTERMEDIATE)
		)
	);

INVARSPEC
	NAME NoPointHeadToTailCollisions := (
		(point1.occSNR in {TAILOCC, COMPLETETRAINOCC}) -> !(seg5.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (point1.occNS in {TAILOCC, COMPLETETRAINOCC}) -> !(seg3.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (point1.occRS in {TAILOCC, COMPLETETRAINOCC}) -> !(seg16.occUp in {HEADOCC, COMPLETETRAINOCC})
	);

INVARSPEC
	NAME NoSegmentLockModeTransitionError := (
		(seg5.mode = EXLOCKED -> (r0.mode in {ALLOCATING, LOCKED, OCCUPIED} | r3.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg5.mode = USED -> (r0.mode = OCCUPIED | r3.mode = OCCUPIED))
		& (seg6.mode = EXLOCKED -> (r0.mode in {ALLOCATING, LOCKED, OCCUPIED} | r3.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg6.mode = USED -> (r0.mode = OCCUPIED | r3.mode = OCCUPIED))
		& (seg7.mode = EXLOCKED -> (r0.mode in {ALLOCATING, LOCKED, OCCUPIED} | r3.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg3.mode = EXLOCKED -> (r1.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg3.mode = USED -> (r1.mode = OCCUPIED))
		& (seg2.mode = EXLOCKED -> (r1.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg2.mode = USED -> (r1.mode = OCCUPIED))
		& (seg1.mode = EXLOCKED -> (r1.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg16.mode = EXLOCKED -> (r2.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg16.mode = USED -> (r2.mode = OCCUPIED))
		& (seg15.mode = EXLOCKED -> (r2.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg15.mode = USED -> (r2.mode = OCCUPIED))
		& (seg14.mode = EXLOCKED -> (r2.mode in {ALLOCATING, LOCKED, OCCUPIED}))
	);

INVARSPEC
	NAME NoPointLockModeTransitionError := (
		(point1.mode = EXLOCKED -> (r0.mode in {ALLOCATING, LOCKED, OCCUPIED} | r1.mode in {ALLOCATING, LOCKED, OCCUPIED} | r2.mode in {ALLOCATING, LOCKED, OCCUPIED} | r3.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (point1.mode = USED -> (r0.mode = OCCUPIED | r1.mode = OCCUPIED | r2.mode = OCCUPIED | r3.mode = OCCUPIED))
	);

-- LTL Properties --
LTLSPEC
	NAME r0IsReleasedEventually :=
		G(r0.mode = OCCUPIED -> F(r0.mode = FREE));

LTLSPEC
	NAME r0TrainReachesSeg7UpEventuallyForever :=
		F(r0.mode = OCCUPIED) -> F(G(seg7.occUp = COMPLETETRAINOCC));

LTLSPEC
	NAME r0ElementReleaseWavePoint1ToSeg5 :=
		G((seg5.mode = USED & point1.mode = AVAILABLE) -> F(seg5.mode = AVAILABLE));

LTLSPEC
	NAME r0ElementReleaseWaveSeg5ToSeg6 :=
		G((seg6.mode = USED & seg5.mode = AVAILABLE) -> F(seg6.mode = AVAILABLE));

LTLSPEC
	NAME r1IsReleasedEventually :=
		G(r1.mode = OCCUPIED -> F(r1.mode = FREE));

LTLSPEC
	NAME r1TrainReachesSeg1DownEventuallyForever :=
		F(r1.mode = OCCUPIED) -> F(G(seg1.occDown = COMPLETETRAINOCC));

LTLSPEC
	NAME r1ElementReleaseWavePoint1ToSeg3 :=
		G((seg3.mode = USED & point1.mode = AVAILABLE) -> F(seg3.mode = AVAILABLE));

LTLSPEC
	NAME r1ElementReleaseWaveSeg3ToSeg2 :=
		G((seg2.mode = USED & seg3.mode = AVAILABLE) -> F(seg2.mode = AVAILABLE));

LTLSPEC
	NAME r2IsReleasedEventually :=
		G(r2.mode = OCCUPIED -> F(r2.mode = FREE));

LTLSPEC
	NAME r2TrainReachesSeg14DownEventuallyForever :=
		F(r2.mode = OCCUPIED) -> F(G(seg14.occDown = COMPLETETRAINOCC));

LTLSPEC
	NAME r2ElementReleaseWavePoint1ToSeg16 :=
		G((seg16.mode = USED & point1.mode = AVAILABLE) -> F(seg16.mode = AVAILABLE));

LTLSPEC
	NAME r2ElementReleaseWaveSeg16ToSeg15 :=
		G((seg15.mode = USED & seg16.mode = AVAILABLE) -> F(seg15.mode = AVAILABLE));

LTLSPEC
	NAME r3IsReleasedEventually :=
		G(r3.mode = OCCUPIED -> F(r3.mode = FREE));

LTLSPEC
	NAME r3TrainReachesSeg7UpEventuallyForever :=
		F(r3.mode = OCCUPIED) -> F(G(seg7.occUp = COMPLETETRAINOCC));

LTLSPEC
	NAME r3ElementReleaseWavePoint1ToSeg5 :=
		G((seg5.mode = USED & point1.mode = AVAILABLE) -> F(seg5.mode = AVAILABLE));

LTLSPEC
	NAME r3ElementReleaseWaveSeg5ToSeg6 :=
		G((seg6.mode = USED & seg5.mode = AVAILABLE) -> F(seg6.mode = AVAILABLE));

-- Route mutual exclusion --
LTLSPEC
	NAME r0AndR2MutuallyExclusive :=
		G(!(r0.mode = OCCUPIED & r2.mode = OCCUPIED));

LTLSPEC
	NAME r0AndR3MutuallyExclusive :=
		G(!(r0.mode = OCCUPIED & r3.mode = OCCUPIED));

LTLSPEC
	NAME r0AndR1MutuallyExclusive :=
		G(!(r0.mode = OCCUPIED & r1.mode = OCCUPIED));

LTLSPEC
	NAME r1AndR2MutuallyExclusive :=
		G(!(r1.mode = OCCUPIED & r2.mode = OCCUPIED));

LTLSPEC
	NAME r1AndR3MutuallyExclusive :=
		G(!(r1.mode = OCCUPIED & r3.mode = OCCUPIED));

LTLSPEC
	NAME r2AndR3MutuallyExclusive :=
		G(!(r2.mode = OCCUPIED & r3.mode = OCCUPIED));

-- Sanity checks: add manually based on extras_config.yml initial train positions
-- LTLSPEC NAME SanityCheckPos := F(G(<start_seg>.occ<Dir> = FREE & ...));
-- LTLSPEC NAME SanityCheckNeg := !(F(G(<start_seg>.occ<Dir> = FREE & ...)));

-------------------------------------------------------------------------------
-- Interlocking System Moduel --
-- Represents a route state transitions for the train movement
-------------------------------------------------------------------------------
MODULE InterlockingSystem 
VAR
	track : TrackSection;
ASSIGN
	next(track.r0.transition) := case
		track.r0.transition = CAN_DISPATCH
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
        & track.point1.mode = AVAILABLE
		& track.seg5.mode = AVAILABLE
		& track.seg6.mode = AVAILABLE
		& track.seg7.mode = AVAILABLE
        & TRUE
        & track.seg3.occUp != FREE
		: CAN_ALLOCATE;

		track.r0.transition = CAN_ALLOCATE
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
        & track.signal2.ACT = STOP
		& track.signal4.ACT = STOP
        & track.point1.ACT = NORMAL
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
        & track.point1.mode = EXLOCKED
		& track.seg5.mode = EXLOCKED
		& track.seg6.mode = EXLOCKED
		& track.seg7.mode = EXLOCKED
        & TRUE
		: CAN_LOCK;

		track.r0.transition = CAN_LOCK
		& track.r0.mode = LOCKED
		& track.signal2.ACT = GO
		& track.point1.occNS != FREE
		: CAN_OCCUPY;

		track.r0.transition = CAN_OCCUPY
		& track.r0.mode = FREE
		: CAN_DISPATCH;

		TRUE : track.r0.transition;
	esac;

	next(track.r0.mode) := case
		track.r0.mode = FREE
		& track.r0.transition = CAN_DISPATCH
		: MARKED;

		track.r0.mode = MARKED
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
        & track.point1.mode = AVAILABLE
		& track.seg5.mode = AVAILABLE
		& track.seg6.mode = AVAILABLE
		& track.seg7.mode = AVAILABLE
        & TRUE
        & track.seg3.occUp != FREE
		: ALLOCATING;

		track.r0.mode = ALLOCATING
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
        & track.signal2.ACT = STOP
		& track.signal4.ACT = STOP
        & track.point1.ACT = NORMAL
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
        & track.point1.mode = EXLOCKED
		& track.seg5.mode = EXLOCKED
		& track.seg6.mode = EXLOCKED
		& track.seg7.mode = EXLOCKED
        & TRUE
		: LOCKED;

		track.r0.mode = LOCKED
		& track.signal2.ACT = GO
		& track.point1.occNS != FREE
		: OCCUPIED;

		track.r0.mode = OCCUPIED
		& track.seg7.occUp in {HEADOCC, COMPLETETRAINOCC}
		& track.seg7.mode = USED
		& track.seg7.prev = RELEASED
		: FREE;

		TRUE : track.r0.mode;
	esac;

	next(track.r1.transition) := case
		track.r1.transition = CAN_DISPATCH
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg3.occDown = FREE & track.seg3.occUp = FREE
		& track.seg2.occDown = FREE & track.seg2.occUp = FREE
		& track.seg1.occDown = FREE & track.seg1.occUp = FREE
        & track.point1.mode = AVAILABLE
		& track.seg3.mode = AVAILABLE
		& track.seg2.mode = AVAILABLE
		& track.seg1.mode = AVAILABLE
        & TRUE
        & track.seg5.occDown != FREE
		: CAN_ALLOCATE;

		track.r1.transition = CAN_ALLOCATE
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
        & track.signal3.ACT = STOP
		& track.signal1.ACT = STOP
        & track.point1.ACT = NORMAL
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg3.occDown = FREE & track.seg3.occUp = FREE
		& track.seg2.occDown = FREE & track.seg2.occUp = FREE
		& track.seg1.occDown = FREE & track.seg1.occUp = FREE
        & track.point1.mode = EXLOCKED
		& track.seg3.mode = EXLOCKED
		& track.seg2.mode = EXLOCKED
		& track.seg1.mode = EXLOCKED
        & TRUE
		: CAN_LOCK;

		track.r1.transition = CAN_LOCK
		& track.r1.mode = LOCKED
		& track.signal3.ACT = GO
		& track.point1.occSNR != FREE
		: CAN_OCCUPY;

		track.r1.transition = CAN_OCCUPY
		& track.r1.mode = FREE
		: CAN_DISPATCH;

		TRUE : track.r1.transition;
	esac;

	next(track.r1.mode) := case
		track.r1.mode = FREE
		& track.r1.transition = CAN_DISPATCH
		: MARKED;

		track.r1.mode = MARKED
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg3.occDown = FREE & track.seg3.occUp = FREE
		& track.seg2.occDown = FREE & track.seg2.occUp = FREE
		& track.seg1.occDown = FREE & track.seg1.occUp = FREE
        & track.point1.mode = AVAILABLE
		& track.seg3.mode = AVAILABLE
		& track.seg2.mode = AVAILABLE
		& track.seg1.mode = AVAILABLE
        & TRUE
        & track.seg5.occDown != FREE
		: ALLOCATING;

		track.r1.mode = ALLOCATING
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
        & track.signal3.ACT = STOP
		& track.signal1.ACT = STOP
        & track.point1.ACT = NORMAL
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg3.occDown = FREE & track.seg3.occUp = FREE
		& track.seg2.occDown = FREE & track.seg2.occUp = FREE
		& track.seg1.occDown = FREE & track.seg1.occUp = FREE
        & track.point1.mode = EXLOCKED
		& track.seg3.mode = EXLOCKED
		& track.seg2.mode = EXLOCKED
		& track.seg1.mode = EXLOCKED
        & TRUE
		: LOCKED;

		track.r1.mode = LOCKED
		& track.signal3.ACT = GO
		& track.point1.occSNR != FREE
		: OCCUPIED;

		track.r1.mode = OCCUPIED
		& track.seg1.occDown in {HEADOCC, COMPLETETRAINOCC}
		& track.seg1.mode = USED
		& track.seg1.prev = RELEASED
		: FREE;

		TRUE : track.r1.mode;
	esac;

	next(track.r2.transition) := case
		track.r2.transition = CAN_DISPATCH
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg16.occDown = FREE & track.seg16.occUp = FREE
		& track.seg15.occDown = FREE & track.seg15.occUp = FREE
		& track.seg14.occDown = FREE & track.seg14.occUp = FREE
        & track.point1.mode = AVAILABLE
		& track.seg16.mode = AVAILABLE
		& track.seg15.mode = AVAILABLE
		& track.seg14.mode = AVAILABLE
        & TRUE
        & track.seg5.occDown != FREE
		: CAN_ALLOCATE;

		track.r2.transition = CAN_ALLOCATE
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
        & track.signal3.ACT = STOP
		& track.signal7.ACT = STOP
        & track.point1.ACT = REVERSE
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg16.occDown = FREE & track.seg16.occUp = FREE
		& track.seg15.occDown = FREE & track.seg15.occUp = FREE
		& track.seg14.occDown = FREE & track.seg14.occUp = FREE
        & track.point1.mode = EXLOCKED
		& track.seg16.mode = EXLOCKED
		& track.seg15.mode = EXLOCKED
		& track.seg14.mode = EXLOCKED
        & TRUE
		: CAN_LOCK;

		track.r2.transition = CAN_LOCK
		& track.r2.mode = LOCKED
		& track.signal3.ACT = GO
		& track.point1.occSNR != FREE
		: CAN_OCCUPY;

		track.r2.transition = CAN_OCCUPY
		& track.r2.mode = FREE
		: CAN_DISPATCH;

		TRUE : track.r2.transition;
	esac;

	next(track.r2.mode) := case
		track.r2.mode = FREE
		& track.r2.transition = CAN_DISPATCH
		: MARKED;

		track.r2.mode = MARKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg16.occDown = FREE & track.seg16.occUp = FREE
		& track.seg15.occDown = FREE & track.seg15.occUp = FREE
		& track.seg14.occDown = FREE & track.seg14.occUp = FREE
        & track.point1.mode = AVAILABLE
		& track.seg16.mode = AVAILABLE
		& track.seg15.mode = AVAILABLE
		& track.seg14.mode = AVAILABLE
        & TRUE
        & track.seg5.occDown != FREE
		: ALLOCATING;

		track.r2.mode = ALLOCATING
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
        & track.signal3.ACT = STOP
		& track.signal7.ACT = STOP
        & track.point1.ACT = REVERSE
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg16.occDown = FREE & track.seg16.occUp = FREE
		& track.seg15.occDown = FREE & track.seg15.occUp = FREE
		& track.seg14.occDown = FREE & track.seg14.occUp = FREE
        & track.point1.mode = EXLOCKED
		& track.seg16.mode = EXLOCKED
		& track.seg15.mode = EXLOCKED
		& track.seg14.mode = EXLOCKED
        & TRUE
		: LOCKED;

		track.r2.mode = LOCKED
		& track.signal3.ACT = GO
		& track.point1.occSNR != FREE
		: OCCUPIED;

		track.r2.mode = OCCUPIED
		& track.seg14.occDown in {HEADOCC, COMPLETETRAINOCC}
		& track.seg14.mode = USED
		& track.seg14.prev = RELEASED
		: FREE;

		TRUE : track.r2.mode;
	esac;

	next(track.r3.transition) := case
		track.r3.transition = CAN_DISPATCH
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
        & track.point1.mode = AVAILABLE
		& track.seg5.mode = AVAILABLE
		& track.seg6.mode = AVAILABLE
		& track.seg7.mode = AVAILABLE
        & TRUE
        & track.seg16.occUp != FREE
		: CAN_ALLOCATE;

		track.r3.transition = CAN_ALLOCATE
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
        & track.signal8.ACT = STOP
		& track.signal4.ACT = STOP
        & track.point1.ACT = REVERSE
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
        & track.point1.mode = EXLOCKED
		& track.seg5.mode = EXLOCKED
		& track.seg6.mode = EXLOCKED
		& track.seg7.mode = EXLOCKED
        & TRUE
		: CAN_LOCK;

		track.r3.transition = CAN_LOCK
		& track.r3.mode = LOCKED
		& track.signal8.ACT = GO
		& track.point1.occRS != FREE
		: CAN_OCCUPY;

		track.r3.transition = CAN_OCCUPY
		& track.r3.mode = FREE
		: CAN_DISPATCH;

		TRUE : track.r3.transition;
	esac;

	next(track.r3.mode) := case
		track.r3.mode = FREE
		& track.r3.transition = CAN_DISPATCH
		: MARKED;

		track.r3.mode = MARKED
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
        & track.point1.mode = AVAILABLE
		& track.seg5.mode = AVAILABLE
		& track.seg6.mode = AVAILABLE
		& track.seg7.mode = AVAILABLE
        & TRUE
        & track.seg16.occUp != FREE
		: ALLOCATING;

		track.r3.mode = ALLOCATING
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
        & track.signal8.ACT = STOP
		& track.signal4.ACT = STOP
        & track.point1.ACT = REVERSE
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
        & track.point1.mode = EXLOCKED
		& track.seg5.mode = EXLOCKED
		& track.seg6.mode = EXLOCKED
		& track.seg7.mode = EXLOCKED
        & TRUE
		: LOCKED;

		track.r3.mode = LOCKED
		& track.signal8.ACT = GO
		& track.point1.occRS != FREE
		: OCCUPIED;

		track.r3.mode = OCCUPIED
		& track.seg7.occUp in {HEADOCC, COMPLETETRAINOCC}
		& track.seg7.mode = USED
		& track.seg7.prev = RELEASED
		: FREE;

		TRUE : track.r3.mode;
	esac;


-------------------------------------------------------------------------------
-- Main Module --
-- Routes grant states in an interlocked layout
-------------------------------------------------------------------------------
MODULE main
VAR
	iSys : InterlockingSystem;

-- Fairness: all infinite executions are fair (required for non-vacuous LTL)
FAIRNESS TRUE
-------------------------------------------------------------------------------
