		& (point4.occSNR = HEADOCC -> (seg14.occDown in {TAILOCC, ERROROCC} & point6.occNS != HEADOCC & point3.occRS != HEADOCC))
		& (point4.occSNR = COMPLETETRAINOCC -> (seg14.occDown = TAILOCC & point6.occNS != HEADOCC & point3.occRS != HEADOCC))
