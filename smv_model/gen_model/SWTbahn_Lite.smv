-- Safety Invariants --
INVARSPEC
	NAME NoHeadToHeadSegmentCollisons := (
		(seg5.occDown != FREE -> seg5.occUp = FREE) & (seg5.occUp != FREE -> seg5.occDown = FREE)
		& (seg6.occDown != FREE -> seg6.occUp = FREE) & (seg6.occUp != FREE -> seg6.occDown = FREE)
		& (seg7.occDown != FREE -> seg7.occUp = FREE) & (seg7.occUp != FREE -> seg7.occDown = FREE)
		& (seg9.occDown != FREE -> seg9.occUp = FREE) & (seg9.occUp != FREE -> seg9.occDown = FREE)
		& (seg10.occDown != FREE -> seg10.occUp = FREE) & (seg10.occUp != FREE -> seg10.occDown = FREE)
		& (seg11.occDown != FREE -> seg11.occUp = FREE) & (seg11.occUp != FREE -> seg11.occDown = FREE)
		& (seg1.occDown != FREE -> seg1.occUp = FREE) & (seg1.occUp != FREE -> seg1.occDown = FREE)
		& (seg2.occDown != FREE -> seg2.occUp = FREE) & (seg2.occUp != FREE -> seg2.occDown = FREE)
		& (seg3.occDown != FREE -> seg3.occUp = FREE) & (seg3.occUp != FREE -> seg3.occDown = FREE)
		& (seg18.occDown != FREE -> seg18.occUp = FREE) & (seg18.occUp != FREE -> seg18.occDown = FREE)
		& (seg19.occDown != FREE -> seg19.occUp = FREE) & (seg19.occUp != FREE -> seg19.occDown = FREE)
		& (seg20.occDown != FREE -> seg20.occUp = FREE) & (seg20.occUp != FREE -> seg20.occDown = FREE)
		& (seg23.occDown != FREE -> seg23.occUp = FREE) & (seg23.occUp != FREE -> seg23.occDown = FREE)
		& (seg24.occDown != FREE -> seg24.occUp = FREE) & (seg24.occUp != FREE -> seg24.occDown = FREE)
		& (seg25.occDown != FREE -> seg25.occUp = FREE) & (seg25.occUp != FREE -> seg25.occDown = FREE)
		& (seg16.occDown != FREE -> seg16.occUp = FREE) & (seg16.occUp != FREE -> seg16.occDown = FREE)
		& (seg15.occDown != FREE -> seg15.occUp = FREE) & (seg15.occUp != FREE -> seg15.occDown = FREE)
		& (seg14.occDown != FREE -> seg14.occUp = FREE) & (seg14.occUp != FREE -> seg14.occDown = FREE)
		& (seg27.occDown != FREE -> seg27.occUp = FREE) & (seg27.occUp != FREE -> seg27.occDown = FREE)
		& (seg28.occDown != FREE -> seg28.occUp = FREE) & (seg28.occUp != FREE -> seg28.occDown = FREE)
		& (seg29.occDown != FREE -> seg29.occUp = FREE) & (seg29.occUp != FREE -> seg29.occDown = FREE)
		& (seg26.occDown != FREE -> seg26.occUp = FREE) & (seg26.occUp != FREE -> seg26.occDown = FREE)
	);

INVARSPEC
	NAME NoHeadToHeadPointCollisons := (
		(point1.occSNR != FREE -> (point1.occNS = FREE & point1.occRS = FREE))
        & (point1.occNS != FREE -> (point1.occSNR = FREE & point1.occRS != FREE))
        & (point1.occRS != FREE -> (point1.occSNR = FREE & point1.occNS != FREE))
		& (point2.occSNR != FREE -> (point2.occNS = FREE & point2.occRS = FREE))
        & (point2.occNS != FREE -> (point2.occSNR = FREE & point2.occRS != FREE))
        & (point2.occRS != FREE -> (point2.occSNR = FREE & point2.occNS != FREE))
		& (point3.occSNR != FREE -> (point3.occNS = FREE & point3.occRS = FREE))
        & (point3.occNS != FREE -> (point3.occSNR = FREE & point3.occRS != FREE))
        & (point3.occRS != FREE -> (point3.occSNR = FREE & point3.occNS != FREE))
		& (point5.occSNR != FREE -> (point5.occNS = FREE & point5.occRS = FREE))
        & (point5.occNS != FREE -> (point5.occSNR = FREE & point5.occRS != FREE))
        & (point5.occRS != FREE -> (point5.occSNR = FREE & point5.occNS != FREE))
		& (point6.occSNR != FREE -> (point6.occNS = FREE & point6.occRS = FREE))
        & (point6.occNS != FREE -> (point6.occSNR = FREE & point6.occRS != FREE))
        & (point6.occRS != FREE -> (point6.occSNR = FREE & point6.occNS != FREE))
		& (point7.occSNR != FREE -> (point7.occNS = FREE & point7.occRS = FREE))
        & (point7.occNS != FREE -> (point7.occSNR = FREE & point7.occRS != FREE))
        & (point7.occRS != FREE -> (point7.occSNR = FREE & point7.occNS != FREE))
		& (point4.occSNR != FREE -> (point4.occNS = FREE & point4.occRS = FREE))
        & (point4.occNS != FREE -> (point4.occSNR = FREE & point4.occRS != FREE))
        & (point4.occRS != FREE -> (point4.occSNR = FREE & point4.occNS != FREE))
	);

INVARSPEC
	NAME NoHeadToTailCollisionsDown := (
		(seg5.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg6.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg6.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg7.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg9.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg10.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg10.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg11.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg1.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg2.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg2.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg3.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg18.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg19.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg19.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg20.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg23.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg24.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg24.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg25.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg15.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg16.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg14.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg15.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg27.occDown in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point5.occNS in {COMPLETETRAINOCC, HEADOCC})
			| point5.ACT != NORMAL
		)
		& (seg28.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg27.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg29.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg28.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg26.occDown in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point7.occNS in {COMPLETETRAINOCC, HEADOCC})
			| point7.ACT != NORMAL
		)
	);
INVARSPEC
	NAME NoHeadToTailCollisionsUp := (
		(seg5.occUp in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point1.occSNR in {COMPLETETRAINOCC, HEADOCC})
			| point1.ACT = INTERMEDIATE
		)
		& (seg6.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg5.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg7.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg6.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg9.occUp in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point2.occNS in {COMPLETETRAINOCC, HEADOCC})
			| point2.ACT != NORMAL
		)
		& (seg10.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg9.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg11.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg10.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg1.occUp in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point3.occNS in {COMPLETETRAINOCC, HEADOCC})
			| point3.ACT != NORMAL
		)
		& (seg2.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg1.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg3.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg2.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg18.occUp in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point5.occSNR in {COMPLETETRAINOCC, HEADOCC})
			| point5.ACT = INTERMEDIATE
		)
		& (seg19.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg18.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg20.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg19.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg23.occUp in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point7.occSNR in {COMPLETETRAINOCC, HEADOCC})
			| point7.ACT = INTERMEDIATE
		)
		& (seg24.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg23.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg25.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg24.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg16.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg15.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg15.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg14.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg14.occUp in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point4.occSNR in {COMPLETETRAINOCC, HEADOCC})
			| point4.ACT = INTERMEDIATE
		)
		& (seg27.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg28.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg28.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg29.occUp in {HEADOCC, COMPLETETRAINOCC})
	);

INVARSPEC
	NAME NoPointDerailments := (
		(
			(point1.occNS != FREE -> point1.ACT = NORMAL)
            | (point1.occRS != FREE -> point1.ACT = REVERSE)
            | (point1.occSNR != FREE -> point1.ACT != INTERMEDIATE)
		)
		& (
			(point2.occNS != FREE -> point2.ACT = NORMAL)
            | (point2.occRS != FREE -> point2.ACT = REVERSE)
            | (point2.occSNR != FREE -> point2.ACT != INTERMEDIATE)
		)
		& (
			(point3.occNS != FREE -> point3.ACT = NORMAL)
            | (point3.occRS != FREE -> point3.ACT = REVERSE)
            | (point3.occSNR != FREE -> point3.ACT != INTERMEDIATE)
		)
		& (
			(point5.occNS != FREE -> point5.ACT = NORMAL)
            | (point5.occRS != FREE -> point5.ACT = REVERSE)
            | (point5.occSNR != FREE -> point5.ACT != INTERMEDIATE)
		)
		& (
			(point6.occNS != FREE -> point6.ACT = NORMAL)
            | (point6.occRS != FREE -> point6.ACT = REVERSE)
            | (point6.occSNR != FREE -> point6.ACT != INTERMEDIATE)
		)
		& (
			(point7.occNS != FREE -> point7.ACT = NORMAL)
            | (point7.occRS != FREE -> point7.ACT = REVERSE)
            | (point7.occSNR != FREE -> point7.ACT != INTERMEDIATE)
		)
		& (
			(point4.occNS != FREE -> point4.ACT = NORMAL)
            | (point4.occRS != FREE -> point4.ACT = REVERSE)
            | (point4.occSNR != FREE -> point4.ACT != INTERMEDIATE)
		)
	);

