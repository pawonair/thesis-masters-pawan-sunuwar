		point4.occSNR = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		point4.occSNR = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		point4.occSNR = TAILOCC : FREE;

		TRUE : point4.occSNR;
	esac;

	next(point4.occNS) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		point4.occNS = FREE & point6.occNS in {FREE, ERROROCC} : FREE;

		-- stays FREE if not in USED mode
		point4.occNS = FREE & point4.mode != USED : FREE;

		-- train head may enter if previous segment has head of a train
		point4.occNS = FREE & point4.mode = USED & point4.ACT = NORMAL
		& point6.occNS = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		point4.occNS = FREE & point4.mode = USED & point4.ACT = NORMAL
		& point6.occNS = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		point4.occNS = FREE & point4.mode = USED & point4.ACT = NORMAL
		& point6.occNS = TAILOCC
		: ERROROCC;

		-- ERROROCC if train present and aspect is INTERMEDIATE
		point4.occNS != FREE & point4.ACT = INTERMEDIATE : ERROROCC;

		-- train head leaves or train collects here if head present
		point4.occNS = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		point4.occNS = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		point4.occNS = TAILOCC : FREE;

		TRUE : point4.occNS;
	esac;

	next(point4.occRS) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		point4.occRS = FREE & point3.occRS in {FREE, ERROROCC} : FREE;

		-- stays FREE if not in USED mode
		point4.occRS = FREE & point4.mode != USED : FREE;

		-- train head may enter if previous segment has head of a train
		point4.occRS = FREE & point4.mode = USED & point4.ACT = REVERSE
		& point3.occRS = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		point4.occRS = FREE & point4.mode = USED & point4.ACT = REVERSE
		& point3.occRS = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		point4.occRS = FREE & point4.mode = USED & point4.ACT = REVERSE
		& point3.occRS = TAILOCC
		: ERROROCC;

		-- ERROROCC if train present and aspect is INTERMEDIATE
		point4.occRS != FREE & point4.ACT = INTERMEDIATE : ERROROCC;

		-- train head leaves or train collects here if head present
		point4.occRS = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		point4.occRS = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		point4.occRS = TAILOCC : FREE;

		TRUE : point4.occRS;
	esac;


