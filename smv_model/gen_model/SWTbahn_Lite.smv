-------------------------------------------------------------------------------
-- Interlocking System Moduel --
-- Represents a route state transitions for the train movement
-------------------------------------------------------------------------------
MODULE InterlockingSystem 
VAR
	track : TrackSection;
ASSIGN
	next(track.r0.transition) := case
		track.r0.transition = CAN_DISPATCH
		& track.r46.mode != ALLOCATING & track.r46.mode != LOCKED
		& track.r31.mode != ALLOCATING & track.r31.mode != LOCKED
		& track.r66.mode != ALLOCATING & track.r66.mode != LOCKED
		& track.r25.mode != ALLOCATING & track.r25.mode != LOCKED
