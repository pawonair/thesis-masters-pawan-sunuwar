		& (point7.occNS = HEADOCC -> (seg26.occUp in {TAILOCC, ERROROCC} & seg23.occUp != HEADOCC))
		& (point7.occNS = COMPLETETRAINOCC -> (seg26.occUp = TAILOCC & seg23.occUp != HEADOCC))
