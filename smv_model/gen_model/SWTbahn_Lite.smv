		& (point6.occSNR = TAILOCC -> (seg20.occDown != TAILOCC & (point4.occNS in {HEADOCC, ERROROCC} | point7.occRS in {HEADOCC, ERROROCC})))
		& (point6.occNS = HEADOCC -> (point4.occNS in {TAILOCC, ERROROCC} & seg20.occUp != HEADOCC))
		& (point6.occNS = COMPLETETRAINOCC -> (point4.occNS = TAILOCC & seg20.occUp != HEADOCC))
		& (point6.occNS = TAILOCC -> (point4.occNS != TAILOCC & seg20.occUp in {HEADOCC, ERROROCC}))
		& (point6.occRS = HEADOCC -> (point7.occRS in {TAILOCC, ERROROCC} & seg20.occUp != HEADOCC))
		& (point6.occRS = COMPLETETRAINOCC -> (point7.occRS = TAILOCC & seg20.occUp != HEADOCC))
		& (point6.occRS = TAILOCC -> (point7.occRS != TAILOCC & seg20.occUp in {HEADOCC, ERROROCC}))
		& (point7.occSNR = HEADOCC -> (seg23.occDown in {TAILOCC, ERROROCC} & seg26.occDown != HEADOCC & point6.occRS != HEADOCC))
		& (point7.occSNR = COMPLETETRAINOCC -> (seg23.occDown = TAILOCC & seg26.occDown != HEADOCC & point6.occRS != HEADOCC))
