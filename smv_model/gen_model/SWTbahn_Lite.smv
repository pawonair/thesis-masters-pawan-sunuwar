		-- ERROROCC if previous segment has tail but this segment has no head
		point7.occRS = FREE & point7.mode = USED & point7.ACT = REVERSE
		& point6.occRS = TAILOCC
		: ERROROCC;

		-- ERROROCC if train present and aspect is INTERMEDIATE
		point7.occRS != FREE & point7.ACT = INTERMEDIATE : ERROROCC;

		-- train head leaves or train collects here if head present
		point7.occRS = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		point7.occRS = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		point7.occRS = TAILOCC : FREE;

		TRUE : point7.occRS;
	esac;

	-- point4
	next(point4.occSNR) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		point4.occSNR = FREE & seg14.occDown in {FREE, ERROROCC} : FREE;

		-- stays FREE if not in USED mode
		point4.occSNR = FREE & point4.mode != USED : FREE;

		-- train head may enter if previous segment has head of a train
		point4.occSNR = FREE & point4.mode = USED & point4.ACT != INTERMEDIATE
		& seg14.occDown = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		point4.occSNR = FREE & point4.mode = USED & point4.ACT != INTERMEDIATE
		& seg14.occDown = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		point4.occSNR = FREE & point4.mode = USED & point4.ACT != INTERMEDIATE
		& seg14.occDown = TAILOCC
		: ERROROCC;

		-- ERROROCC if train present and aspect is INTERMEDIATE
		point4.occSNR != FREE & point4.ACT = INTERMEDIATE : ERROROCC;

