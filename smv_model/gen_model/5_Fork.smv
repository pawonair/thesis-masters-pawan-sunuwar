		& track.seg20.mode = EXLOCKED
		& track.seg19.mode = EXLOCKED
		& track.seg18.mode = EXLOCKED
        & TRUE
		: LOCKED;

		track.r5.mode = LOCKED
		& track.signal7.ACT = GO
		& track.point6.occSNR != FREE
