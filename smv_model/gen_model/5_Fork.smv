		track.r4.mode = LOCKED
		& track.signal5.ACT = GO
		& track.point2.occSNR != FREE
		: OCCUPIED;

		track.r4.mode = OCCUPIED
		& track.seg5.occDown in {HEADOCC, COMPLETETRAINOCC}
		& track.seg5.mode = USED
