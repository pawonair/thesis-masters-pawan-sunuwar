LTLSPEC
	NAME r7ElementReleaseWaveSeg20ToSeg19 :=
		G((seg19.mode = USED & seg20.mode = AVAILABLE) -> F(seg19.mode = AVAILABLE));

-- Route mutual exclusion --
LTLSPEC
	NAME r0AndR7MutuallyExclusive :=
		G(!(r0.mode = OCCUPIED & r7.mode = OCCUPIED));

LTLSPEC
	NAME r0AndR5MutuallyExclusive :=
		G(!(r0.mode = OCCUPIED & r5.mode = OCCUPIED));

LTLSPEC
	NAME r0AndR1MutuallyExclusive :=
		G(!(r0.mode = OCCUPIED & r1.mode = OCCUPIED));

LTLSPEC
	NAME r1AndR7MutuallyExclusive :=
		G(!(r1.mode = OCCUPIED & r7.mode = OCCUPIED));

LTLSPEC
	NAME r1AndR5MutuallyExclusive :=
		G(!(r1.mode = OCCUPIED & r5.mode = OCCUPIED));

LTLSPEC
	NAME r2AndR5MutuallyExclusive :=
		G(!(r2.mode = OCCUPIED & r5.mode = OCCUPIED));

LTLSPEC
	NAME r2AndR7MutuallyExclusive :=
		G(!(r2.mode = OCCUPIED & r7.mode = OCCUPIED));

LTLSPEC
	NAME r2AndR6MutuallyExclusive :=
		G(!(r2.mode = OCCUPIED & r6.mode = OCCUPIED));

LTLSPEC
	NAME r2AndR3MutuallyExclusive :=
		G(!(r2.mode = OCCUPIED & r3.mode = OCCUPIED));

LTLSPEC
	NAME r2AndR4MutuallyExclusive :=
		G(!(r2.mode = OCCUPIED & r4.mode = OCCUPIED));

LTLSPEC
	NAME r3AndR4MutuallyExclusive :=
		G(!(r3.mode = OCCUPIED & r4.mode = OCCUPIED));

LTLSPEC
	NAME r3AndR6MutuallyExclusive :=
		G(!(r3.mode = OCCUPIED & r6.mode = OCCUPIED));

LTLSPEC
	NAME r4AndR6MutuallyExclusive :=
		G(!(r4.mode = OCCUPIED & r6.mode = OCCUPIED));

LTLSPEC
	NAME r5AndR7MutuallyExclusive :=
		G(!(r5.mode = OCCUPIED & r7.mode = OCCUPIED));

-- Sanity checks: add manually based on extras_config.yml initial train positions
-- LTLSPEC NAME SanityCheckPos := F(G(<start_seg>.occ<Dir> = FREE & ...));
-- LTLSPEC NAME SanityCheckNeg := !(F(G(<start_seg>.occ<Dir> = FREE & ...)));

-------------------------------------------------------------------------------
-- Interlocking System Moduel --
-- Represents a route state transitions for the train movement
-------------------------------------------------------------------------------
MODULE InterlockingSystem 
VAR
	track : TrackSection;
ASSIGN
	next(track.r0.transition) := case
		track.r0.transition = CAN_DISPATCH
		& track.r7.mode != ALLOCATING & track.r7.mode != LOCKED
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
        & track.point6.occSNR = FREE & track.point6.occNS = FREE & track.point6.occRS = FREE
		& track.seg14.occDown = FREE & track.seg14.occUp = FREE
		& track.seg15.occDown = FREE & track.seg15.occUp = FREE
		& track.seg16.occDown = FREE & track.seg16.occUp = FREE
        & track.point6.mode = AVAILABLE
		& track.seg14.mode = AVAILABLE
		& track.seg15.mode = AVAILABLE
		& track.seg16.mode = AVAILABLE
        & TRUE
		: CAN_ALLOCATE;

		track.r0.transition = CAN_ALLOCATE
		& track.r7.mode != ALLOCATING & track.r7.mode != LOCKED
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
        & track.signal10.ACT = STOP
		& track.signal8.ACT = STOP
        & track.point6.ACT = NORMAL
        & track.point6.occSNR = FREE & track.point6.occNS = FREE & track.point6.occRS = FREE
		& track.seg14.occDown = FREE & track.seg14.occUp = FREE
		& track.seg15.occDown = FREE & track.seg15.occUp = FREE
		& track.seg16.occDown = FREE & track.seg16.occUp = FREE
        & track.point6.mode = EXLOCKED
		& track.seg14.mode = EXLOCKED
		& track.seg15.mode = EXLOCKED
		& track.seg16.mode = EXLOCKED
        & TRUE
		: CAN_LOCK;

		track.r0.transition = CAN_LOCK
		& track.r0.mode = LOCKED
		& track.signal10.ACT = GO
		& track.point6.occNS != FREE
		: CAN_OCCUPY;

		track.r0.transition = CAN_OCCUPY
		& track.r0.mode = FREE
		: CAN_DISPATCH;

		TRUE : track.r0.transition;
	esac;

	next(track.r0.mode) := case
		track.r0.mode = FREE
		& track.r0.transition = CAN_DISPATCH
		: MARKED;

		track.r0.mode = MARKED
		& track.r7.mode != ALLOCATING & track.r7.mode != LOCKED
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
        & track.point6.occSNR = FREE & track.point6.occNS = FREE & track.point6.occRS = FREE
		& track.seg14.occDown = FREE & track.seg14.occUp = FREE
		& track.seg15.occDown = FREE & track.seg15.occUp = FREE
		& track.seg16.occDown = FREE & track.seg16.occUp = FREE
        & track.point6.mode = AVAILABLE
		& track.seg14.mode = AVAILABLE
		& track.seg15.mode = AVAILABLE
		& track.seg16.mode = AVAILABLE
        & TRUE
		: ALLOCATING;

		track.r0.mode = ALLOCATING
		& track.r7.mode != ALLOCATING & track.r7.mode != LOCKED
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
        & track.signal10.ACT = STOP
		& track.signal8.ACT = STOP
        & track.point6.ACT = NORMAL
        & track.point6.occSNR = FREE & track.point6.occNS = FREE & track.point6.occRS = FREE
		& track.seg14.occDown = FREE & track.seg14.occUp = FREE
		& track.seg15.occDown = FREE & track.seg15.occUp = FREE
		& track.seg16.occDown = FREE & track.seg16.occUp = FREE
        & track.point6.mode = EXLOCKED
		& track.seg14.mode = EXLOCKED
		& track.seg15.mode = EXLOCKED
		& track.seg16.mode = EXLOCKED
        & TRUE
		: LOCKED;

		track.r0.mode = LOCKED
		& track.signal10.ACT = GO
		& track.point6.occNS != FREE
		: OCCUPIED;

		track.r0.mode = OCCUPIED
		& track.seg16.occUp in {HEADOCC, COMPLETETRAINOCC}
		& track.seg16.mode = USED
		& track.seg16.prev = RELEASED
		: FREE;

		TRUE : track.r0.mode;
	esac;

	next(track.r1.transition) := case
		track.r1.transition = CAN_DISPATCH
		& track.r7.mode != ALLOCATING & track.r7.mode != LOCKED
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
        & track.point6.occSNR = FREE & track.point6.occNS = FREE & track.point6.occRS = FREE
		& track.seg23.occDown = FREE & track.seg23.occUp = FREE
		& track.seg24.occDown = FREE & track.seg24.occUp = FREE
		& track.seg25.occDown = FREE & track.seg25.occUp = FREE
        & track.point6.mode = AVAILABLE
		& track.seg23.mode = AVAILABLE
		& track.seg24.mode = AVAILABLE
		& track.seg25.mode = AVAILABLE
        & TRUE
		: CAN_ALLOCATE;

		track.r1.transition = CAN_ALLOCATE
		& track.r7.mode != ALLOCATING & track.r7.mode != LOCKED
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
        & track.signal10.ACT = STOP
		& track.signal12.ACT = STOP
        & track.point6.ACT = REVERSE
        & track.point6.occSNR = FREE & track.point6.occNS = FREE & track.point6.occRS = FREE
		& track.seg23.occDown = FREE & track.seg23.occUp = FREE
		& track.seg24.occDown = FREE & track.seg24.occUp = FREE
		& track.seg25.occDown = FREE & track.seg25.occUp = FREE
        & track.point6.mode = EXLOCKED
		& track.seg23.mode = EXLOCKED
		& track.seg24.mode = EXLOCKED
		& track.seg25.mode = EXLOCKED
        & TRUE
		: CAN_LOCK;

		track.r1.transition = CAN_LOCK
		& track.r1.mode = LOCKED
		& track.signal10.ACT = GO
		& track.point6.occRS != FREE
		: CAN_OCCUPY;

		track.r1.transition = CAN_OCCUPY
		& track.r1.mode = FREE
		: CAN_DISPATCH;

		TRUE : track.r1.transition;
	esac;

	next(track.r1.mode) := case
		track.r1.mode = FREE
		& track.r1.transition = CAN_DISPATCH
		: MARKED;

		track.r1.mode = MARKED
		& track.r7.mode != ALLOCATING & track.r7.mode != LOCKED
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
        & track.point6.occSNR = FREE & track.point6.occNS = FREE & track.point6.occRS = FREE
		& track.seg23.occDown = FREE & track.seg23.occUp = FREE
		& track.seg24.occDown = FREE & track.seg24.occUp = FREE
		& track.seg25.occDown = FREE & track.seg25.occUp = FREE
        & track.point6.mode = AVAILABLE
		& track.seg23.mode = AVAILABLE
		& track.seg24.mode = AVAILABLE
		& track.seg25.mode = AVAILABLE
        & TRUE
		: ALLOCATING;

		track.r1.mode = ALLOCATING
		& track.r7.mode != ALLOCATING & track.r7.mode != LOCKED
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
        & track.signal10.ACT = STOP
		& track.signal12.ACT = STOP
        & track.point6.ACT = REVERSE
        & track.point6.occSNR = FREE & track.point6.occNS = FREE & track.point6.occRS = FREE
		& track.seg23.occDown = FREE & track.seg23.occUp = FREE
		& track.seg24.occDown = FREE & track.seg24.occUp = FREE
		& track.seg25.occDown = FREE & track.seg25.occUp = FREE
        & track.point6.mode = EXLOCKED
		& track.seg23.mode = EXLOCKED
		& track.seg24.mode = EXLOCKED
		& track.seg25.mode = EXLOCKED
        & TRUE
		: LOCKED;

		track.r1.mode = LOCKED
		& track.signal10.ACT = GO
		& track.point6.occRS != FREE
		: OCCUPIED;

		track.r1.mode = OCCUPIED
		& track.seg25.occUp in {HEADOCC, COMPLETETRAINOCC}
		& track.seg25.mode = USED
		& track.seg25.prev = RELEASED
		: FREE;

		TRUE : track.r1.mode;
	esac;

	next(track.r2.transition) := case
		track.r2.transition = CAN_DISPATCH
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r7.mode != ALLOCATING & track.r7.mode != LOCKED
		& track.r6.mode != ALLOCATING & track.r6.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
        & track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.seg18.occDown = FREE & track.seg18.occUp = FREE
		& track.seg19.occDown = FREE & track.seg19.occUp = FREE
		& track.seg20.occDown = FREE & track.seg20.occUp = FREE
        & track.point2.mode = AVAILABLE
		& track.seg18.mode = AVAILABLE
		& track.seg19.mode = AVAILABLE
		& track.seg20.mode = AVAILABLE
        & TRUE
		: CAN_ALLOCATE;

		track.r2.transition = CAN_ALLOCATE
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r7.mode != ALLOCATING & track.r7.mode != LOCKED
		& track.r6.mode != ALLOCATING & track.r6.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
        & track.signal4.ACT = STOP
		& track.signal10.ACT = STOP
        & track.point2.ACT = REVERSE
        & track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.seg18.occDown = FREE & track.seg18.occUp = FREE
		& track.seg19.occDown = FREE & track.seg19.occUp = FREE
		& track.seg20.occDown = FREE & track.seg20.occUp = FREE
        & track.point2.mode = EXLOCKED
		& track.seg18.mode = EXLOCKED
		& track.seg19.mode = EXLOCKED
		& track.seg20.mode = EXLOCKED
        & TRUE
		: CAN_LOCK;

		track.r2.transition = CAN_LOCK
		& track.r2.mode = LOCKED
		& track.signal4.ACT = GO
		& track.point2.occRS != FREE
		: CAN_OCCUPY;

		track.r2.transition = CAN_OCCUPY
		& track.r2.mode = FREE
		: CAN_DISPATCH;

		TRUE : track.r2.transition;
	esac;

	next(track.r2.mode) := case
		track.r2.mode = FREE
		& track.r2.transition = CAN_DISPATCH
		: MARKED;

		track.r2.mode = MARKED
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r7.mode != ALLOCATING & track.r7.mode != LOCKED
		& track.r6.mode != ALLOCATING & track.r6.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
        & track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.seg18.occDown = FREE & track.seg18.occUp = FREE
		& track.seg19.occDown = FREE & track.seg19.occUp = FREE
		& track.seg20.occDown = FREE & track.seg20.occUp = FREE
        & track.point2.mode = AVAILABLE
		& track.seg18.mode = AVAILABLE
		& track.seg19.mode = AVAILABLE
		& track.seg20.mode = AVAILABLE
        & TRUE
		: ALLOCATING;

		track.r2.mode = ALLOCATING
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r7.mode != ALLOCATING & track.r7.mode != LOCKED
		& track.r6.mode != ALLOCATING & track.r6.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
        & track.signal4.ACT = STOP
		& track.signal10.ACT = STOP
        & track.point2.ACT = REVERSE
        & track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.seg18.occDown = FREE & track.seg18.occUp = FREE
		& track.seg19.occDown = FREE & track.seg19.occUp = FREE
		& track.seg20.occDown = FREE & track.seg20.occUp = FREE
        & track.point2.mode = EXLOCKED
		& track.seg18.mode = EXLOCKED
		& track.seg19.mode = EXLOCKED
		& track.seg20.mode = EXLOCKED
        & TRUE
		: LOCKED;

		track.r2.mode = LOCKED
		& track.signal4.ACT = GO
		& track.point2.occRS != FREE
		: OCCUPIED;

		track.r2.mode = OCCUPIED
		& track.seg20.occUp in {HEADOCC, COMPLETETRAINOCC}
		& track.seg20.mode = USED
		& track.seg20.prev = RELEASED
		: FREE;

		TRUE : track.r2.mode;
	esac;

	next(track.r3.transition) := case
		track.r3.transition = CAN_DISPATCH
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
		& track.r6.mode != ALLOCATING & track.r6.mode != LOCKED
        & track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.seg9.occDown = FREE & track.seg9.occUp = FREE
		& track.seg10.occDown = FREE & track.seg10.occUp = FREE
		& track.seg11.occDown = FREE & track.seg11.occUp = FREE
        & track.point2.mode = AVAILABLE
		& track.seg9.mode = AVAILABLE
		& track.seg10.mode = AVAILABLE
		& track.seg11.mode = AVAILABLE
        & TRUE
		: CAN_ALLOCATE;

		track.r3.transition = CAN_ALLOCATE
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
		& track.r6.mode != ALLOCATING & track.r6.mode != LOCKED
        & track.signal4.ACT = STOP
		& track.signal6.ACT = STOP
        & track.point2.ACT = NORMAL
        & track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.seg9.occDown = FREE & track.seg9.occUp = FREE
		& track.seg10.occDown = FREE & track.seg10.occUp = FREE
		& track.seg11.occDown = FREE & track.seg11.occUp = FREE
        & track.point2.mode = EXLOCKED
		& track.seg9.mode = EXLOCKED
		& track.seg10.mode = EXLOCKED
		& track.seg11.mode = EXLOCKED
        & TRUE
		: CAN_LOCK;

		track.r3.transition = CAN_LOCK
		& track.r3.mode = LOCKED
		& track.signal4.ACT = GO
		& track.point2.occNS != FREE
		: CAN_OCCUPY;

		track.r3.transition = CAN_OCCUPY
		& track.r3.mode = FREE
		: CAN_DISPATCH;

		TRUE : track.r3.transition;
	esac;

	next(track.r3.mode) := case
		track.r3.mode = FREE
		& track.r3.transition = CAN_DISPATCH
		: MARKED;

		track.r3.mode = MARKED
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
		& track.r6.mode != ALLOCATING & track.r6.mode != LOCKED
        & track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.seg9.occDown = FREE & track.seg9.occUp = FREE
		& track.seg10.occDown = FREE & track.seg10.occUp = FREE
		& track.seg11.occDown = FREE & track.seg11.occUp = FREE
        & track.point2.mode = AVAILABLE
		& track.seg9.mode = AVAILABLE
		& track.seg10.mode = AVAILABLE
		& track.seg11.mode = AVAILABLE
        & TRUE
		: ALLOCATING;

		track.r3.mode = ALLOCATING
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
		& track.r6.mode != ALLOCATING & track.r6.mode != LOCKED
        & track.signal4.ACT = STOP
		& track.signal6.ACT = STOP
        & track.point2.ACT = NORMAL
        & track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.seg9.occDown = FREE & track.seg9.occUp = FREE
		& track.seg10.occDown = FREE & track.seg10.occUp = FREE
		& track.seg11.occDown = FREE & track.seg11.occUp = FREE
        & track.point2.mode = EXLOCKED
		& track.seg9.mode = EXLOCKED
		& track.seg10.mode = EXLOCKED
		& track.seg11.mode = EXLOCKED
        & TRUE
		: LOCKED;

		track.r3.mode = LOCKED
		& track.signal4.ACT = GO
		& track.point2.occNS != FREE
		: OCCUPIED;

		track.r3.mode = OCCUPIED
		& track.seg11.occUp in {HEADOCC, COMPLETETRAINOCC}
		& track.seg11.mode = USED
		& track.seg11.prev = RELEASED
		: FREE;

		TRUE : track.r3.mode;
	esac;

	next(track.r4.transition) := case
		track.r4.transition = CAN_DISPATCH
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
		& track.r6.mode != ALLOCATING & track.r6.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
        & track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
        & track.point2.mode = AVAILABLE
		& track.seg7.mode = AVAILABLE
		& track.seg6.mode = AVAILABLE
		& track.seg5.mode = AVAILABLE
        & TRUE
		: CAN_ALLOCATE;

		track.r4.transition = CAN_ALLOCATE
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
		& track.r6.mode != ALLOCATING & track.r6.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
        & track.signal5.ACT = STOP
		& track.signal3.ACT = STOP
        & track.point2.ACT = NORMAL
        & track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
        & track.point2.mode = EXLOCKED
		& track.seg7.mode = EXLOCKED
		& track.seg6.mode = EXLOCKED
		& track.seg5.mode = EXLOCKED
        & TRUE
		: CAN_LOCK;

		track.r4.transition = CAN_LOCK
		& track.r4.mode = LOCKED
		& track.signal5.ACT = GO
		& track.point2.occSNR != FREE
		: CAN_OCCUPY;

		track.r4.transition = CAN_OCCUPY
		& track.r4.mode = FREE
		: CAN_DISPATCH;

		TRUE : track.r4.transition;
	esac;

	next(track.r4.mode) := case
		track.r4.mode = FREE
		& track.r4.transition = CAN_DISPATCH
		: MARKED;

		track.r4.mode = MARKED
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
		& track.r6.mode != ALLOCATING & track.r6.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
        & track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
        & track.point2.mode = AVAILABLE
		& track.seg7.mode = AVAILABLE
		& track.seg6.mode = AVAILABLE
		& track.seg5.mode = AVAILABLE
        & TRUE
		: ALLOCATING;

		track.r4.mode = ALLOCATING
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
		& track.r6.mode != ALLOCATING & track.r6.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
        & track.signal5.ACT = STOP
		& track.signal3.ACT = STOP
        & track.point2.ACT = NORMAL
        & track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
