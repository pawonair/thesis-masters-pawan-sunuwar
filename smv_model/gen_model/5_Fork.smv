		seg10.occDown = FREE & seg10.mode != AVAILABLE
		& seg11.occDown = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg10.occDown = FREE & seg10.mode != AVAILABLE
		& seg11.occDown = TAILOCC
		: ERROROCC;

		-- train head leaves or train collects here if head present
		seg10.occDown = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		seg10.occDown = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		seg10.occDown = TAILOCC : FREE;

		TRUE : seg10.occDown;
	esac;

	next(seg10.occUp) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg10.occUp = FREE & seg9.occUp in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg10.occUp = FREE & seg10.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg10.occUp = FREE & seg10.mode != AVAILABLE
		& seg9.occUp = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg10.occUp = FREE & seg10.mode != AVAILABLE
		& seg9.occUp = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg10.occUp = FREE & seg10.mode != AVAILABLE
		& seg9.occUp = TAILOCC
		: ERROROCC;

		-- train head leaves or train collects here if head present
		seg10.occUp = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		seg10.occUp = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		seg10.occUp = TAILOCC : FREE;

		TRUE : seg10.occUp;
	esac;

	-- seg11
	next(seg11.occDown) := case
		-- stays FREE as no train can enter from out of bounds
		seg11.occDown = FREE : FREE;

		-- ERROROCC if head of a train is here, as the tail has no previous segment
		seg11.occDown = HEADOCC : ERROROCC;

		-- stays COMPLETETRAINOCC if the segment is not in USED mode
		seg11.occDown = COMPLETETRAINOCC & seg11.mode != USED : COMPLETETRAINOCC;

		-- train moves on with head if train is present
		seg11.occDown = COMPLETETRAINOCC & seg11.mode = USED : TAILOCC;

		-- train tail leaves if tail is present
		seg11.occDown = TAILOCC : FREE;

		TRUE : seg11.occDown;
	esac;

	next(seg11.occUp) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg11.occUp = FREE & seg10.occUp in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg11.occUp = FREE & seg11.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg11.occUp = FREE & seg11.mode != AVAILABLE
		& seg10.occUp = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg11.occUp = FREE & seg11.mode != AVAILABLE
		& seg10.occUp = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg11.occUp = FREE & seg11.mode != AVAILABLE
		& seg10.occUp = TAILOCC
		: ERROROCC;

		-- train collects here if head present and signal is STOP
		seg11.occUp = HEADOCC & signal6.ACT = STOP : COMPLETETRAINOCC;

		-- ERROROCC if train head present and signal is GO
		seg11.occUp = HEADOCC & signal6.ACT = GO : ERROROCC;

		-- train stays here and signal is STOP
		seg11.occUp = COMPLETETRAINOCC & signal6.ACT = STOP : COMPLETETRAINOCC;

		-- ERROROCC if train in COMPLETETRAINOCC and signal is GO
		seg11.occUp = COMPLETETRAINOCC & signal6.ACT = GO : ERROROCC;

		-- ERROROCC if train tail is present
		seg11.occUp = TAILOCC : ERROROCC;

		TRUE : seg11.occUp;
	esac;

	-- seg7
	next(seg7.occDown) := case
		-- stays FREE if predecessor point has no train (per ACT position)
		seg7.occDown = FREE & ((point2.ACT = NORMAL & point2.occNS in {FREE, ERROROCC}) | (point2.ACT = REVERSE & point2.occRS in {FREE, ERROROCC})) : FREE;

		-- stays FREE if not allocated
		seg7.occDown = FREE & seg7.mode = AVAILABLE : FREE;

		-- non-deterministic head entry with point2.ACT = NORMAL
		seg7.occDown = FREE & seg7.mode != AVAILABLE
		& point2.ACT = NORMAL & point2.occNS = HEADOCC
		: {HEADOCC, FREE};

		-- deterministic head entry with point2.ACT = NORMAL
		seg7.occDown = FREE & seg7.mode != AVAILABLE
		& point2.ACT = NORMAL & point2.occNS = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC: tail without head with point2.ACT = NORMAL
		seg7.occDown = FREE & seg7.mode != AVAILABLE
		& point2.ACT = NORMAL & point2.occNS = TAILOCC
		: ERROROCC;

		-- non-deterministic head entry with point2.ACT = REVERSE
		seg7.occDown = FREE & seg7.mode != AVAILABLE
		& point2.ACT = REVERSE & point2.occRS = HEADOCC
		: {HEADOCC, FREE};

		-- deterministic head entry with point2.ACT = REVERSE
		seg7.occDown = FREE & seg7.mode != AVAILABLE
		& point2.ACT = REVERSE & point2.occRS = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC: tail without head with point2.ACT = REVERSE
		seg7.occDown = FREE & seg7.mode != AVAILABLE
		& point2.ACT = REVERSE & point2.occRS = TAILOCC
		: ERROROCC;

		-- train head leaves or train collects here if head present
		seg7.occDown = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		seg7.occDown = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		seg7.occDown = TAILOCC : FREE;

		TRUE : seg7.occDown;
	esac;

	next(seg7.occUp) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg7.occUp = FREE & seg6.occUp in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg7.occUp = FREE & seg7.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg7.occUp = FREE & seg7.mode != AVAILABLE
		& seg6.occUp = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg7.occUp = FREE & seg7.mode != AVAILABLE
		& seg6.occUp = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg7.occUp = FREE & seg7.mode != AVAILABLE
		& seg6.occUp = TAILOCC
		: ERROROCC;

		-- train head leaves or train collects here if head present and signal is GO
		seg7.occUp = HEADOCC & signal4.ACT = GO : {COMPLETETRAINOCC, TAILOCC};

		-- train collects here if head present and signal is STOP
		seg7.occUp = HEADOCC & signal4.ACT = STOP : COMPLETETRAINOCC;

		-- train stays here if train is present and signal is STOP
		seg7.occUp = COMPLETETRAINOCC & signal4.ACT = STOP : COMPLETETRAINOCC;

		-- train moves on with head if train is present and signal is GO
		seg7.occUp = COMPLETETRAINOCC & signal4.ACT = GO : TAILOCC;

		-- train tail leaves if tail is present
		seg7.occUp = TAILOCC : FREE;

		TRUE : seg7.occUp;
	esac;

	-- seg6
	next(seg6.occDown) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg6.occDown = FREE & seg7.occDown in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg6.occDown = FREE & seg6.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg6.occDown = FREE & seg6.mode != AVAILABLE
		& seg7.occDown = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg6.occDown = FREE & seg6.mode != AVAILABLE
		& seg7.occDown = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg6.occDown = FREE & seg6.mode != AVAILABLE
		& seg7.occDown = TAILOCC
		: ERROROCC;

		-- train head leaves or train collects here if head present
		seg6.occDown = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		seg6.occDown = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		seg6.occDown = TAILOCC : FREE;

		TRUE : seg6.occDown;
	esac;

	next(seg6.occUp) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg6.occUp = FREE & seg5.occUp in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg6.occUp = FREE & seg6.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg6.occUp = FREE & seg6.mode != AVAILABLE
		& seg5.occUp = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg6.occUp = FREE & seg6.mode != AVAILABLE
		& seg5.occUp = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg6.occUp = FREE & seg6.mode != AVAILABLE
		& seg5.occUp = TAILOCC
		: ERROROCC;

		-- train head leaves or train collects here if head present
		seg6.occUp = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		seg6.occUp = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		seg6.occUp = TAILOCC : FREE;

		TRUE : seg6.occUp;
	esac;

	-- seg5
	next(seg5.occDown) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg5.occDown = FREE & seg6.occDown in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg5.occDown = FREE & seg5.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg5.occDown = FREE & seg5.mode != AVAILABLE
		& seg6.occDown = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg5.occDown = FREE & seg5.mode != AVAILABLE
		& seg6.occDown = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg5.occDown = FREE & seg5.mode != AVAILABLE
		& seg6.occDown = TAILOCC
		: ERROROCC;

		-- train collects here if head present and signal is STOP
		seg5.occDown = HEADOCC & signal3.ACT = STOP : COMPLETETRAINOCC;

		-- ERROROCC if train head present and signal is GO
		seg5.occDown = HEADOCC & signal3.ACT = GO : ERROROCC;

		-- train stays here and signal is STOP
		seg5.occDown = COMPLETETRAINOCC & signal3.ACT = STOP : COMPLETETRAINOCC;

		-- ERROROCC if train in COMPLETETRAINOCC and signal is GO
		seg5.occDown = COMPLETETRAINOCC & signal3.ACT = GO : ERROROCC;

		-- ERROROCC if train tail is present
		seg5.occDown = TAILOCC : ERROROCC;

		TRUE : seg5.occDown;
	esac;

	next(seg5.occUp) := case
		-- stays FREE as no train can enter from out of bounds
		seg5.occUp = FREE : FREE;

		-- ERROROCC if head of a train is here, as the tail has no previous segment
		seg5.occUp = HEADOCC : ERROROCC;

		-- stays COMPLETETRAINOCC if the segment is not in USED mode
		seg5.occUp = COMPLETETRAINOCC & seg5.mode != USED : COMPLETETRAINOCC;

		-- train moves on with head if train is present
		seg5.occUp = COMPLETETRAINOCC & seg5.mode = USED : TAILOCC;

		-- train tail leaves if tail is present
		seg5.occUp = TAILOCC : FREE;

		TRUE : seg5.occUp;
	esac;

	-- POINTS OCCUPANCY NEXT --
	-- point6
	next(point6.occSNR) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		point6.occSNR = FREE & seg20.occUp in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		point6.occSNR = FREE & point6.mode = AVAILABLE : FREE;

		-- train blocked at signal STOP regardless of predecessor state
		point6.occSNR = FREE & point6.mode != AVAILABLE & point6.ACT != INTERMEDIATE
		& seg20.occUp in {HEADOCC, COMPLETETRAINOCC} & signal10.ACT = STOP
		: FREE;

		-- non-deterministic head entry if previous segment has head and signal is GO
		point6.occSNR = FREE & point6.mode != AVAILABLE & point6.ACT != INTERMEDIATE
		& seg20.occUp = HEADOCC & signal10.ACT = GO
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train and signal is GO
		point6.occSNR = FREE & point6.mode != AVAILABLE & point6.ACT != INTERMEDIATE
		& seg20.occUp = COMPLETETRAINOCC & signal10.ACT = GO
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		-- and signal is GO
		point6.occSNR = FREE & point6.mode != AVAILABLE & point6.ACT != INTERMEDIATE
		& seg20.occUp = TAILOCC & signal10.ACT = GO
		: ERROROCC;

		-- ERROROCC if train present and aspect is INTERMEDIATE
		point6.occSNR != FREE & point6.ACT = INTERMEDIATE : ERROROCC;

		-- train head leaves or train collects here if head present
		point6.occSNR = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		point6.occSNR = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		point6.occSNR = TAILOCC : FREE;

		TRUE : point6.occSNR;
	esac;

	next(point6.occNS) := case
		-- stays FREE as no train can enter from out of bounds
		point6.occNS = FREE : FREE;

		-- ERROROCC if head of a train is here, as the tail has no previous segment
		point6.occNS = HEADOCC : ERROROCC;

		-- stays COMPLETETRAINOCC if the segment is not in USED mode
		point6.occNS = COMPLETETRAINOCC & point6.mode != USED : COMPLETETRAINOCC;

		-- train moves on with head if train is present
		point6.occNS = COMPLETETRAINOCC & point6.mode = USED : TAILOCC;

		-- train tail leaves if tail is present
		point6.occNS = TAILOCC : FREE;

		TRUE : point6.occNS;
	esac;

	next(point6.occRS) := case
		-- stays FREE as no train can enter from out of bounds
		point6.occRS = FREE : FREE;

		-- ERROROCC if head of a train is here, as the tail has no previous segment
		point6.occRS = HEADOCC : ERROROCC;

		-- stays COMPLETETRAINOCC if the segment is not in USED mode
		point6.occRS = COMPLETETRAINOCC & point6.mode != USED : COMPLETETRAINOCC;

		-- train moves on with head if train is present
		point6.occRS = COMPLETETRAINOCC & point6.mode = USED : TAILOCC;

		-- train tail leaves if tail is present
		point6.occRS = TAILOCC : FREE;

		TRUE : point6.occRS;
	esac;

	-- point2
	next(point2.occSNR) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		point2.occSNR = FREE & seg7.occUp in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		point2.occSNR = FREE & point2.mode = AVAILABLE : FREE;

		-- train blocked at signal STOP regardless of predecessor state
		point2.occSNR = FREE & point2.mode != AVAILABLE & point2.ACT != INTERMEDIATE
		& seg7.occUp in {HEADOCC, COMPLETETRAINOCC} & signal4.ACT = STOP
		: FREE;

		-- non-deterministic head entry if previous segment has head and signal is GO
		point2.occSNR = FREE & point2.mode != AVAILABLE & point2.ACT != INTERMEDIATE
		& seg7.occUp = HEADOCC & signal4.ACT = GO
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train and signal is GO
		point2.occSNR = FREE & point2.mode != AVAILABLE & point2.ACT != INTERMEDIATE
		& seg7.occUp = COMPLETETRAINOCC & signal4.ACT = GO
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		-- and signal is GO
		point2.occSNR = FREE & point2.mode != AVAILABLE & point2.ACT != INTERMEDIATE
		& seg7.occUp = TAILOCC & signal4.ACT = GO
		: ERROROCC;

		-- ERROROCC if train present and aspect is INTERMEDIATE
		point2.occSNR != FREE & point2.ACT = INTERMEDIATE : ERROROCC;

		-- train head leaves or train collects here if head present
		point2.occSNR = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		point2.occSNR = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		point2.occSNR = TAILOCC : FREE;

		TRUE : point2.occSNR;
	esac;

	next(point2.occNS) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		point2.occNS = FREE & seg9.occDown in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		point2.occNS = FREE & point2.mode = AVAILABLE : FREE;

		-- train blocked at signal STOP regardless of predecessor state
		point2.occNS = FREE & point2.mode != AVAILABLE & point2.ACT = NORMAL
		& seg9.occDown in {HEADOCC, COMPLETETRAINOCC} & signal5.ACT = STOP
		: FREE;

		-- non-deterministic head entry if previous segment has head and signal is GO
		point2.occNS = FREE & point2.mode != AVAILABLE & point2.ACT = NORMAL
		& seg9.occDown = HEADOCC & signal5.ACT = GO
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train and signal is GO
		point2.occNS = FREE & point2.mode != AVAILABLE & point2.ACT = NORMAL
		& seg9.occDown = COMPLETETRAINOCC & signal5.ACT = GO
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		-- and signal is GO
		point2.occNS = FREE & point2.mode != AVAILABLE & point2.ACT = NORMAL
		& seg9.occDown = TAILOCC & signal5.ACT = GO
		: ERROROCC;

		-- ERROROCC if train present and aspect is INTERMEDIATE
		point2.occNS != FREE & point2.ACT = INTERMEDIATE : ERROROCC;

		-- train head leaves or train collects here if head present
		point2.occNS = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		point2.occNS = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		point2.occNS = TAILOCC : FREE;

		TRUE : point2.occNS;
	esac;

	next(point2.occRS) := case
		-- stays FREE as no train can enter from out of bounds
		point2.occRS = FREE : FREE;

		-- ERROROCC if head of a train is here, as the tail has no previous segment
		point2.occRS = HEADOCC : ERROROCC;

		-- stays COMPLETETRAINOCC if the segment is not in USED mode
		point2.occRS = COMPLETETRAINOCC & point2.mode != USED : COMPLETETRAINOCC;

		-- train moves on with head if train is present
		point2.occRS = COMPLETETRAINOCC & point2.mode = USED : TAILOCC;

		-- train tail leaves if tail is present
		point2.occRS = TAILOCC : FREE;

		TRUE : point2.occRS;
	esac;


-- Train Movement --
INVAR
	(seg14.occUp = HEADOCC -> (seg15.occUp != HEADOCC))
	& (seg14.occUp = COMPLETETRAINOCC -> (seg15.occUp != HEADOCC))
	& (seg14.occUp = TAILOCC -> (seg15.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg14.occDown = HEADOCC -> (seg15.occDown in {TAILOCC, ERROROCC}))
	& (seg14.occDown = COMPLETETRAINOCC -> (seg15.occDown != TAILOCC))
	& (seg14.occDown = TAILOCC -> (seg15.occDown != TAILOCC))
	& (seg15.occUp = HEADOCC -> (seg14.occUp in {TAILOCC, ERROROCC} & seg16.occUp != HEADOCC))
	& (seg15.occUp = COMPLETETRAINOCC -> (seg14.occUp != TAILOCC & seg16.occUp != HEADOCC))
	& (seg15.occUp = TAILOCC -> (seg14.occUp != TAILOCC & seg16.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg15.occDown = HEADOCC -> (seg16.occDown in {TAILOCC, ERROROCC} & seg14.occDown != HEADOCC))
	& (seg15.occDown = COMPLETETRAINOCC -> (seg16.occDown != TAILOCC & seg14.occDown != HEADOCC))
	& (seg15.occDown = TAILOCC -> (seg16.occDown != TAILOCC & seg14.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg16.occUp = HEADOCC -> (seg15.occUp in {TAILOCC, ERROROCC}))
	& (seg16.occUp = COMPLETETRAINOCC -> (seg15.occUp != TAILOCC))
	& (seg16.occUp = TAILOCC -> (seg15.occUp != TAILOCC))
	& (seg16.occDown = HEADOCC -> (seg15.occDown != HEADOCC))
	& (seg16.occDown = COMPLETETRAINOCC -> (seg15.occDown != HEADOCC))
	& (seg16.occDown = TAILOCC -> (seg15.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg23.occUp = HEADOCC -> (seg24.occUp != HEADOCC))
	& (seg23.occUp = COMPLETETRAINOCC -> (seg24.occUp != HEADOCC))
	& (seg23.occUp = TAILOCC -> (seg24.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg23.occDown = HEADOCC -> (seg24.occDown in {TAILOCC, ERROROCC}))
	& (seg23.occDown = COMPLETETRAINOCC -> (seg24.occDown != TAILOCC))
	& (seg23.occDown = TAILOCC -> (seg24.occDown != TAILOCC))
	& (seg24.occUp = HEADOCC -> (seg23.occUp in {TAILOCC, ERROROCC} & seg25.occUp != HEADOCC))
	& (seg24.occUp = COMPLETETRAINOCC -> (seg23.occUp != TAILOCC & seg25.occUp != HEADOCC))
	& (seg24.occUp = TAILOCC -> (seg23.occUp != TAILOCC & seg25.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg24.occDown = HEADOCC -> (seg25.occDown in {TAILOCC, ERROROCC} & seg23.occDown != HEADOCC))
	& (seg24.occDown = COMPLETETRAINOCC -> (seg25.occDown != TAILOCC & seg23.occDown != HEADOCC))
	& (seg24.occDown = TAILOCC -> (seg25.occDown != TAILOCC & seg23.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg25.occUp = HEADOCC -> (seg24.occUp in {TAILOCC, ERROROCC}))
	& (seg25.occUp = COMPLETETRAINOCC -> (seg24.occUp != TAILOCC))
	& (seg25.occUp = TAILOCC -> (seg24.occUp != TAILOCC))
	& (seg25.occDown = HEADOCC -> (seg24.occDown != HEADOCC))
	& (seg25.occDown = COMPLETETRAINOCC -> (seg24.occDown != HEADOCC))
	& (seg25.occDown = TAILOCC -> (seg24.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg18.occUp = HEADOCC -> (seg19.occUp != HEADOCC))
	& (seg18.occUp = COMPLETETRAINOCC -> (seg19.occUp != HEADOCC))
	& (seg18.occUp = TAILOCC -> (seg19.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg18.occDown = HEADOCC -> (seg19.occDown in {TAILOCC, ERROROCC}))
	& (seg18.occDown = COMPLETETRAINOCC -> (seg19.occDown != TAILOCC))
	& (seg18.occDown = TAILOCC -> (seg19.occDown != TAILOCC))
	& (seg19.occUp = HEADOCC -> (seg18.occUp in {TAILOCC, ERROROCC} & seg20.occUp != HEADOCC))
	& (seg19.occUp = COMPLETETRAINOCC -> (seg18.occUp != TAILOCC & seg20.occUp != HEADOCC))
	& (seg19.occUp = TAILOCC -> (seg18.occUp != TAILOCC & seg20.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg19.occDown = HEADOCC -> (seg20.occDown in {TAILOCC, ERROROCC} & seg18.occDown != HEADOCC))
	& (seg19.occDown = COMPLETETRAINOCC -> (seg20.occDown != TAILOCC & seg18.occDown != HEADOCC))
	& (seg19.occDown = TAILOCC -> (seg20.occDown != TAILOCC & seg18.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg20.occUp = HEADOCC -> (seg19.occUp in {TAILOCC, ERROROCC}))
	& (seg20.occUp = COMPLETETRAINOCC -> (seg19.occUp != TAILOCC))
	& (seg20.occUp = TAILOCC -> (seg19.occUp != TAILOCC))
	& (seg20.occDown = HEADOCC -> (point6.occSNR in {TAILOCC, ERROROCC} & seg19.occDown != HEADOCC))
	& (seg20.occDown = COMPLETETRAINOCC -> (point6.occSNR != TAILOCC & seg19.occDown != HEADOCC))
	& (seg20.occDown = TAILOCC -> (point6.occSNR != TAILOCC & seg19.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg9.occUp = HEADOCC -> (point2.occNS in {TAILOCC, ERROROCC} & seg10.occUp != HEADOCC))
	& (seg9.occUp = COMPLETETRAINOCC -> (point2.occNS != TAILOCC & seg10.occUp != HEADOCC))
	& (seg9.occUp = TAILOCC -> (point2.occNS != TAILOCC & seg10.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg9.occDown = HEADOCC -> (seg10.occDown in {TAILOCC, ERROROCC} & point2.occSNR != HEADOCC))
	& (seg9.occDown = COMPLETETRAINOCC -> (seg10.occDown != TAILOCC & point2.occSNR != HEADOCC))
	& (seg9.occDown = TAILOCC -> (seg10.occDown != TAILOCC & point2.occSNR in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg10.occUp = HEADOCC -> (seg9.occUp in {TAILOCC, ERROROCC} & seg11.occUp != HEADOCC))
	& (seg10.occUp = COMPLETETRAINOCC -> (seg9.occUp != TAILOCC & seg11.occUp != HEADOCC))
	& (seg10.occUp = TAILOCC -> (seg9.occUp != TAILOCC & seg11.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg10.occDown = HEADOCC -> (seg11.occDown in {TAILOCC, ERROROCC} & seg9.occDown != HEADOCC))
	& (seg10.occDown = COMPLETETRAINOCC -> (seg11.occDown != TAILOCC & seg9.occDown != HEADOCC))
	& (seg10.occDown = TAILOCC -> (seg11.occDown != TAILOCC & seg9.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg11.occUp = HEADOCC -> (seg10.occUp in {TAILOCC, ERROROCC}))
	& (seg11.occUp = COMPLETETRAINOCC -> (seg10.occUp != TAILOCC))
	& (seg11.occUp = TAILOCC -> (seg10.occUp != TAILOCC))
	& (seg11.occDown = HEADOCC -> (seg10.occDown != HEADOCC))
	& (seg11.occDown = COMPLETETRAINOCC -> (seg10.occDown != HEADOCC))
	& (seg11.occDown = TAILOCC -> (seg10.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg7.occUp = HEADOCC -> (seg6.occUp in {TAILOCC, ERROROCC}))
	& (seg7.occUp = COMPLETETRAINOCC -> (seg6.occUp != TAILOCC))
	& (seg7.occUp = TAILOCC -> (seg6.occUp != TAILOCC))
	& (seg7.occDown = HEADOCC -> (point2.occSNR in {TAILOCC, ERROROCC} & seg6.occDown != HEADOCC))
	& (seg7.occDown = COMPLETETRAINOCC -> (point2.occSNR != TAILOCC & seg6.occDown != HEADOCC))
	& (seg7.occDown = TAILOCC -> (point2.occSNR != TAILOCC & seg6.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg6.occUp = HEADOCC -> (seg5.occUp in {TAILOCC, ERROROCC} & seg7.occUp != HEADOCC))
	& (seg6.occUp = COMPLETETRAINOCC -> (seg5.occUp != TAILOCC & seg7.occUp != HEADOCC))
	& (seg6.occUp = TAILOCC -> (seg5.occUp != TAILOCC & seg7.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg6.occDown = HEADOCC -> (seg7.occDown in {TAILOCC, ERROROCC} & seg5.occDown != HEADOCC))
	& (seg6.occDown = COMPLETETRAINOCC -> (seg7.occDown != TAILOCC & seg5.occDown != HEADOCC))
	& (seg6.occDown = TAILOCC -> (seg7.occDown != TAILOCC & seg5.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg5.occUp = HEADOCC -> (seg6.occUp != HEADOCC))
	& (seg5.occUp = COMPLETETRAINOCC -> (seg6.occUp != HEADOCC))
	& (seg5.occUp = TAILOCC -> (seg6.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg5.occDown = HEADOCC -> (seg6.occDown in {TAILOCC, ERROROCC}))
	& (seg5.occDown = COMPLETETRAINOCC -> (seg6.occDown != TAILOCC))
	& (seg5.occDown = TAILOCC -> (seg6.occDown != TAILOCC))
	& (point2.occNS = HEADOCC -> (seg9.occUp in {TAILOCC, ERROROCC} & seg7.occUp != HEADOCC))
	& (point2.occNS = COMPLETETRAINOCC -> (seg9.occUp != TAILOCC & seg7.occUp != HEADOCC))
	& (point2.occNS = TAILOCC -> (seg9.occUp != TAILOCC & seg7.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))

-- Train Occupancy Error --
INVARSPEC
	NAME NoOccUpErrors := !(
		seg14.occUp = ERROROCC
		| seg15.occUp = ERROROCC
		| seg16.occUp = ERROROCC
		| seg23.occUp = ERROROCC
		| seg24.occUp = ERROROCC
		| seg25.occUp = ERROROCC
		| seg18.occUp = ERROROCC
		| seg19.occUp = ERROROCC
		| seg20.occUp = ERROROCC
		| seg9.occUp = ERROROCC
		| seg10.occUp = ERROROCC
		| seg11.occUp = ERROROCC
		| seg7.occUp = ERROROCC
		| seg6.occUp = ERROROCC
		| seg5.occUp = ERROROCC
	);

INVARSPEC
	NAME NoOccDownErrors := !(
		seg14.occDown = ERROROCC
		| seg15.occDown = ERROROCC
		| seg16.occDown = ERROROCC
		| seg23.occDown = ERROROCC
		| seg24.occDown = ERROROCC
		| seg25.occDown = ERROROCC
		| seg18.occDown = ERROROCC
		| seg19.occDown = ERROROCC
		| seg20.occDown = ERROROCC
		| seg9.occDown = ERROROCC
		| seg10.occDown = ERROROCC
		| seg11.occDown = ERROROCC
		| seg7.occDown = ERROROCC
		| seg6.occDown = ERROROCC
		| seg5.occDown = ERROROCC
	);

INVARSPEC
	NAME NoOccPointErrors := !(
		point6.occSNR = ERROROCC
		| point6.occRS = ERROROCC
		| point6.occNS = ERROROCC
		| point2.occSNR = ERROROCC
		| point2.occRS = ERROROCC
		| point2.occNS = ERROROCC
	);


-- Safety Invariants --
INVARSPEC
	NAME NoHeadToHeadSegmentCollisions := (
		(seg14.occDown != FREE -> seg14.occUp = FREE) & (seg14.occUp != FREE -> seg14.occDown = FREE)
		& (seg15.occDown != FREE -> seg15.occUp = FREE) & (seg15.occUp != FREE -> seg15.occDown = FREE)
		& (seg16.occDown != FREE -> seg16.occUp = FREE) & (seg16.occUp != FREE -> seg16.occDown = FREE)
		& (seg23.occDown != FREE -> seg23.occUp = FREE) & (seg23.occUp != FREE -> seg23.occDown = FREE)
		& (seg24.occDown != FREE -> seg24.occUp = FREE) & (seg24.occUp != FREE -> seg24.occDown = FREE)
		& (seg25.occDown != FREE -> seg25.occUp = FREE) & (seg25.occUp != FREE -> seg25.occDown = FREE)
		& (seg18.occDown != FREE -> seg18.occUp = FREE) & (seg18.occUp != FREE -> seg18.occDown = FREE)
		& (seg19.occDown != FREE -> seg19.occUp = FREE) & (seg19.occUp != FREE -> seg19.occDown = FREE)
		& (seg20.occDown != FREE -> seg20.occUp = FREE) & (seg20.occUp != FREE -> seg20.occDown = FREE)
		& (seg9.occDown != FREE -> seg9.occUp = FREE) & (seg9.occUp != FREE -> seg9.occDown = FREE)
		& (seg10.occDown != FREE -> seg10.occUp = FREE) & (seg10.occUp != FREE -> seg10.occDown = FREE)
		& (seg11.occDown != FREE -> seg11.occUp = FREE) & (seg11.occUp != FREE -> seg11.occDown = FREE)
		& (seg7.occDown != FREE -> seg7.occUp = FREE) & (seg7.occUp != FREE -> seg7.occDown = FREE)
		& (seg6.occDown != FREE -> seg6.occUp = FREE) & (seg6.occUp != FREE -> seg6.occDown = FREE)
		& (seg5.occDown != FREE -> seg5.occUp = FREE) & (seg5.occUp != FREE -> seg5.occDown = FREE)
	);

INVARSPEC
	NAME NoHeadToHeadPointCollisions := (
		(point6.occSNR != FREE -> (point6.occNS = FREE & point6.occRS = FREE))
        & (point6.occNS != FREE -> (point6.occSNR = FREE & point6.occRS = FREE))
        & (point6.occRS != FREE -> (point6.occSNR = FREE & point6.occNS = FREE))
		& (point2.occSNR != FREE -> (point2.occNS = FREE & point2.occRS = FREE))
        & (point2.occNS != FREE -> (point2.occSNR = FREE & point2.occRS = FREE))
        & (point2.occRS != FREE -> (point2.occSNR = FREE & point2.occNS = FREE))
	);

INVARSPEC
	NAME NoHeadToTailCollisionsDown := (
		(seg14.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg15.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg15.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg16.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg23.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg24.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg24.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg25.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg18.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg19.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg19.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg20.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg20.occDown in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point6.occSNR in {COMPLETETRAINOCC, HEADOCC})
			| point6.ACT = INTERMEDIATE
		)
		& (seg9.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg10.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg10.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg11.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg7.occDown in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point2.occSNR in {COMPLETETRAINOCC, HEADOCC})
			| point2.ACT = INTERMEDIATE
		)
		& (seg6.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg7.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg5.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg6.occDown in {HEADOCC, COMPLETETRAINOCC})
	);
INVARSPEC
	NAME NoHeadToTailCollisionsUp := (
		(seg15.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg14.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg16.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg15.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg24.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg23.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg25.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg24.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg19.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg18.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg20.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg19.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg9.occUp in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point2.occNS in {COMPLETETRAINOCC, HEADOCC})
			| point2.ACT != NORMAL
		)
		& (seg10.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg9.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg11.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg10.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg7.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg6.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg6.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg5.occUp in {HEADOCC, COMPLETETRAINOCC})
	);

INVARSPEC
	NAME NoPointDerailments := (
		(
			(point6.occNS != FREE -> point6.ACT = NORMAL)
            & (point6.occRS != FREE -> point6.ACT = REVERSE)
            & (point6.occSNR != FREE -> point6.ACT != INTERMEDIATE)
		)
		& (
			(point2.occNS != FREE -> point2.ACT = NORMAL)
            & (point2.occRS != FREE -> point2.ACT = REVERSE)
            & (point2.occSNR != FREE -> point2.ACT != INTERMEDIATE)
		)
	);

INVARSPEC
	NAME NoPointHeadToTailCollisions := (
		(point6.occSNR in {TAILOCC, COMPLETETRAINOCC}) -> !(seg20.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (point2.occSNR in {TAILOCC, COMPLETETRAINOCC}) -> !(seg7.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (point2.occNS in {TAILOCC, COMPLETETRAINOCC}) -> !(seg9.occUp in {HEADOCC, COMPLETETRAINOCC})
	);

INVARSPEC
	NAME NoSegmentLockModeTransitionError := (
		(seg14.mode = EXLOCKED -> (r0.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg14.mode = USED -> (r0.mode = OCCUPIED))
		& (seg15.mode = EXLOCKED -> (r0.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg15.mode = USED -> (r0.mode = OCCUPIED))
		& (seg16.mode = EXLOCKED -> (r0.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg23.mode = EXLOCKED -> (r1.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg23.mode = USED -> (r1.mode = OCCUPIED))
		& (seg24.mode = EXLOCKED -> (r1.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg24.mode = USED -> (r1.mode = OCCUPIED))
		& (seg25.mode = EXLOCKED -> (r1.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg18.mode = EXLOCKED -> (r2.mode in {ALLOCATING, LOCKED, OCCUPIED} | r5.mode in {ALLOCATING, LOCKED, OCCUPIED} | r7.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg19.mode = EXLOCKED -> (r2.mode in {ALLOCATING, LOCKED, OCCUPIED} | r5.mode in {ALLOCATING, LOCKED, OCCUPIED} | r7.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg19.mode = USED -> (r2.mode = OCCUPIED | r5.mode = OCCUPIED | r7.mode = OCCUPIED))
		& (seg20.mode = EXLOCKED -> (r2.mode in {ALLOCATING, LOCKED, OCCUPIED} | r5.mode in {ALLOCATING, LOCKED, OCCUPIED} | r7.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg9.mode = EXLOCKED -> (r3.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg9.mode = USED -> (r3.mode = OCCUPIED))
		& (seg10.mode = EXLOCKED -> (r3.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg10.mode = USED -> (r3.mode = OCCUPIED))
		& (seg11.mode = EXLOCKED -> (r3.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg7.mode = EXLOCKED -> (r4.mode in {ALLOCATING, LOCKED, OCCUPIED} | r6.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg7.mode = USED -> (r4.mode = OCCUPIED | r6.mode = OCCUPIED))
		& (seg6.mode = EXLOCKED -> (r4.mode in {ALLOCATING, LOCKED, OCCUPIED} | r6.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg6.mode = USED -> (r4.mode = OCCUPIED | r6.mode = OCCUPIED))
		& (seg5.mode = EXLOCKED -> (r4.mode in {ALLOCATING, LOCKED, OCCUPIED} | r6.mode in {ALLOCATING, LOCKED, OCCUPIED}))
	);

INVARSPEC
	NAME NoPointLockModeTransitionError := (
		(point6.mode = EXLOCKED -> (r0.mode in {ALLOCATING, LOCKED, OCCUPIED} | r1.mode in {ALLOCATING, LOCKED, OCCUPIED} | r5.mode in {ALLOCATING, LOCKED, OCCUPIED} | r7.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (point6.mode = USED -> (r0.mode = OCCUPIED | r1.mode = OCCUPIED | r5.mode = OCCUPIED | r7.mode = OCCUPIED))
		& (point2.mode = EXLOCKED -> (r2.mode in {ALLOCATING, LOCKED, OCCUPIED} | r3.mode in {ALLOCATING, LOCKED, OCCUPIED} | r4.mode in {ALLOCATING, LOCKED, OCCUPIED} | r6.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (point2.mode = USED -> (r2.mode = OCCUPIED | r3.mode = OCCUPIED | r4.mode = OCCUPIED | r6.mode = OCCUPIED))
	);

