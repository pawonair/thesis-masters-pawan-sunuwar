-------------------------------------------------------------------------------
-- Signal Module --
-- Represents a signal in the track
-- Inputs:- id_in: frozen var, ID of this signal, number in range 0..15
--          CMD_in: command for the aspect of the signal
-------------------------------------------------------------------------------
MODULE Signal(id_in, CMD_in)
FROZENVAR
	id: 0..15;
VAR
	ACT : {STOP, GO};
ASSIGN
	init(id) := id_in;
	init(ACT) := STOP;
	next(ACT) := case
		ACT != CMD_in : CMD_in;
		TRUE : ACT;
	esac;
-------------------------------------------------------------------------------
-------------------------------------------------------------------------------
-- Point Module --
-- Represents a point and its track section/segment.
--      Track related variables are like in LinearSection mostly might
--      want to change this similar to Vu et al, to use 3 variables for
--      occupancy instead of 2 (require lots of other changes though).
-- Inputs:- id_in: frozen var, ID of this point, number in range 0..29
--          segID_in: frozen var, ID of the segment of the point,
--                        number in range 0..29
--          CMD_in: command for the aspect/position of the point,
--                        enum values "NORMAL" and "REVERSE"
-------------------------------------------------------------------------------
MODULE Point(id_in, segID_in, CMD_in)
FROZENVAR
	id : 0..29;
	segID : 0..29;
VAR
	occSNR : {FREE, HEADOCC, COMPLETETRAINOCC, TAILOCC, ERROROCC};
	occNS : {FREE, HEADOCC, COMPLETETRAINOCC, TAILOCC, ERROROCC};
	occRS : {FREE, HEADOCC, COMPLETETRAINOCC, TAILOCC, ERROROCC};
	ACT : {NORMAL, INTERMEDIATE, REVERSE};
	mode : {AVAILABLE, EXLOCKED, USED};
	prev : {PENDING, RELEASED};
ASSIGN
	init(id) := id_in;
	init(segID) := segID_in;
	init(ACT) := NORMAL;
	init(mode) := AVAILABLE;
	init(prev) := PENDING;

	next(ACT) := case
		ACT != CMD_in & ACT != INTERMEDIATE : INTERMEDIATE;
		-- if in INTERMEDIATE, change to CMD_in next
		ACT = INTERMEDIATE : CMD_in;
		TRUE : ACT;
	esac;
-------------------------------------------------------------------------------
-------------------------------------------------------------------------------
-- Linear Section Module --
-- Represents a section/segment in the track
-- Inputs:- id_in: track segment identifier
-------------------------------------------------------------------------------
MODULE Linear(id_in)
FROZENVAR
	id : 0..29;
VAR
	occDown : {FREE, HEADOCC, COMPLETETRAINOCC, TAILOCC, ERROROCC};
	occUp : {FREE, HEADOCC, COMPLETETRAINOCC, TAILOCC, ERROROCC};
	mode : {AVAILABLE, EXLOCKED, USED};
	prev : {PENDING, RELEASED};
ASSIGN
	init(id) := id_in;
	init(mode) := AVAILABLE;
	init(prev) := PENDING;
-------------------------------------------------------------------------------
-------------------------------------------------------------------------------
-- Route Module --
-- Represents a route in the interlocked layout
-- Inputs:- id_in: route identifier
-------------------------------------------------------------------------------
MODULE Route(id_in)
FROZENVAR
	id : 0..74;
VAR
	mode : {FREE, MARKED, ALLOCATING, LOCKED, OCCUPIED};
	transition : {CAN_DISPATCH, CAN_ALLOCATE, CAN_LOCK, CAN_OCCUPY};
ASSIGN
	init(id) := id_in;
	init(mode) := FREE;
	init(transition) := CAN_DISPATCH;
-------------------------------------------------------------------------------


-------------------------------------------------------------------------------
-- Track Section Module --
-- This bundles all segments/sections, points, train movement etc.
-------------------------------------------------------------------------------
MODULE TrackSection -- Segments/sections + point switching + signal comm
VAR
	r0 : Route(0);
	r1 : Route(1);
	r2 : Route(2);
	r3 : Route(3);
	r4 : Route(4);
	r5 : Route(5);
	r6 : Route(6);
	r7 : Route(7);

	seg14 : Linear(14);
	seg15 : Linear(15);
	seg16 : Linear(16);
	seg23 : Linear(23);
	seg24 : Linear(24);
	seg25 : Linear(25);
	seg18 : Linear(18);
	seg19 : Linear(19);
	seg20 : Linear(20);
	seg9 : Linear(9);
	seg10 : Linear(10);
	seg11 : Linear(11);
	seg7 : Linear(7);
	seg6 : Linear(6);
	seg5 : Linear(5);

	point6CMD : {NORMAL, REVERSE};
	point6 : Point(6, 21, point6CMD);

	point2CMD : {NORMAL, REVERSE};
	point2 : Point(2, 8, point2CMD);


	signal10CMD : {GO, STOP};
	signal10 : Signal(10, signal10CMD);

	signal8CMD : {GO, STOP};
	signal8 : Signal(8, signal8CMD);

	signal12CMD : {GO, STOP};
	signal12 : Signal(12, signal12CMD);

	signal4CMD : {GO, STOP};
	signal4 : Signal(4, signal4CMD);

	signal6CMD : {GO, STOP};
	signal6 : Signal(6, signal6CMD);

	signal5CMD : {GO, STOP};
	signal5 : Signal(5, signal5CMD);

	signal3CMD : {GO, STOP};
	signal3 : Signal(3, signal3CMD);

	signal7CMD : {GO, STOP};
	signal7 : Signal(7, signal7CMD);

	signal9CMD : {GO, STOP};
	signal9 : Signal(9, signal9CMD);

	signal11CMD : {GO, STOP};
	signal11 : Signal(11, signal11CMD);


ASSIGN
	-- SEGMENTS OCCUPANCY INITIAL --
	init(seg14.occDown) := FREE;
	init(seg14.occUp) := FREE;
	init(seg15.occDown) := FREE;
	init(seg15.occUp) := FREE;
	init(seg16.occDown) := FREE;
	init(seg16.occUp) := FREE;
	init(seg23.occDown) := COMPLETETRAINOCC;
	init(seg23.occUp) := FREE;
	init(seg24.occDown) := FREE;
	init(seg24.occUp) := FREE;
	init(seg25.occDown) := FREE;
	init(seg25.occUp) := FREE;
	init(seg18.occDown) := FREE;
	init(seg18.occUp) := FREE;
	init(seg19.occDown) := FREE;
	init(seg19.occUp) := FREE;
	init(seg20.occDown) := FREE;
	init(seg20.occUp) := FREE;
	init(seg9.occDown) := FREE;
	init(seg9.occUp) := FREE;
	init(seg10.occDown) := FREE;
	init(seg10.occUp) := FREE;
	init(seg11.occDown) := FREE;
	init(seg11.occUp) := FREE;
	init(seg7.occDown) := FREE;
	init(seg7.occUp) := COMPLETETRAINOCC;
	init(seg6.occDown) := FREE;
	init(seg6.occUp) := FREE;
	init(seg5.occDown) := FREE;
	init(seg5.occUp) := FREE;

	-- SEGMENTS OCCUPANCY INITIAL --
	init(point6.occSNR) := FREE;
	init(point6.occNS) := FREE;
	init(point6.occRS) := FREE;
	init(point6CMD) := NORMAL;
	init(point2.occSNR) := FREE;
	init(point2.occNS) := FREE;
	init(point2.occRS) := FREE;
	init(point2CMD) := NORMAL;

	-- SIGNALS CMD INITIAL --
	init(signal10CMD) := STOP;
	init(signal8CMD) := STOP;
	init(signal12CMD) := STOP;
	init(signal4CMD) := STOP;
	init(signal6CMD) := STOP;
	init(signal5CMD) := STOP;
	init(signal3CMD) := STOP;
	init(signal7CMD) := STOP;
	init(signal9CMD) := STOP;
	init(signal11CMD) := STOP;

	-- NEXTS --
	-- SIGNALS CMD NEXT --
	next(signal10CMD) := case
		(
			r0.mode = LOCKED
			| r1.mode = LOCKED
			| r5.mode = LOCKED
			| r7.mode = LOCKED
		)
		: GO;

		(
			r0.mode = OCCUPIED
			| r1.mode = OCCUPIED
			| r5.mode = OCCUPIED
			| r7.mode = OCCUPIED
		)
		: STOP;

		TRUE : signal10CMD;
	esac;

	next(signal8CMD) := case
		TRUE : signal8CMD;
	esac;

	next(signal12CMD) := case
		TRUE : signal12CMD;
	esac;

	next(signal4CMD) := case
		(
			r2.mode = LOCKED
			| r3.mode = LOCKED
			| r4.mode = LOCKED
			| r6.mode = LOCKED
		)
		: GO;

		(
			r2.mode = OCCUPIED
			| r3.mode = OCCUPIED
			| r4.mode = OCCUPIED
			| r6.mode = OCCUPIED
		)
		: STOP;

		TRUE : signal4CMD;
	esac;

	next(signal6CMD) := case
		TRUE : signal6CMD;
	esac;

	next(signal5CMD) := case
		(
			r3.mode = LOCKED
			| r4.mode = LOCKED
		)
		: GO;

		(
			r3.mode = OCCUPIED
			| r4.mode = OCCUPIED
		)
		: STOP;

		TRUE : signal5CMD;
	esac;

	next(signal3CMD) := case
		TRUE : signal3CMD;
	esac;

	next(signal7CMD) := case
		(
			r0.mode = LOCKED
			| r5.mode = LOCKED
		)
		: GO;

		(
			r0.mode = OCCUPIED
			| r5.mode = OCCUPIED
		)
		: STOP;

		TRUE : signal7CMD;
	esac;

	next(signal9CMD) := case
		(
			r2.mode = LOCKED
			| r6.mode = LOCKED
		)
		: GO;

		(
			r2.mode = OCCUPIED
			| r6.mode = OCCUPIED
		)
		: STOP;

		TRUE : signal9CMD;
	esac;

	next(signal11CMD) := case
		(
			r1.mode = LOCKED
			| r7.mode = LOCKED
		)
		: GO;

		(
			r1.mode = OCCUPIED
			| r7.mode = OCCUPIED
		)
		: STOP;

		TRUE : signal11CMD;
	esac;


	-- POINTS CMD NEXT --
	next(point6CMD) := case
		r1.mode in {ALLOCATING, LOCKED, OCCUPIED} | r7.mode in {ALLOCATING, LOCKED, OCCUPIED} : REVERSE;
		TRUE : NORMAL;
	esac;

	next(point2CMD) := case
		r2.mode in {ALLOCATING, LOCKED, OCCUPIED} | r6.mode in {ALLOCATING, LOCKED, OCCUPIED} : REVERSE;
		TRUE : NORMAL;
	esac;


	-- SEGMENTS/SECTIONS MODE NEXT --
	next(seg14.mode) := case
		seg14.mode = AVAILABLE
		& (r0.mode = ALLOCATING)
		: EXLOCKED;

		seg14.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
			r0.mode = OCCUPIED
			& point6.mode = USED
			& seg15.mode = EXLOCKED
			& seg14.occDown = FREE & seg14.occUp = FREE
		)
		: USED;

		seg14.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
			r0.mode = OCCUPIED
			& (seg15.mode = USED | seg15.prev = PENDING)
		)
		& (seg14.occDown = FREE & seg14.occUp = FREE)
		& seg14.prev = RELEASED
		: AVAILABLE;

		TRUE : seg14.mode;
	esac;

	next(seg15.mode) := case
		seg15.mode = AVAILABLE
		& (r0.mode = ALLOCATING)
		: EXLOCKED;

		seg15.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
			r0.mode = OCCUPIED
			& seg14.mode = USED
			& seg16.mode = EXLOCKED
			& seg15.occDown = FREE & seg15.occUp = FREE
		)
		: USED;

		seg15.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
			r0.mode = OCCUPIED
			& (seg16.mode = USED | seg16.prev = PENDING)
		)
		& (seg15.occDown = FREE & seg15.occUp = FREE)
		& seg15.prev = RELEASED
		: AVAILABLE;

		TRUE : seg15.mode;
	esac;

	next(seg16.mode) := case
		seg16.mode = AVAILABLE
		& (r0.mode = ALLOCATING)
		: EXLOCKED;

		seg16.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
			r0.mode = OCCUPIED
			& seg15.mode = USED
			& seg16.occUp in {HEADOCC, COMPLETETRAINOCC}
		)
		: USED;

		seg16.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
			r0.mode = OCCUPIED
		)
		& (seg16.occDown = FREE & seg16.occUp = FREE)
		& seg16.prev = RELEASED
		: AVAILABLE;

		TRUE : seg16.mode;
	esac;

	next(seg23.mode) := case
		seg23.mode = AVAILABLE
		& (r1.mode = ALLOCATING)
		: EXLOCKED;

		seg23.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
			r1.mode = OCCUPIED
			& point6.mode = USED
			& seg24.mode = EXLOCKED
			& seg23.occDown = FREE & seg23.occUp = FREE
		)
		: USED;

		seg23.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
			r1.mode = OCCUPIED
			& (seg24.mode = USED | seg24.prev = PENDING)
		)
		& (seg23.occDown = FREE & seg23.occUp = FREE)
		& seg23.prev = RELEASED
		: AVAILABLE;

		TRUE : seg23.mode;
	esac;

	next(seg24.mode) := case
		seg24.mode = AVAILABLE
		& (r1.mode = ALLOCATING)
		: EXLOCKED;

		seg24.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
			r1.mode = OCCUPIED
			& seg23.mode = USED
			& seg25.mode = EXLOCKED
			& seg24.occDown = FREE & seg24.occUp = FREE
		)
		: USED;

		seg24.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
			r1.mode = OCCUPIED
			& (seg25.mode = USED | seg25.prev = PENDING)
		)
		& (seg24.occDown = FREE & seg24.occUp = FREE)
		& seg24.prev = RELEASED
		: AVAILABLE;

		TRUE : seg24.mode;
	esac;

	next(seg25.mode) := case
		seg25.mode = AVAILABLE
		& (r1.mode = ALLOCATING)
		: EXLOCKED;

		seg25.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
			r1.mode = OCCUPIED
			& seg24.mode = USED
			& seg25.occUp in {HEADOCC, COMPLETETRAINOCC}
		)
		: USED;

		seg25.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
			r1.mode = OCCUPIED
		)
		& (seg25.occDown = FREE & seg25.occUp = FREE)
		& seg25.prev = RELEASED
		: AVAILABLE;

		TRUE : seg25.mode;
	esac;

	next(seg18.mode) := case
		seg18.mode = AVAILABLE
		& (r2.mode = ALLOCATING | r5.mode = ALLOCATING | r7.mode = ALLOCATING)
		: EXLOCKED;

		seg18.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r2.mode = OCCUPIED
			& point2.mode = USED
			& seg19.mode = EXLOCKED
			& seg18.occDown = FREE & seg18.occUp = FREE
		)
		| (
			r5.mode = OCCUPIED
			& seg19.mode = USED
			& seg18.occDown in {HEADOCC, COMPLETETRAINOCC}
		)
		| (
			r7.mode = OCCUPIED
			& seg19.mode = USED
			& seg18.occDown in {HEADOCC, COMPLETETRAINOCC}
		)
		)
		: USED;

		seg18.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r2.mode = OCCUPIED
			& (seg19.mode = USED | seg19.prev = PENDING)
		)
		| (
			r5.mode = OCCUPIED
		)
		| (
			r7.mode = OCCUPIED
		)
		)
		& (seg18.occDown = FREE & seg18.occUp = FREE)
		& seg18.prev = RELEASED
		: AVAILABLE;

		TRUE : seg18.mode;
	esac;

	next(seg19.mode) := case
		seg19.mode = AVAILABLE
		& (r2.mode = ALLOCATING | r5.mode = ALLOCATING | r7.mode = ALLOCATING)
		: EXLOCKED;

		seg19.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r2.mode = OCCUPIED
			& seg18.mode = USED
			& seg20.mode = EXLOCKED
			& seg19.occDown = FREE & seg19.occUp = FREE
		)
		| (
			r5.mode = OCCUPIED
			& seg20.mode = USED
			& seg18.mode = EXLOCKED
			& seg19.occDown = FREE & seg19.occUp = FREE
		)
		| (
			r7.mode = OCCUPIED
			& seg20.mode = USED
			& seg18.mode = EXLOCKED
			& seg19.occDown = FREE & seg19.occUp = FREE
		)
		)
		: USED;

		seg19.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r2.mode = OCCUPIED
			& (seg20.mode = USED | seg20.prev = PENDING)
		)
		| (
			r5.mode = OCCUPIED
			& (seg18.mode = USED | seg18.prev = PENDING)
		)
		| (
			r7.mode = OCCUPIED
			& (seg18.mode = USED | seg18.prev = PENDING)
		)
		)
		& (seg19.occDown = FREE & seg19.occUp = FREE)
		& seg19.prev = RELEASED
		: AVAILABLE;

		TRUE : seg19.mode;
	esac;

	next(seg20.mode) := case
		seg20.mode = AVAILABLE
		& (r2.mode = ALLOCATING | r5.mode = ALLOCATING | r7.mode = ALLOCATING)
		: EXLOCKED;

		seg20.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r2.mode = OCCUPIED
			& seg19.mode = USED
			& seg20.occUp in {HEADOCC, COMPLETETRAINOCC}
		)
		| (
			r5.mode = OCCUPIED
			& point6.mode = USED
			& seg19.mode = EXLOCKED
			& seg20.occDown = FREE & seg20.occUp = FREE
		)
		| (
			r7.mode = OCCUPIED
			& point6.mode = USED
			& seg19.mode = EXLOCKED
			& seg20.occDown = FREE & seg20.occUp = FREE
		)
		)
		: USED;

		seg20.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r2.mode = OCCUPIED
		)
		| (
			r5.mode = OCCUPIED
			& (seg19.mode = USED | seg19.prev = PENDING)
		)
		| (
			r7.mode = OCCUPIED
			& (seg19.mode = USED | seg19.prev = PENDING)
		)
		)
		& (seg20.occDown = FREE & seg20.occUp = FREE)
		& seg20.prev = RELEASED
		: AVAILABLE;

		TRUE : seg20.mode;
	esac;

	next(seg9.mode) := case
		seg9.mode = AVAILABLE
		& (r3.mode = ALLOCATING)
		: EXLOCKED;

		seg9.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
			r3.mode = OCCUPIED
			& point2.mode = USED
			& seg10.mode = EXLOCKED
			& seg9.occDown = FREE & seg9.occUp = FREE
		)
		: USED;

		seg9.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
			r3.mode = OCCUPIED
			& (seg10.mode = USED | seg10.prev = PENDING)
		)
		& (seg9.occDown = FREE & seg9.occUp = FREE)
		& seg9.prev = RELEASED
		: AVAILABLE;

		TRUE : seg9.mode;
	esac;

	next(seg10.mode) := case
		seg10.mode = AVAILABLE
		& (r3.mode = ALLOCATING)
		: EXLOCKED;

		seg10.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
			r3.mode = OCCUPIED
			& seg9.mode = USED
			& seg11.mode = EXLOCKED
			& seg10.occDown = FREE & seg10.occUp = FREE
		)
		: USED;

		seg10.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
			r3.mode = OCCUPIED
			& (seg11.mode = USED | seg11.prev = PENDING)
		)
		& (seg10.occDown = FREE & seg10.occUp = FREE)
		& seg10.prev = RELEASED
		: AVAILABLE;

		TRUE : seg10.mode;
	esac;

	next(seg11.mode) := case
		seg11.mode = AVAILABLE
		& (r3.mode = ALLOCATING)
		: EXLOCKED;

		seg11.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
			r3.mode = OCCUPIED
			& seg10.mode = USED
			& seg11.occUp in {HEADOCC, COMPLETETRAINOCC}
		)
		: USED;

		seg11.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
			r3.mode = OCCUPIED
		)
		& (seg11.occDown = FREE & seg11.occUp = FREE)
		& seg11.prev = RELEASED
		: AVAILABLE;

		TRUE : seg11.mode;
	esac;

	next(seg7.mode) := case
		seg7.mode = AVAILABLE
		& (r4.mode = ALLOCATING | r6.mode = ALLOCATING)
		: EXLOCKED;

		seg7.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r4.mode = OCCUPIED
			& point2.mode = USED
			& seg6.mode = EXLOCKED
			& seg7.occDown = FREE & seg7.occUp = FREE
		)
		| (
			r6.mode = OCCUPIED
			& point2.mode = USED
			& seg6.mode = EXLOCKED
			& seg7.occDown = FREE & seg7.occUp = FREE
		)
		)
		: USED;

		seg7.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r4.mode = OCCUPIED
			& (seg6.mode = USED | seg6.prev = PENDING)
		)
		| (
			r6.mode = OCCUPIED
			& (seg6.mode = USED | seg6.prev = PENDING)
		)
		)
		& (seg7.occDown = FREE & seg7.occUp = FREE)
		& seg7.prev = RELEASED
		: AVAILABLE;

		TRUE : seg7.mode;
	esac;

	next(seg6.mode) := case
		seg6.mode = AVAILABLE
		& (r4.mode = ALLOCATING | r6.mode = ALLOCATING)
		: EXLOCKED;

		seg6.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r4.mode = OCCUPIED
			& seg7.mode = USED
			& seg5.mode = EXLOCKED
			& seg6.occDown = FREE & seg6.occUp = FREE
		)
		| (
			r6.mode = OCCUPIED
			& seg7.mode = USED
			& seg5.mode = EXLOCKED
			& seg6.occDown = FREE & seg6.occUp = FREE
		)
		)
		: USED;

		seg6.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r4.mode = OCCUPIED
			& (seg5.mode = USED | seg5.prev = PENDING)
		)
		| (
			r6.mode = OCCUPIED
			& (seg5.mode = USED | seg5.prev = PENDING)
		)
		)
		& (seg6.occDown = FREE & seg6.occUp = FREE)
		& seg6.prev = RELEASED
		: AVAILABLE;

		TRUE : seg6.mode;
	esac;

	next(seg5.mode) := case
		seg5.mode = AVAILABLE
		& (r4.mode = ALLOCATING | r6.mode = ALLOCATING)
		: EXLOCKED;

		seg5.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r4.mode = OCCUPIED
			& seg6.mode = USED
			& seg5.occDown in {HEADOCC, COMPLETETRAINOCC}
		)
		| (
			r6.mode = OCCUPIED
			& seg6.mode = USED
			& seg5.occDown in {HEADOCC, COMPLETETRAINOCC}
		)
		)
		: USED;

		seg5.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r4.mode = OCCUPIED
		)
		| (
			r6.mode = OCCUPIED
		)
		)
		& (seg5.occDown = FREE & seg5.occUp = FREE)
		& seg5.prev = RELEASED
		: AVAILABLE;

		TRUE : seg5.mode;
	esac;

	next(point6.mode) := case
		point6.mode = AVAILABLE
		& (r0.mode = ALLOCATING | r1.mode = ALLOCATING | r5.mode = ALLOCATING | r7.mode = ALLOCATING)
		: EXLOCKED;

		point6.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r0.mode = OCCUPIED
			& seg14.mode = EXLOCKED
			& point6.ACT = NORMAL
			& point6.occSNR = FREE & point6.occNS = FREE & point6.occRS = FREE
		)
		| (
			r1.mode = OCCUPIED
			& seg23.mode = EXLOCKED
			& point6.ACT = REVERSE
			& point6.occSNR = FREE & point6.occNS = FREE & point6.occRS = FREE
		)
		| (
			r5.mode = OCCUPIED
			& seg20.mode = EXLOCKED
			& point6.ACT = NORMAL
			& point6.occSNR = FREE & point6.occNS = FREE & point6.occRS = FREE
		)
		| (
			r7.mode = OCCUPIED
			& seg20.mode = EXLOCKED
			& point6.ACT = REVERSE
			& point6.occSNR = FREE & point6.occNS = FREE & point6.occRS = FREE
		)
		)
		: USED;

		point6.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r0.mode = OCCUPIED
			& (seg14.mode = USED | seg14.prev = PENDING)
			& point6.ACT = NORMAL
		)
		| (
			r1.mode = OCCUPIED
			& (seg23.mode = USED | seg23.prev = PENDING)
			& point6.ACT = REVERSE
		)
		| (
			r5.mode = OCCUPIED
			& (seg20.mode = USED | seg20.prev = PENDING)
			& point6.ACT = NORMAL
		)
		| (
			r7.mode = OCCUPIED
			& (seg20.mode = USED | seg20.prev = PENDING)
			& point6.ACT = REVERSE
		)
		)
		& (point6.occSNR = FREE & point6.occNS = FREE & point6.occRS = FREE)
		& point6.prev = RELEASED
		: AVAILABLE;

		TRUE : point6.mode;
	esac;

	next(point2.mode) := case
