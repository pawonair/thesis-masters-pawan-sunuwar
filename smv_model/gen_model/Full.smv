LTLSPEC
	NAME r0IsReleasedEventually :=
		G(r0.mode = OCCUPIED -> F(r0.mode = FREE));

LTLSPEC
	NAME r0TrainReachesSeg3UpEventuallyForever :=
		F(r0.mode = OCCUPIED) -> F(G(seg3.occUp = COMPLETETRAINOCC));

