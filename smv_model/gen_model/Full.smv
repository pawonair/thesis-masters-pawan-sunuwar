		& track.seg18.occDown = FREE & track.seg18.occUp = FREE
		& track.seg19.occDown = FREE & track.seg19.occUp = FREE
		& track.seg20.occDown = FREE & track.seg20.occUp = FREE
		& track.point6.occSNR = FREE & track.point6.occNS = FREE & track.point6.occRS = FREE
		& track.point7.occSNR = FREE & track.point7.occNS = FREE & track.point7.occRS = FREE
		& track.seg23.occDown = FREE & track.seg23.occUp = FREE
		& track.seg24.occDown = FREE & track.seg24.occUp = FREE
		& track.seg25.occDown = FREE & track.seg25.occUp = FREE
        & track.point5.mode = AVAILABLE
		& track.seg18.mode = AVAILABLE
		& track.seg19.mode = AVAILABLE
		& track.seg20.mode = AVAILABLE
		& track.point6.mode = AVAILABLE
		& track.point7.mode = AVAILABLE
		& track.seg23.mode = AVAILABLE
		& track.seg24.mode = AVAILABLE
		& track.seg25.mode = AVAILABLE
        & TRUE
        & track.seg27.occUp != FREE
		: ALLOCATING;

		track.r74.mode = ALLOCATING
		& track.r30.mode != ALLOCATING & track.r30.mode != LOCKED
		& track.r65.mode != ALLOCATING & track.r65.mode != LOCKED
		& track.r27.mode != ALLOCATING & track.r27.mode != LOCKED
		& track.r15.mode != ALLOCATING & track.r15.mode != LOCKED
		& track.r36.mode != ALLOCATING & track.r36.mode != LOCKED
		& track.r47.mode != ALLOCATING & track.r47.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
		& track.r61.mode != ALLOCATING & track.r61.mode != LOCKED
		& track.r7.mode != ALLOCATING & track.r7.mode != LOCKED
		& track.r53.mode != ALLOCATING & track.r53.mode != LOCKED
		& track.r58.mode != ALLOCATING & track.r58.mode != LOCKED
		& track.r39.mode != ALLOCATING & track.r39.mode != LOCKED
		& track.r51.mode != ALLOCATING & track.r51.mode != LOCKED
		& track.r11.mode != ALLOCATING & track.r11.mode != LOCKED
		& track.r69.mode != ALLOCATING & track.r69.mode != LOCKED
		& track.r71.mode != ALLOCATING & track.r71.mode != LOCKED
		& track.r6.mode != ALLOCATING & track.r6.mode != LOCKED
		& track.r64.mode != ALLOCATING & track.r64.mode != LOCKED
		& track.r21.mode != ALLOCATING & track.r21.mode != LOCKED
		& track.r17.mode != ALLOCATING & track.r17.mode != LOCKED
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
		& track.r9.mode != ALLOCATING & track.r9.mode != LOCKED
		& track.r34.mode != ALLOCATING & track.r34.mode != LOCKED
		& track.r18.mode != ALLOCATING & track.r18.mode != LOCKED
		& track.r29.mode != ALLOCATING & track.r29.mode != LOCKED
		& track.r10.mode != ALLOCATING & track.r10.mode != LOCKED
		& track.r43.mode != ALLOCATING & track.r43.mode != LOCKED
		& track.r60.mode != ALLOCATING & track.r60.mode != LOCKED
		& track.r8.mode != ALLOCATING & track.r8.mode != LOCKED
		& track.r22.mode != ALLOCATING & track.r22.mode != LOCKED
		& track.r70.mode != ALLOCATING & track.r70.mode != LOCKED
		& track.r57.mode != ALLOCATING & track.r57.mode != LOCKED
		& track.r48.mode != ALLOCATING & track.r48.mode != LOCKED
		& track.r62.mode != ALLOCATING & track.r62.mode != LOCKED
		& track.r72.mode != ALLOCATING & track.r72.mode != LOCKED
		& track.r31.mode != ALLOCATING & track.r31.mode != LOCKED
		& track.r28.mode != ALLOCATING & track.r28.mode != LOCKED
		& track.r54.mode != ALLOCATING & track.r54.mode != LOCKED
		& track.r38.mode != ALLOCATING & track.r38.mode != LOCKED
		& track.r66.mode != ALLOCATING & track.r66.mode != LOCKED
		& track.r67.mode != ALLOCATING & track.r67.mode != LOCKED
		& track.r32.mode != ALLOCATING & track.r32.mode != LOCKED
		& track.r68.mode != ALLOCATING & track.r68.mode != LOCKED
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r63.mode != ALLOCATING & track.r63.mode != LOCKED
		& track.r45.mode != ALLOCATING & track.r45.mode != LOCKED
		& track.r73.mode != ALLOCATING & track.r73.mode != LOCKED
		& track.r52.mode != ALLOCATING & track.r52.mode != LOCKED
        & track.signal14.ACT = STOP
		& track.signal10.ACT = STOP
		& track.signal12.ACT = STOP
        & track.point5.ACT = NORMAL
		& track.point6.ACT = REVERSE
		& track.point7.ACT = REVERSE
        & track.point5.occSNR = FREE & track.point5.occNS = FREE & track.point5.occRS = FREE
		& track.seg18.occDown = FREE & track.seg18.occUp = FREE
		& track.seg19.occDown = FREE & track.seg19.occUp = FREE
		& track.seg20.occDown = FREE & track.seg20.occUp = FREE
		& track.point6.occSNR = FREE & track.point6.occNS = FREE & track.point6.occRS = FREE
		& track.point7.occSNR = FREE & track.point7.occNS = FREE & track.point7.occRS = FREE
		& track.seg23.occDown = FREE & track.seg23.occUp = FREE
		& track.seg24.occDown = FREE & track.seg24.occUp = FREE
		& track.seg25.occDown = FREE & track.seg25.occUp = FREE
        & track.point5.mode = EXLOCKED
		& track.seg18.mode = EXLOCKED
		& track.seg19.mode = EXLOCKED
		& track.seg20.mode = EXLOCKED
		& track.point6.mode = EXLOCKED
		& track.point7.mode = EXLOCKED
		& track.seg23.mode = EXLOCKED
		& track.seg24.mode = EXLOCKED
		& track.seg25.mode = EXLOCKED
        & TRUE
		: LOCKED;

		track.r74.mode = LOCKED
		& track.signal14.ACT = GO
		& track.point5.occNS != FREE
		: OCCUPIED;

		track.r74.mode = OCCUPIED
		& track.seg25.occUp in {HEADOCC, COMPLETETRAINOCC}
		& track.seg25.mode = USED
		& track.seg25.prev = RELEASED
		: FREE;

		TRUE : track.r74.mode;
	esac;


-------------------------------------------------------------------------------
-- Main Module --
-- Routes grant states in an interlocked layout
-------------------------------------------------------------------------------
MODULE main
VAR
	iSys : InterlockingSystem;

-- Fairness: all infinite executions are fair (required for non-vacuous LTL)
FAIRNESS TRUE
