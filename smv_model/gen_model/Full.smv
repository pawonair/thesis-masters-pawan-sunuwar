			& (point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE)
			& (seg14.mode = AVAILABLE | seg14.mode = EXLOCKED)
			& seg14.prev = PENDING
			& (seg14.occDown = FREE & seg14.occUp = FREE)
			& point4.ACT = NORMAL
		)
		| (
			r44.mode = OCCUPIED
			& (point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE)
			& (point3.mode = AVAILABLE | point3.mode = EXLOCKED)
			& point3.prev = PENDING
			& (point3.occSNR = FREE & point3.occNS = FREE & point3.occRS = FREE)
			& point4.ACT = REVERSE
		)
		| (
			r45.mode = OCCUPIED
			& (point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE)
			& (point6.mode = AVAILABLE | point6.mode = EXLOCKED)
			& point6.prev = PENDING
			& (point6.occSNR = FREE & point6.occNS = FREE & point6.occRS = FREE)
			& point4.ACT = NORMAL
		)
		| (
			r48.mode = OCCUPIED
			& (point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE)
			& (point3.mode = AVAILABLE | point3.mode = EXLOCKED)
			& point3.prev = PENDING
			& (point3.occSNR = FREE & point3.occNS = FREE & point3.occRS = FREE)
			& point4.ACT = REVERSE
		)
		| (
			r50.mode = OCCUPIED
			& (point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE)
			& (point3.mode = AVAILABLE | point3.mode = EXLOCKED)
			& point3.prev = PENDING
			& (point3.occSNR = FREE & point3.occNS = FREE & point3.occRS = FREE)
			& point4.ACT = REVERSE
		)
		| (
			r52.mode = OCCUPIED
			& (point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE)
			& (point3.mode = AVAILABLE | point3.mode = EXLOCKED)
			& point3.prev = PENDING
			& (point3.occSNR = FREE & point3.occNS = FREE & point3.occRS = FREE)
			& point4.ACT = REVERSE
		)
		| (
			r53.mode = OCCUPIED
			& (point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE)
			& point4.ACT = NORMAL
		)
		| (
			r54.mode = OCCUPIED
			& (point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE)
			& point4.ACT = NORMAL
		)
		| (
			r55.mode = OCCUPIED
			& (point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE)
			& point4.ACT = REVERSE
		)
		| (
			r56.mode = OCCUPIED
			& (point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE)
			& point4.ACT = REVERSE
		)
		| (
			r57.mode = OCCUPIED
			& (point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE)
			& point4.ACT = NORMAL
		)
		| (
			r58.mode = OCCUPIED
			& (point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE)
			& point4.ACT = NORMAL
		)
		| (
			r59.mode = OCCUPIED
			& (point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE)
			& point4.ACT = REVERSE
		)
		| (
			r60.mode = OCCUPIED
			& (point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE)
			& point4.ACT = NORMAL
		)
		| (
			r64.mode = OCCUPIED
			& (point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE)
			& (seg14.mode = AVAILABLE | seg14.mode = EXLOCKED)
			& seg14.prev = PENDING
			& (seg14.occDown = FREE & seg14.occUp = FREE)
			& point4.ACT = REVERSE
		)
		| (
			r69.mode = OCCUPIED
			& (point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE)
			& (point6.mode = AVAILABLE | point6.mode = EXLOCKED)
			& point6.prev = PENDING
			& (point6.occSNR = FREE & point6.occNS = FREE & point6.occRS = FREE)
			& point4.ACT = NORMAL
		)
		| (
			r70.mode = OCCUPIED
			& (point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE)
			& (point6.mode = AVAILABLE | point6.mode = EXLOCKED)
			& point6.prev = PENDING
			& (point6.occSNR = FREE & point6.occNS = FREE & point6.occRS = FREE)
			& point4.ACT = NORMAL
		)
		| (
			r72.mode = OCCUPIED
			& (point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE)
			& (point6.mode = AVAILABLE | point6.mode = EXLOCKED)
			& point6.prev = PENDING
			& (point6.occSNR = FREE & point6.occNS = FREE & point6.occRS = FREE)
			& point4.ACT = NORMAL
		)
		| (
			r73.mode = OCCUPIED
			& (point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE)
			& (point6.mode = AVAILABLE | point6.mode = EXLOCKED)
			& point6.prev = PENDING
			& (point6.occSNR = FREE & point6.occNS = FREE & point6.occRS = FREE)
			& point4.ACT = NORMAL
		)
		)
		: RELEASED;

		point4.prev = RELEASED & point4.mode = AVAILABLE : PENDING;

		TRUE : point4.prev;
	esac;

	-- SEGMENTS OCCUPANCY NEXT --
	-- seg5
	next(seg5.occDown) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg5.occDown = FREE & seg6.occDown in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg5.occDown = FREE & seg5.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg5.occDown = FREE & seg5.mode != AVAILABLE
		& seg6.occDown = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg5.occDown = FREE & seg5.mode != AVAILABLE
		& seg6.occDown = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg5.occDown = FREE & seg5.mode != AVAILABLE
		& seg6.occDown = TAILOCC
		: ERROROCC;

		-- train head leaves or train collects here if head present and signal is GO
		seg5.occDown = HEADOCC & signal3.ACT = GO : {COMPLETETRAINOCC, TAILOCC};

		-- train collects here if head present and signal is STOP
		seg5.occDown = HEADOCC & signal3.ACT = STOP : COMPLETETRAINOCC;

		-- train stays here if train is present and signal is STOP
		seg5.occDown = COMPLETETRAINOCC & signal3.ACT = STOP : COMPLETETRAINOCC;

		-- train moves on with head if train is present and signal is GO
		seg5.occDown = COMPLETETRAINOCC & signal3.ACT = GO : TAILOCC;

		-- train tail leaves if tail is present
		seg5.occDown = TAILOCC : FREE;

		TRUE : seg5.occDown;
	esac;

	next(seg5.occUp) := case
		-- stays FREE if predecessor point has no train (per ACT position)
		seg5.occUp = FREE & ((point1.ACT = NORMAL & point1.occNS in {FREE, ERROROCC}) | (point1.ACT = REVERSE & point1.occRS in {FREE, ERROROCC})) : FREE;

		-- stays FREE if not allocated
		seg5.occUp = FREE & seg5.mode = AVAILABLE : FREE;

		-- non-deterministic head entry with point1.ACT = NORMAL
		seg5.occUp = FREE & seg5.mode != AVAILABLE
		& point1.ACT = NORMAL & point1.occNS = HEADOCC
		: {HEADOCC, FREE};

		-- deterministic head entry with point1.ACT = NORMAL
		seg5.occUp = FREE & seg5.mode != AVAILABLE
		& point1.ACT = NORMAL & point1.occNS = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC: tail without head with point1.ACT = NORMAL
		seg5.occUp = FREE & seg5.mode != AVAILABLE
		& point1.ACT = NORMAL & point1.occNS = TAILOCC
		: ERROROCC;

		-- non-deterministic head entry with point1.ACT = REVERSE
		seg5.occUp = FREE & seg5.mode != AVAILABLE
		& point1.ACT = REVERSE & point1.occRS = HEADOCC
		: {HEADOCC, FREE};

		-- deterministic head entry with point1.ACT = REVERSE
		seg5.occUp = FREE & seg5.mode != AVAILABLE
		& point1.ACT = REVERSE & point1.occRS = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC: tail without head with point1.ACT = REVERSE
		seg5.occUp = FREE & seg5.mode != AVAILABLE
		& point1.ACT = REVERSE & point1.occRS = TAILOCC
		: ERROROCC;

		-- train head leaves or train collects here if head present
		seg5.occUp = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		seg5.occUp = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		seg5.occUp = TAILOCC : FREE;

		TRUE : seg5.occUp;
	esac;

	-- seg6
	next(seg6.occDown) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg6.occDown = FREE & seg7.occDown in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg6.occDown = FREE & seg6.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg6.occDown = FREE & seg6.mode != AVAILABLE
		& seg7.occDown = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg6.occDown = FREE & seg6.mode != AVAILABLE
		& seg7.occDown = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg6.occDown = FREE & seg6.mode != AVAILABLE
		& seg7.occDown = TAILOCC
		: ERROROCC;

		-- train head leaves or train collects here if head present
		seg6.occDown = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		seg6.occDown = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		seg6.occDown = TAILOCC : FREE;

		TRUE : seg6.occDown;
	esac;

	next(seg6.occUp) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg6.occUp = FREE & seg5.occUp in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg6.occUp = FREE & seg6.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg6.occUp = FREE & seg6.mode != AVAILABLE
		& seg5.occUp = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg6.occUp = FREE & seg6.mode != AVAILABLE
		& seg5.occUp = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg6.occUp = FREE & seg6.mode != AVAILABLE
		& seg5.occUp = TAILOCC
		: ERROROCC;

		-- train head leaves or train collects here if head present
		seg6.occUp = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		seg6.occUp = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		seg6.occUp = TAILOCC : FREE;

		TRUE : seg6.occUp;
	esac;

	-- seg7
	next(seg7.occDown) := case
		-- stays FREE as no train can enter from out of bounds
		seg7.occDown = FREE : FREE;

		-- ERROROCC if head of a train is here, as the tail has no previous segment
		seg7.occDown = HEADOCC : ERROROCC;

		-- stays COMPLETETRAINOCC if the segment is not in USED mode
		seg7.occDown = COMPLETETRAINOCC & seg7.mode != USED : COMPLETETRAINOCC;

		-- train moves on with head if train is present
		seg7.occDown = COMPLETETRAINOCC & seg7.mode = USED : TAILOCC;

		-- train tail leaves if tail is present
		seg7.occDown = TAILOCC : FREE;

		TRUE : seg7.occDown;
	esac;

	next(seg7.occUp) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg7.occUp = FREE & seg6.occUp in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg7.occUp = FREE & seg7.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg7.occUp = FREE & seg7.mode != AVAILABLE
		& seg6.occUp = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg7.occUp = FREE & seg7.mode != AVAILABLE
		& seg6.occUp = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg7.occUp = FREE & seg7.mode != AVAILABLE
		& seg6.occUp = TAILOCC
		: ERROROCC;

		-- train collects here if head present and signal is STOP
		seg7.occUp = HEADOCC & signal4.ACT = STOP : COMPLETETRAINOCC;

		-- ERROROCC if train head present and signal is GO
		seg7.occUp = HEADOCC & signal4.ACT = GO : ERROROCC;

		-- train stays here and signal is STOP
		seg7.occUp = COMPLETETRAINOCC & signal4.ACT = STOP : COMPLETETRAINOCC;

		-- ERROROCC if train in COMPLETETRAINOCC and signal is GO
		seg7.occUp = COMPLETETRAINOCC & signal4.ACT = GO : ERROROCC;

		-- ERROROCC if train tail is present
		seg7.occUp = TAILOCC : ERROROCC;

		TRUE : seg7.occUp;
	esac;

	-- seg9
	next(seg9.occDown) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg9.occDown = FREE & seg10.occDown in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg9.occDown = FREE & seg9.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg9.occDown = FREE & seg9.mode != AVAILABLE
		& seg10.occDown = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg9.occDown = FREE & seg9.mode != AVAILABLE
		& seg10.occDown = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg9.occDown = FREE & seg9.mode != AVAILABLE
		& seg10.occDown = TAILOCC
		: ERROROCC;

		-- train head leaves or train collects here if head present and signal is GO
		seg9.occDown = HEADOCC & signal5.ACT = GO : {COMPLETETRAINOCC, TAILOCC};

		-- train collects here if head present and signal is STOP
		seg9.occDown = HEADOCC & signal5.ACT = STOP : COMPLETETRAINOCC;

		-- train stays here if train is present and signal is STOP
		seg9.occDown = COMPLETETRAINOCC & signal5.ACT = STOP : COMPLETETRAINOCC;

		-- train moves on with head if train is present and signal is GO
		seg9.occDown = COMPLETETRAINOCC & signal5.ACT = GO : TAILOCC;

		-- train tail leaves if tail is present
		seg9.occDown = TAILOCC : FREE;

		TRUE : seg9.occDown;
	esac;

	next(seg9.occUp) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg9.occUp = FREE & point2.occSNR in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg9.occUp = FREE & seg9.mode = AVAILABLE : FREE;

		-- train blocked at signal STOP regardless of predecessor state
		seg9.occUp = FREE & seg9.mode != AVAILABLE
		& point2.occSNR in {HEADOCC, COMPLETETRAINOCC} & signal5.ACT = STOP
		: FREE;

		-- non-deterministic head entry if previous segment has head and signal is GO
		seg9.occUp = FREE & seg9.mode != AVAILABLE
		& point2.occSNR = HEADOCC & signal5.ACT = GO
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train and signal is GO
		seg9.occUp = FREE & seg9.mode != AVAILABLE
		& point2.occSNR = COMPLETETRAINOCC & signal5.ACT = GO
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		-- and signal is GO
		seg9.occUp = FREE & seg9.mode != AVAILABLE
		& point2.occSNR = TAILOCC & signal5.ACT = GO
		: ERROROCC;

		-- train head leaves or train collects here if head present
		seg9.occUp = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		seg9.occUp = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		seg9.occUp = TAILOCC : FREE;

		TRUE : seg9.occUp;
	esac;

	-- seg10
	next(seg10.occDown) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg10.occDown = FREE & seg11.occDown in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg10.occDown = FREE & seg10.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg10.occDown = FREE & seg10.mode != AVAILABLE
		& seg11.occDown = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg10.occDown = FREE & seg10.mode != AVAILABLE
		& seg11.occDown = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg10.occDown = FREE & seg10.mode != AVAILABLE
		& seg11.occDown = TAILOCC
		: ERROROCC;

		-- train head leaves or train collects here if head present
		seg10.occDown = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		seg10.occDown = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		seg10.occDown = TAILOCC : FREE;

		TRUE : seg10.occDown;
	esac;

	next(seg10.occUp) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg10.occUp = FREE & seg9.occUp in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg10.occUp = FREE & seg10.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg10.occUp = FREE & seg10.mode != AVAILABLE
		& seg9.occUp = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg10.occUp = FREE & seg10.mode != AVAILABLE
		& seg9.occUp = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg10.occUp = FREE & seg10.mode != AVAILABLE
		& seg9.occUp = TAILOCC
		: ERROROCC;

		-- train head leaves or train collects here if head present
		seg10.occUp = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		seg10.occUp = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		seg10.occUp = TAILOCC : FREE;

		TRUE : seg10.occUp;
	esac;

	-- seg11
	next(seg11.occDown) := case
		-- stays FREE as no train can enter from out of bounds
		seg11.occDown = FREE : FREE;

		-- ERROROCC if head of a train is here, as the tail has no previous segment
		seg11.occDown = HEADOCC : ERROROCC;

		-- stays COMPLETETRAINOCC if the segment is not in USED mode
		seg11.occDown = COMPLETETRAINOCC & seg11.mode != USED : COMPLETETRAINOCC;

		-- train moves on with head if train is present
		seg11.occDown = COMPLETETRAINOCC & seg11.mode = USED : TAILOCC;

		-- train tail leaves if tail is present
		seg11.occDown = TAILOCC : FREE;

		TRUE : seg11.occDown;
	esac;

	next(seg11.occUp) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg11.occUp = FREE & seg10.occUp in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg11.occUp = FREE & seg11.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg11.occUp = FREE & seg11.mode != AVAILABLE
		& seg10.occUp = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg11.occUp = FREE & seg11.mode != AVAILABLE
		& seg10.occUp = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg11.occUp = FREE & seg11.mode != AVAILABLE
		& seg10.occUp = TAILOCC
		: ERROROCC;

		-- train collects here if head present and signal is STOP
		seg11.occUp = HEADOCC & signal6.ACT = STOP : COMPLETETRAINOCC;

		-- ERROROCC if train head present and signal is GO
		seg11.occUp = HEADOCC & signal6.ACT = GO : ERROROCC;

		-- train stays here and signal is STOP
		seg11.occUp = COMPLETETRAINOCC & signal6.ACT = STOP : COMPLETETRAINOCC;

		-- ERROROCC if train in COMPLETETRAINOCC and signal is GO
		seg11.occUp = COMPLETETRAINOCC & signal6.ACT = GO : ERROROCC;

		-- ERROROCC if train tail is present
		seg11.occUp = TAILOCC : ERROROCC;

		TRUE : seg11.occUp;
