	& (point4.occNS = COMPLETETRAINOCC -> (point6.occNS != TAILOCC & seg14.occUp != HEADOCC))
	& (point4.occNS = TAILOCC -> (point6.occNS != TAILOCC & seg14.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (point4.occRS = HEADOCC -> (point3.occRS in {TAILOCC, ERROROCC} & seg14.occUp != HEADOCC))
	& (point4.occRS = COMPLETETRAINOCC -> (point3.occRS != TAILOCC & seg14.occUp != HEADOCC))
	& (point4.occRS = TAILOCC -> (point3.occRS != TAILOCC & seg14.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))

