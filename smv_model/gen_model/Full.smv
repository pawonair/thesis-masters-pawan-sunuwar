-------------------------------------------------------------------------------
-- Interlocking System Moduel --
-- Represents a route state transitions for the train movement
-------------------------------------------------------------------------------
MODULE InterlockingSystem 
VAR
	track : TrackSection;
ASSIGN
	next(track.r0.transition) := case
		track.r0.transition = CAN_DISPATCH
		& track.r33.mode != ALLOCATING & track.r33.mode != LOCKED
		& track.r30.mode != ALLOCATING & track.r30.mode != LOCKED
		& track.r65.mode != ALLOCATING & track.r65.mode != LOCKED
		& track.r27.mode != ALLOCATING & track.r27.mode != LOCKED
