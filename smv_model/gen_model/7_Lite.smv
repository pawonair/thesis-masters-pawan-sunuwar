	& (seg15.occUp = COMPLETETRAINOCC -> (seg14.occUp != TAILOCC & seg16.occUp != HEADOCC))
	& (seg15.occUp = TAILOCC -> (seg14.occUp != TAILOCC & seg16.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg15.occDown = HEADOCC -> (seg16.occDown in {TAILOCC, ERROROCC} & seg14.occDown != HEADOCC))
	& (seg15.occDown = COMPLETETRAINOCC -> (seg16.occDown != TAILOCC & seg14.occDown != HEADOCC))
	& (seg15.occDown = TAILOCC -> (seg16.occDown != TAILOCC & seg14.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg14.occUp = HEADOCC -> (seg15.occUp != HEADOCC))
	& (seg14.occUp = COMPLETETRAINOCC -> (seg15.occUp != HEADOCC))
	& (seg14.occUp = TAILOCC -> (seg15.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg14.occDown = HEADOCC -> (seg15.occDown in {TAILOCC, ERROROCC} & point4.occSNR != HEADOCC))
	& (seg14.occDown = COMPLETETRAINOCC -> (seg15.occDown != TAILOCC & point4.occSNR != HEADOCC))
	& (seg14.occDown = TAILOCC -> (seg15.occDown != TAILOCC & point4.occSNR in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg18.occUp = HEADOCC -> (seg19.occUp in {TAILOCC, ERROROCC}))
	& (seg18.occUp = COMPLETETRAINOCC -> (seg19.occUp != TAILOCC))
	& (seg18.occUp = TAILOCC -> (seg19.occUp != TAILOCC))
	& (seg18.occDown = HEADOCC -> (point5.occSNR in {TAILOCC, ERROROCC} & seg19.occDown != HEADOCC))
	& (seg18.occDown = COMPLETETRAINOCC -> (point5.occSNR != TAILOCC & seg19.occDown != HEADOCC))
	& (seg18.occDown = TAILOCC -> (point5.occSNR != TAILOCC & seg19.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg19.occUp = HEADOCC -> (seg18.occUp in {TAILOCC, ERROROCC} & seg20.occUp != HEADOCC))
	& (seg19.occUp = COMPLETETRAINOCC -> (seg18.occUp != TAILOCC & seg20.occUp != HEADOCC))
	& (seg19.occUp = TAILOCC -> (seg18.occUp != TAILOCC & seg20.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg19.occDown = HEADOCC -> (seg20.occDown in {TAILOCC, ERROROCC} & seg18.occDown != HEADOCC))
	& (seg19.occDown = COMPLETETRAINOCC -> (seg20.occDown != TAILOCC & seg18.occDown != HEADOCC))
	& (seg19.occDown = TAILOCC -> (seg20.occDown != TAILOCC & seg18.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg20.occUp = HEADOCC -> (seg19.occUp in {TAILOCC, ERROROCC} & seg19.occUp != HEADOCC))
	& (seg20.occUp = COMPLETETRAINOCC -> (seg19.occUp != TAILOCC & seg19.occUp != HEADOCC))
	& (seg20.occUp = TAILOCC -> (seg19.occUp != TAILOCC & seg19.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg20.occDown = HEADOCC -> (seg19.occDown in {TAILOCC, ERROROCC} & seg19.occDown != HEADOCC))
	& (seg20.occDown = COMPLETETRAINOCC -> (seg19.occDown != TAILOCC & seg19.occDown != HEADOCC))
	& (seg20.occDown = TAILOCC -> (seg19.occDown != TAILOCC & seg19.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (point1.occSNR = HEADOCC -> (seg5.occDown in {TAILOCC, ERROROCC} & seg3.occDown != HEADOCC & seg16.occDown != HEADOCC))
	& (point1.occSNR = COMPLETETRAINOCC -> (seg5.occDown != TAILOCC & seg3.occDown != HEADOCC & seg16.occDown != HEADOCC))
	& (point1.occSNR = TAILOCC -> (seg5.occDown != TAILOCC & (seg3.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC} | seg16.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC})))
	& (point1.occNS = HEADOCC -> (seg3.occUp in {TAILOCC, ERROROCC} & seg5.occUp != HEADOCC))
	& (point1.occNS = COMPLETETRAINOCC -> (seg3.occUp != TAILOCC & seg5.occUp != HEADOCC))
	& (point1.occNS = TAILOCC -> (seg3.occUp != TAILOCC & seg5.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (point1.occRS = HEADOCC -> (seg16.occUp in {TAILOCC, ERROROCC} & seg5.occUp != HEADOCC))
	& (point1.occRS = COMPLETETRAINOCC -> (seg16.occUp != TAILOCC & seg5.occUp != HEADOCC))
	& (point1.occRS = TAILOCC -> (seg16.occUp != TAILOCC & seg5.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (point5.occRS = HEADOCC -> (point2.occRS in {TAILOCC, ERROROCC} & seg18.occUp != HEADOCC))
	& (point5.occRS = COMPLETETRAINOCC -> (point2.occRS != TAILOCC & seg18.occUp != HEADOCC))
	& (point5.occRS = TAILOCC -> (point2.occRS != TAILOCC & seg18.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (point2.occSNR = HEADOCC -> (seg7.occDown in {TAILOCC, ERROROCC} & seg9.occDown != HEADOCC & point5.occSNR != HEADOCC))
	& (point2.occSNR = COMPLETETRAINOCC -> (seg7.occDown != TAILOCC & seg9.occDown != HEADOCC & point5.occSNR != HEADOCC))
	& (point2.occSNR = TAILOCC -> (seg7.occDown != TAILOCC & (seg9.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC} | point5.occSNR in {HEADOCC, COMPLETETRAINOCC, ERROROCC})))
	& (point2.occNS = HEADOCC -> (seg9.occUp in {TAILOCC, ERROROCC} & seg7.occUp != HEADOCC))
	& (point2.occNS = COMPLETETRAINOCC -> (seg9.occUp != TAILOCC & seg7.occUp != HEADOCC))
	& (point2.occNS = TAILOCC -> (seg9.occUp != TAILOCC & seg7.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (point2.occRS = HEADOCC -> (point5.occRS in {TAILOCC, ERROROCC} & seg7.occUp != HEADOCC))
	& (point2.occRS = COMPLETETRAINOCC -> (point5.occRS != TAILOCC & seg7.occUp != HEADOCC))
	& (point2.occRS = TAILOCC -> (point5.occRS != TAILOCC & seg7.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (point3.occSNR = HEADOCC -> (seg11.occDown in {TAILOCC, ERROROCC} & seg1.occDown != HEADOCC & point4.occSNR != HEADOCC))
	& (point3.occSNR = COMPLETETRAINOCC -> (seg11.occDown != TAILOCC & seg1.occDown != HEADOCC & point4.occSNR != HEADOCC))
	& (point3.occSNR = TAILOCC -> (seg11.occDown != TAILOCC & (seg1.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC} | point4.occSNR in {HEADOCC, COMPLETETRAINOCC, ERROROCC})))
	& (point3.occNS = HEADOCC -> (seg1.occUp in {TAILOCC, ERROROCC} & seg11.occUp != HEADOCC))
	& (point3.occNS = COMPLETETRAINOCC -> (seg1.occUp != TAILOCC & seg11.occUp != HEADOCC))
	& (point3.occNS = TAILOCC -> (seg1.occUp != TAILOCC & seg11.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (point3.occRS = HEADOCC -> (point4.occRS in {TAILOCC, ERROROCC} & seg11.occUp != HEADOCC))
	& (point3.occRS = COMPLETETRAINOCC -> (point4.occRS != TAILOCC & seg11.occUp != HEADOCC))
	& (point3.occRS = TAILOCC -> (point4.occRS != TAILOCC & seg11.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (point6.occSNR = HEADOCC -> (seg20.occDown in {TAILOCC, ERROROCC} & point4.occSNR != HEADOCC & point7.occSNR != HEADOCC))
	& (point6.occSNR = COMPLETETRAINOCC -> (seg20.occDown != TAILOCC & point4.occSNR != HEADOCC & point7.occSNR != HEADOCC))
	& (point6.occSNR = TAILOCC -> (seg20.occDown != TAILOCC & (point4.occSNR in {HEADOCC, COMPLETETRAINOCC, ERROROCC} | point7.occSNR in {HEADOCC, COMPLETETRAINOCC, ERROROCC})))
	& (point6.occNS = HEADOCC -> (point4.occNS in {TAILOCC, ERROROCC} & seg20.occUp != HEADOCC))
	& (point6.occNS = COMPLETETRAINOCC -> (point4.occNS != TAILOCC & seg20.occUp != HEADOCC))
	& (point6.occNS = TAILOCC -> (point4.occNS != TAILOCC & seg20.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (point6.occRS = HEADOCC -> (point7.occRS in {TAILOCC, ERROROCC} & seg20.occUp != HEADOCC))
	& (point6.occRS = COMPLETETRAINOCC -> (point7.occRS != TAILOCC & seg20.occUp != HEADOCC))
	& (point6.occRS = TAILOCC -> (point7.occRS != TAILOCC & seg20.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (point4.occSNR = HEADOCC -> (seg14.occDown in {TAILOCC, ERROROCC} & point6.occSNR != HEADOCC & point3.occSNR != HEADOCC))
	& (point4.occSNR = COMPLETETRAINOCC -> (seg14.occDown != TAILOCC & point6.occSNR != HEADOCC & point3.occSNR != HEADOCC))
	& (point4.occSNR = TAILOCC -> (seg14.occDown != TAILOCC & (point6.occSNR in {HEADOCC, COMPLETETRAINOCC, ERROROCC} | point3.occSNR in {HEADOCC, COMPLETETRAINOCC, ERROROCC})))
	& (point4.occNS = HEADOCC -> (point6.occNS in {TAILOCC, ERROROCC} & seg14.occUp != HEADOCC))
	& (point4.occNS = COMPLETETRAINOCC -> (point6.occNS != TAILOCC & seg14.occUp != HEADOCC))
	& (point4.occNS = TAILOCC -> (point6.occNS != TAILOCC & seg14.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (point4.occRS = HEADOCC -> (point3.occRS in {TAILOCC, ERROROCC} & seg14.occUp != HEADOCC))
	& (point4.occRS = COMPLETETRAINOCC -> (point3.occRS != TAILOCC & seg14.occUp != HEADOCC))
	& (point4.occRS = TAILOCC -> (point3.occRS != TAILOCC & seg14.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))

-- Train Occupancy Error --
INVARSPEC
	NAME NoOccUpErrors := !(
		seg5.occUp = ERROROCC
		| seg6.occUp = ERROROCC
		| seg7.occUp = ERROROCC
		| seg11.occUp = ERROROCC
		| seg10.occUp = ERROROCC
		| seg9.occUp = ERROROCC
		| seg3.occUp = ERROROCC
		| seg2.occUp = ERROROCC
		| seg1.occUp = ERROROCC
		| seg16.occUp = ERROROCC
		| seg15.occUp = ERROROCC
		| seg14.occUp = ERROROCC
		| seg18.occUp = ERROROCC
		| seg19.occUp = ERROROCC
		| seg20.occUp = ERROROCC
	);

INVARSPEC
	NAME NoOccDownErrors := !(
		seg5.occDown = ERROROCC
		| seg6.occDown = ERROROCC
		| seg7.occDown = ERROROCC
		| seg11.occDown = ERROROCC
		| seg10.occDown = ERROROCC
		| seg9.occDown = ERROROCC
		| seg3.occDown = ERROROCC
		| seg2.occDown = ERROROCC
		| seg1.occDown = ERROROCC
		| seg16.occDown = ERROROCC
		| seg15.occDown = ERROROCC
		| seg14.occDown = ERROROCC
		| seg18.occDown = ERROROCC
		| seg19.occDown = ERROROCC
		| seg20.occDown = ERROROCC
	);

INVARSPEC
	NAME NoOccPointErrors := !(
		point1.occSNR = ERROROCC
		| point1.occRS = ERROROCC
		| point1.occNS = ERROROCC
		| point5.occSNR = ERROROCC
		| point5.occRS = ERROROCC
		| point5.occNS = ERROROCC
		| point2.occSNR = ERROROCC
		| point2.occRS = ERROROCC
		| point2.occNS = ERROROCC
		| point3.occSNR = ERROROCC
		| point3.occRS = ERROROCC
		| point3.occNS = ERROROCC
		| point6.occSNR = ERROROCC
		| point6.occRS = ERROROCC
		| point6.occNS = ERROROCC
		| point4.occSNR = ERROROCC
		| point4.occRS = ERROROCC
		| point4.occNS = ERROROCC
		| point7.occSNR = ERROROCC
		| point7.occRS = ERROROCC
		| point7.occNS = ERROROCC
	);


-- Safety Invariants --
INVARSPEC
	NAME NoHeadToHeadSegmentCollisions := (
		(seg5.occDown != FREE -> seg5.occUp = FREE) & (seg5.occUp != FREE -> seg5.occDown = FREE)
		& (seg6.occDown != FREE -> seg6.occUp = FREE) & (seg6.occUp != FREE -> seg6.occDown = FREE)
		& (seg7.occDown != FREE -> seg7.occUp = FREE) & (seg7.occUp != FREE -> seg7.occDown = FREE)
		& (seg11.occDown != FREE -> seg11.occUp = FREE) & (seg11.occUp != FREE -> seg11.occDown = FREE)
		& (seg10.occDown != FREE -> seg10.occUp = FREE) & (seg10.occUp != FREE -> seg10.occDown = FREE)
		& (seg9.occDown != FREE -> seg9.occUp = FREE) & (seg9.occUp != FREE -> seg9.occDown = FREE)
		& (seg3.occDown != FREE -> seg3.occUp = FREE) & (seg3.occUp != FREE -> seg3.occDown = FREE)
		& (seg2.occDown != FREE -> seg2.occUp = FREE) & (seg2.occUp != FREE -> seg2.occDown = FREE)
		& (seg1.occDown != FREE -> seg1.occUp = FREE) & (seg1.occUp != FREE -> seg1.occDown = FREE)
		& (seg16.occDown != FREE -> seg16.occUp = FREE) & (seg16.occUp != FREE -> seg16.occDown = FREE)
		& (seg15.occDown != FREE -> seg15.occUp = FREE) & (seg15.occUp != FREE -> seg15.occDown = FREE)
		& (seg14.occDown != FREE -> seg14.occUp = FREE) & (seg14.occUp != FREE -> seg14.occDown = FREE)
		& (seg18.occDown != FREE -> seg18.occUp = FREE) & (seg18.occUp != FREE -> seg18.occDown = FREE)
		& (seg19.occDown != FREE -> seg19.occUp = FREE) & (seg19.occUp != FREE -> seg19.occDown = FREE)
		& (seg20.occDown != FREE -> seg20.occUp = FREE) & (seg20.occUp != FREE -> seg20.occDown = FREE)
	);

INVARSPEC
	NAME NoHeadToHeadPointCollisions := (
		(point1.occSNR != FREE -> (point1.occNS = FREE & point1.occRS = FREE))
        & (point1.occNS != FREE -> (point1.occSNR = FREE & point1.occRS = FREE))
        & (point1.occRS != FREE -> (point1.occSNR = FREE & point1.occNS = FREE))
		& (point5.occSNR != FREE -> (point5.occNS = FREE & point5.occRS = FREE))
        & (point5.occNS != FREE -> (point5.occSNR = FREE & point5.occRS = FREE))
        & (point5.occRS != FREE -> (point5.occSNR = FREE & point5.occNS = FREE))
		& (point2.occSNR != FREE -> (point2.occNS = FREE & point2.occRS = FREE))
        & (point2.occNS != FREE -> (point2.occSNR = FREE & point2.occRS = FREE))
        & (point2.occRS != FREE -> (point2.occSNR = FREE & point2.occNS = FREE))
		& (point3.occSNR != FREE -> (point3.occNS = FREE & point3.occRS = FREE))
        & (point3.occNS != FREE -> (point3.occSNR = FREE & point3.occRS = FREE))
        & (point3.occRS != FREE -> (point3.occSNR = FREE & point3.occNS = FREE))
		& (point6.occSNR != FREE -> (point6.occNS = FREE & point6.occRS = FREE))
        & (point6.occNS != FREE -> (point6.occSNR = FREE & point6.occRS = FREE))
        & (point6.occRS != FREE -> (point6.occSNR = FREE & point6.occNS = FREE))
		& (point4.occSNR != FREE -> (point4.occNS = FREE & point4.occRS = FREE))
        & (point4.occNS != FREE -> (point4.occSNR = FREE & point4.occRS = FREE))
        & (point4.occRS != FREE -> (point4.occSNR = FREE & point4.occNS = FREE))
		& (point7.occSNR != FREE -> (point7.occNS = FREE & point7.occRS = FREE))
        & (point7.occNS != FREE -> (point7.occSNR = FREE & point7.occRS = FREE))
        & (point7.occRS != FREE -> (point7.occSNR = FREE & point7.occNS = FREE))
	);

INVARSPEC
	NAME NoHeadToTailCollisionsDown := (
		(seg5.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg6.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg6.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg7.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg7.occDown in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point2.occSNR in {COMPLETETRAINOCC, HEADOCC})
			| point2.ACT = INTERMEDIATE
		)
		& (seg11.occDown in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point3.occSNR in {COMPLETETRAINOCC, HEADOCC})
			| point3.ACT = INTERMEDIATE
		)
		& (seg10.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg11.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg9.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg10.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg3.occDown in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point1.occNS in {COMPLETETRAINOCC, HEADOCC})
			| point1.ACT != NORMAL
		)
		& (seg2.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg3.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg1.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg2.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg16.occDown in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point1.occRS in {COMPLETETRAINOCC, HEADOCC})
			| point1.ACT != REVERSE
		)
		& (seg15.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg16.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg14.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg15.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg18.occDown in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point5.occSNR in {COMPLETETRAINOCC, HEADOCC})
			| point5.ACT = INTERMEDIATE
		)
		& (seg19.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg20.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg20.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg19.occUp in {HEADOCC, COMPLETETRAINOCC})
	);
INVARSPEC
	NAME NoHeadToTailCollisionsUp := (
		(seg5.occUp in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point1.occSNR in {COMPLETETRAINOCC, HEADOCC})
			| point1.ACT = INTERMEDIATE
		)
		& (seg6.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg5.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg7.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg6.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg11.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg10.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg10.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg9.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg9.occUp in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point2.occNS in {COMPLETETRAINOCC, HEADOCC})
			| point2.ACT != NORMAL
		)
		& (seg3.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg2.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg2.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg1.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg1.occUp in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point3.occNS in {COMPLETETRAINOCC, HEADOCC})
			| point3.ACT != NORMAL
		)
		& (seg16.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg15.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg15.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg14.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg14.occUp in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point4.occSNR in {COMPLETETRAINOCC, HEADOCC})
			| point4.ACT = INTERMEDIATE
		)
		& (seg18.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg19.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg19.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg18.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg20.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg19.occUp in {HEADOCC, COMPLETETRAINOCC})
	);

INVARSPEC
	NAME NoPointDerailments := (
		(
			(point1.occNS != FREE -> point1.ACT = NORMAL)
            & (point1.occRS != FREE -> point1.ACT = REVERSE)
            & (point1.occSNR != FREE -> point1.ACT != INTERMEDIATE)
		)
		& (
			(point5.occNS != FREE -> point5.ACT = NORMAL)
            & (point5.occRS != FREE -> point5.ACT = REVERSE)
            & (point5.occSNR != FREE -> point5.ACT != INTERMEDIATE)
		)
		& (
			(point2.occNS != FREE -> point2.ACT = NORMAL)
            & (point2.occRS != FREE -> point2.ACT = REVERSE)
            & (point2.occSNR != FREE -> point2.ACT != INTERMEDIATE)
		)
		& (
			(point3.occNS != FREE -> point3.ACT = NORMAL)
            & (point3.occRS != FREE -> point3.ACT = REVERSE)
            & (point3.occSNR != FREE -> point3.ACT != INTERMEDIATE)
		)
		& (
			(point6.occNS != FREE -> point6.ACT = NORMAL)
            & (point6.occRS != FREE -> point6.ACT = REVERSE)
            & (point6.occSNR != FREE -> point6.ACT != INTERMEDIATE)
		)
		& (
			(point4.occNS != FREE -> point4.ACT = NORMAL)
            & (point4.occRS != FREE -> point4.ACT = REVERSE)
            & (point4.occSNR != FREE -> point4.ACT != INTERMEDIATE)
		)
		& (
			(point7.occNS != FREE -> point7.ACT = NORMAL)
            & (point7.occRS != FREE -> point7.ACT = REVERSE)
            & (point7.occSNR != FREE -> point7.ACT != INTERMEDIATE)
		)
	);

INVARSPEC
	NAME NoPointHeadToTailCollisions := (
		(point1.occSNR in {TAILOCC, COMPLETETRAINOCC}) -> !(seg5.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (point1.occNS in {TAILOCC, COMPLETETRAINOCC}) -> !(seg3.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (point1.occRS in {TAILOCC, COMPLETETRAINOCC}) -> !(seg16.occUp in {HEADOCC, COMPLETETRAINOCC})
