			& point3.ACT = NORMAL
		)
		| (
			r10.mode = OCCUPIED
			& ((point4.mode = USED | point4.prev = PENDING) & point4.ACT = REVERSE)
			& point3.ACT = REVERSE
		)
		| (
			r11.mode = OCCUPIED
			& (seg1.mode = USED | seg1.prev = PENDING)
			& point3.ACT = NORMAL
		)
		| (
			r13.mode = OCCUPIED
			& (seg11.mode = USED | seg11.prev = PENDING)
			& point3.ACT = REVERSE
		)
		)
		& (point3.occSNR = FREE & point3.occNS = FREE & point3.occRS = FREE)
		& point3.prev = RELEASED
		: AVAILABLE;

		TRUE : point3.mode;
	esac;

	next(point6.mode) := case
		point6.mode = AVAILABLE
		& (r6.mode = ALLOCATING | r12.mode = ALLOCATING | r14.mode = ALLOCATING)
		: EXLOCKED;

		point6.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r6.mode = OCCUPIED
			& point4.mode = EXLOCKED
			& point6.ACT = NORMAL
			& point6.occSNR = FREE & point6.occNS = FREE & point6.occRS = FREE
		)
		| (
			r12.mode = OCCUPIED
			& point4.mode = USED
			& seg20.mode = EXLOCKED
			& point6.ACT = NORMAL
			& point6.occSNR = FREE & point6.occNS = FREE & point6.occRS = FREE
		)
		| (
			r14.mode = OCCUPIED
			& point7.mode = USED
			& seg20.mode = EXLOCKED
			& point6.ACT = REVERSE
			& point6.occSNR = FREE & point6.occNS = FREE & point6.occRS = FREE
		)
		)
		: USED;

		point6.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r6.mode = OCCUPIED
			& ((point4.mode = USED | point4.prev = PENDING) & point4.ACT = NORMAL)
			& point6.ACT = NORMAL
		)
		| (
			r12.mode = OCCUPIED
			& (seg20.mode = USED | seg20.prev = PENDING)
			& point6.ACT = NORMAL
		)
		| (
			r14.mode = OCCUPIED
			& (seg20.mode = USED | seg20.prev = PENDING)
			& point6.ACT = REVERSE
		)
		)
		& (point6.occSNR = FREE & point6.occNS = FREE & point6.occRS = FREE)
		& point6.prev = RELEASED
		: AVAILABLE;

		TRUE : point6.mode;
	esac;

	next(point4.mode) := case
		point4.mode = AVAILABLE
		& (r6.mode = ALLOCATING | r10.mode = ALLOCATING | r12.mode = ALLOCATING | r13.mode = ALLOCATING)
		: EXLOCKED;

		point4.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r6.mode = OCCUPIED
			& point6.mode = USED
			& seg14.mode = EXLOCKED
			& point4.ACT = NORMAL
			& point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE
		)
		| (
			r10.mode = OCCUPIED
			& point3.mode = USED
			& seg14.mode = EXLOCKED
			& point4.ACT = REVERSE
			& point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE
		)
		| (
			r12.mode = OCCUPIED
			& point6.mode = EXLOCKED
			& point4.ACT = NORMAL
			& point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE
		)
		| (
			r13.mode = OCCUPIED
			& point3.mode = EXLOCKED
			& point4.ACT = REVERSE
			& point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE
		)
		)
		: USED;

		point4.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r6.mode = OCCUPIED
			& (seg14.mode = USED | seg14.prev = PENDING)
			& point4.ACT = NORMAL
		)
		| (
			r10.mode = OCCUPIED
			& (seg14.mode = USED | seg14.prev = PENDING)
			& point4.ACT = REVERSE
		)
		| (
			r12.mode = OCCUPIED
			& ((point6.mode = USED | point6.prev = PENDING) & point6.ACT = NORMAL)
			& point4.ACT = NORMAL
		)
		| (
			r13.mode = OCCUPIED
			& ((point3.mode = USED | point3.prev = PENDING) & point3.ACT = REVERSE)
			& point4.ACT = REVERSE
		)
		)
		& (point4.occSNR = FREE & point4.occNS = FREE & point4.occRS = FREE)
		& point4.prev = RELEASED
		: AVAILABLE;

		TRUE : point4.mode;
	esac;

	next(point7.mode) := case
		point7.mode = AVAILABLE
		& (r14.mode = ALLOCATING)
		: EXLOCKED;

		point7.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
			r14.mode = OCCUPIED
			& point6.mode = EXLOCKED
			& point7.ACT = REVERSE
