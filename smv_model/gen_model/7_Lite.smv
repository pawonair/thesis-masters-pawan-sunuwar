		point3.occNS = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		point3.occNS = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		point3.occNS = TAILOCC : FREE;

