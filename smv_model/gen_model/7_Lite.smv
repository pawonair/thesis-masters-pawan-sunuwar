	-- seg7
	next(seg7.occDown) := case
		-- stays FREE if predecessor point has no train (per ACT position)
		seg7.occDown = FREE & ((point2.ACT = NORMAL & point2.occNS in {FREE, ERROROCC}) | (point2.ACT = REVERSE & point2.occRS in {FREE, ERROROCC})) : FREE;

		-- stays FREE if not allocated
