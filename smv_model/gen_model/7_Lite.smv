		G(!(r7.mode = OCCUPIED & r9.mode = OCCUPIED));

LTLSPEC
	NAME r15AndR7MutuallyExclusive :=
		G(!(r15.mode = OCCUPIED & r7.mode = OCCUPIED));

LTLSPEC
	NAME r14AndR7MutuallyExclusive :=
		G(!(r14.mode = OCCUPIED & r7.mode = OCCUPIED));

LTLSPEC
	NAME r7AndR8MutuallyExclusive :=
		G(!(r7.mode = OCCUPIED & r8.mode = OCCUPIED));

LTLSPEC
	NAME r12AndR7MutuallyExclusive :=
		G(!(r12.mode = OCCUPIED & r7.mode = OCCUPIED));

LTLSPEC
	NAME r8AndR9MutuallyExclusive :=
		G(!(r8.mode = OCCUPIED & r9.mode = OCCUPIED));

LTLSPEC
	NAME r13AndR8MutuallyExclusive :=
		G(!(r13.mode = OCCUPIED & r8.mode = OCCUPIED));

LTLSPEC
	NAME r10AndR13MutuallyExclusive :=
		G(!(r10.mode = OCCUPIED & r13.mode = OCCUPIED));

LTLSPEC
	NAME r10AndR12MutuallyExclusive :=
		G(!(r10.mode = OCCUPIED & r12.mode = OCCUPIED));

LTLSPEC
	NAME r10AndR11MutuallyExclusive :=
		G(!(r10.mode = OCCUPIED & r11.mode = OCCUPIED));

LTLSPEC
	NAME r11AndR13MutuallyExclusive :=
		G(!(r11.mode = OCCUPIED & r13.mode = OCCUPIED));

LTLSPEC
	NAME r12AndR15MutuallyExclusive :=
		G(!(r12.mode = OCCUPIED & r15.mode = OCCUPIED));

LTLSPEC
	NAME r12AndR13MutuallyExclusive :=
		G(!(r12.mode = OCCUPIED & r13.mode = OCCUPIED));

LTLSPEC
	NAME r12AndR14MutuallyExclusive :=
		G(!(r12.mode = OCCUPIED & r14.mode = OCCUPIED));

LTLSPEC
	NAME r14AndR15MutuallyExclusive :=
		G(!(r14.mode = OCCUPIED & r15.mode = OCCUPIED));

-- Sanity checks: add manually based on extras_config.yml initial train positions
-- LTLSPEC NAME SanityCheckPos := F(G(<start_seg>.occ<Dir> = FREE & ...));
-- LTLSPEC NAME SanityCheckNeg := !(F(G(<start_seg>.occ<Dir> = FREE & ...)));

-------------------------------------------------------------------------------
-- Interlocking System Moduel --
-- Represents a route state transitions for the train movement
-------------------------------------------------------------------------------
MODULE InterlockingSystem 
VAR
	track : TrackSection;
ASSIGN
	next(track.r0.transition) := case
		track.r0.transition = CAN_DISPATCH
		& track.r9.mode != ALLOCATING & track.r9.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
        & track.point1.mode = AVAILABLE
		& track.seg5.mode = AVAILABLE
		& track.seg6.mode = AVAILABLE
		& track.seg7.mode = AVAILABLE
        & TRUE
        & track.seg16.occUp != FREE
		: CAN_ALLOCATE;

		track.r0.transition = CAN_ALLOCATE
		& track.r9.mode != ALLOCATING & track.r9.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
        & track.signal8.ACT = STOP
		& track.signal4.ACT = STOP
        & track.point1.ACT = REVERSE
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
        & track.point1.mode = EXLOCKED
		& track.seg5.mode = EXLOCKED
		& track.seg6.mode = EXLOCKED
		& track.seg7.mode = EXLOCKED
        & TRUE
		: CAN_LOCK;

		track.r0.transition = CAN_LOCK
		& track.r0.mode = LOCKED
		& track.signal8.ACT = GO
		& track.point1.occRS != FREE
		: CAN_OCCUPY;

		track.r0.transition = CAN_OCCUPY
		& track.r0.mode = FREE
		: CAN_DISPATCH;

		TRUE : track.r0.transition;
	esac;

	next(track.r0.mode) := case
		track.r0.mode = FREE
		& track.r0.transition = CAN_DISPATCH
		: MARKED;

		track.r0.mode = MARKED
		& track.r9.mode != ALLOCATING & track.r9.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
        & track.point1.mode = AVAILABLE
		& track.seg5.mode = AVAILABLE
		& track.seg6.mode = AVAILABLE
		& track.seg7.mode = AVAILABLE
        & TRUE
        & track.seg16.occUp != FREE
		: ALLOCATING;

		track.r0.mode = ALLOCATING
		& track.r9.mode != ALLOCATING & track.r9.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
        & track.signal8.ACT = STOP
		& track.signal4.ACT = STOP
        & track.point1.ACT = REVERSE
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
        & track.point1.mode = EXLOCKED
		& track.seg5.mode = EXLOCKED
		& track.seg6.mode = EXLOCKED
		& track.seg7.mode = EXLOCKED
        & TRUE
		: LOCKED;

		track.r0.mode = LOCKED
		& track.signal8.ACT = GO
		& track.point1.occRS != FREE
		: OCCUPIED;

		track.r0.mode = OCCUPIED
		& track.seg7.occUp in {HEADOCC, COMPLETETRAINOCC}
		& track.seg7.mode = USED
		& track.seg7.prev = RELEASED
		: FREE;

		TRUE : track.r0.mode;
	esac;

	next(track.r1.transition) := case
		track.r1.transition = CAN_DISPATCH
		& track.r9.mode != ALLOCATING & track.r9.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r15.mode != ALLOCATING & track.r15.mode != LOCKED
		& track.r8.mode != ALLOCATING & track.r8.mode != LOCKED
		& track.r7.mode != ALLOCATING & track.r7.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
        & track.point5.occSNR = FREE & track.point5.occNS = FREE & track.point5.occRS = FREE
		& track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
        & track.point5.mode = AVAILABLE
		& track.point2.mode = AVAILABLE
		& track.seg7.mode = AVAILABLE
		& track.seg6.mode = AVAILABLE
		& track.seg5.mode = AVAILABLE
        & TRUE
        & track.seg18.occDown != FREE
		: CAN_ALLOCATE;

		track.r1.transition = CAN_ALLOCATE
		& track.r9.mode != ALLOCATING & track.r9.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r15.mode != ALLOCATING & track.r15.mode != LOCKED
		& track.r8.mode != ALLOCATING & track.r8.mode != LOCKED
		& track.r7.mode != ALLOCATING & track.r7.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
        & track.signal9.ACT = STOP
		& track.signal3.ACT = STOP
        & track.point5.ACT = REVERSE
		& track.point2.ACT = REVERSE
        & track.point5.occSNR = FREE & track.point5.occNS = FREE & track.point5.occRS = FREE
		& track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
        & track.point5.mode = EXLOCKED
		& track.point2.mode = EXLOCKED
		& track.seg7.mode = EXLOCKED
		& track.seg6.mode = EXLOCKED
		& track.seg5.mode = EXLOCKED
        & TRUE
		: CAN_LOCK;

		track.r1.transition = CAN_LOCK
		& track.r1.mode = LOCKED
		& track.signal9.ACT = GO
		& track.point5.occSNR != FREE
		: CAN_OCCUPY;

		track.r1.transition = CAN_OCCUPY
		& track.r1.mode = FREE
		: CAN_DISPATCH;

		TRUE : track.r1.transition;
	esac;

	next(track.r1.mode) := case
		track.r1.mode = FREE
		& track.r1.transition = CAN_DISPATCH
		: MARKED;

		track.r1.mode = MARKED
		& track.r9.mode != ALLOCATING & track.r9.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r15.mode != ALLOCATING & track.r15.mode != LOCKED
		& track.r8.mode != ALLOCATING & track.r8.mode != LOCKED
		& track.r7.mode != ALLOCATING & track.r7.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
        & track.point5.occSNR = FREE & track.point5.occNS = FREE & track.point5.occRS = FREE
		& track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
        & track.point5.mode = AVAILABLE
		& track.point2.mode = AVAILABLE
		& track.seg7.mode = AVAILABLE
		& track.seg6.mode = AVAILABLE
		& track.seg5.mode = AVAILABLE
        & TRUE
        & track.seg18.occDown != FREE
		: ALLOCATING;

		track.r1.mode = ALLOCATING
		& track.r9.mode != ALLOCATING & track.r9.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r15.mode != ALLOCATING & track.r15.mode != LOCKED
		& track.r8.mode != ALLOCATING & track.r8.mode != LOCKED
		& track.r7.mode != ALLOCATING & track.r7.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
        & track.signal9.ACT = STOP
		& track.signal3.ACT = STOP
        & track.point5.ACT = REVERSE
		& track.point2.ACT = REVERSE
        & track.point5.occSNR = FREE & track.point5.occNS = FREE & track.point5.occRS = FREE
		& track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
        & track.point5.mode = EXLOCKED
		& track.point2.mode = EXLOCKED
		& track.seg7.mode = EXLOCKED
		& track.seg6.mode = EXLOCKED
		& track.seg5.mode = EXLOCKED
        & TRUE
		: LOCKED;

		track.r1.mode = LOCKED
		& track.signal9.ACT = GO
		& track.point5.occSNR != FREE
		: OCCUPIED;

		track.r1.mode = OCCUPIED
		& track.seg5.occDown in {HEADOCC, COMPLETETRAINOCC}
		& track.seg5.mode = USED
		& track.seg5.prev = RELEASED
		: FREE;

		TRUE : track.r1.mode;
	esac;

	next(track.r2.transition) := case
		track.r2.transition = CAN_DISPATCH
		& track.r13.mode != ALLOCATING & track.r13.mode != LOCKED
		& track.r10.mode != ALLOCATING & track.r10.mode != LOCKED
		& track.r8.mode != ALLOCATING & track.r8.mode != LOCKED
		& track.r11.mode != ALLOCATING & track.r11.mode != LOCKED
        & track.point3.occSNR = FREE & track.point3.occNS = FREE & track.point3.occRS = FREE
		& track.seg11.occDown = FREE & track.seg11.occUp = FREE
		& track.seg10.occDown = FREE & track.seg10.occUp = FREE
		& track.seg9.occDown = FREE & track.seg9.occUp = FREE
        & track.point3.mode = AVAILABLE
		& track.seg11.mode = AVAILABLE
		& track.seg10.mode = AVAILABLE
		& track.seg9.mode = AVAILABLE
        & TRUE
		: CAN_ALLOCATE;

		track.r2.transition = CAN_ALLOCATE
		& track.r13.mode != ALLOCATING & track.r13.mode != LOCKED
		& track.r10.mode != ALLOCATING & track.r10.mode != LOCKED
		& track.r8.mode != ALLOCATING & track.r8.mode != LOCKED
		& track.r11.mode != ALLOCATING & track.r11.mode != LOCKED
        & track.signal1.ACT = STOP
		& track.signal5.ACT = STOP
        & track.point3.ACT = NORMAL
        & track.point3.occSNR = FREE & track.point3.occNS = FREE & track.point3.occRS = FREE
		& track.seg11.occDown = FREE & track.seg11.occUp = FREE
		& track.seg10.occDown = FREE & track.seg10.occUp = FREE
		& track.seg9.occDown = FREE & track.seg9.occUp = FREE
        & track.point3.mode = EXLOCKED
		& track.seg11.mode = EXLOCKED
		& track.seg10.mode = EXLOCKED
		& track.seg9.mode = EXLOCKED
        & TRUE
		: CAN_LOCK;

		track.r2.transition = CAN_LOCK
		& track.r2.mode = LOCKED
		& track.signal1.ACT = GO
		& track.point3.occSNR != FREE
		: CAN_OCCUPY;

		track.r2.transition = CAN_OCCUPY
		& track.r2.mode = FREE
		: CAN_DISPATCH;

		TRUE : track.r2.transition;
	esac;

	next(track.r2.mode) := case
		track.r2.mode = FREE
		& track.r2.transition = CAN_DISPATCH
		: MARKED;

		track.r2.mode = MARKED
		& track.r13.mode != ALLOCATING & track.r13.mode != LOCKED
		& track.r10.mode != ALLOCATING & track.r10.mode != LOCKED
		& track.r8.mode != ALLOCATING & track.r8.mode != LOCKED
		& track.r11.mode != ALLOCATING & track.r11.mode != LOCKED
        & track.point3.occSNR = FREE & track.point3.occNS = FREE & track.point3.occRS = FREE
		& track.seg11.occDown = FREE & track.seg11.occUp = FREE
		& track.seg10.occDown = FREE & track.seg10.occUp = FREE
		& track.seg9.occDown = FREE & track.seg9.occUp = FREE
        & track.point3.mode = AVAILABLE
		& track.seg11.mode = AVAILABLE
		& track.seg10.mode = AVAILABLE
		& track.seg9.mode = AVAILABLE
        & TRUE
		: ALLOCATING;

		track.r2.mode = ALLOCATING
		& track.r13.mode != ALLOCATING & track.r13.mode != LOCKED
		& track.r10.mode != ALLOCATING & track.r10.mode != LOCKED
		& track.r8.mode != ALLOCATING & track.r8.mode != LOCKED
		& track.r11.mode != ALLOCATING & track.r11.mode != LOCKED
        & track.signal1.ACT = STOP
		& track.signal5.ACT = STOP
        & track.point3.ACT = NORMAL
        & track.point3.occSNR = FREE & track.point3.occNS = FREE & track.point3.occRS = FREE
		& track.seg11.occDown = FREE & track.seg11.occUp = FREE
		& track.seg10.occDown = FREE & track.seg10.occUp = FREE
		& track.seg9.occDown = FREE & track.seg9.occUp = FREE
        & track.point3.mode = EXLOCKED
		& track.seg11.mode = EXLOCKED
		& track.seg10.mode = EXLOCKED
		& track.seg9.mode = EXLOCKED
        & TRUE
		: LOCKED;

		track.r2.mode = LOCKED
		& track.signal1.ACT = GO
		& track.point3.occSNR != FREE
		: OCCUPIED;

		track.r2.mode = OCCUPIED
		& track.seg9.occDown in {HEADOCC, COMPLETETRAINOCC}
		& track.seg9.mode = USED
		& track.seg9.prev = RELEASED
		: FREE;

		TRUE : track.r2.mode;
	esac;

	next(track.r3.transition) := case
		track.r3.transition = CAN_DISPATCH
		& track.r9.mode != ALLOCATING & track.r9.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
        & track.point1.mode = AVAILABLE
		& track.seg5.mode = AVAILABLE
		& track.seg6.mode = AVAILABLE
		& track.seg7.mode = AVAILABLE
        & TRUE
        & track.seg3.occUp != FREE
		: CAN_ALLOCATE;

		track.r3.transition = CAN_ALLOCATE
		& track.r9.mode != ALLOCATING & track.r9.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
        & track.signal2.ACT = STOP
		& track.signal4.ACT = STOP
        & track.point1.ACT = NORMAL
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
        & track.point1.mode = EXLOCKED
		& track.seg5.mode = EXLOCKED
		& track.seg6.mode = EXLOCKED
		& track.seg7.mode = EXLOCKED
        & TRUE
		: CAN_LOCK;

		track.r3.transition = CAN_LOCK
		& track.r3.mode = LOCKED
		& track.signal2.ACT = GO
		& track.point1.occNS != FREE
		: CAN_OCCUPY;

		track.r3.transition = CAN_OCCUPY
		& track.r3.mode = FREE
		: CAN_DISPATCH;

		TRUE : track.r3.transition;
	esac;

	next(track.r3.mode) := case
		track.r3.mode = FREE
		& track.r3.transition = CAN_DISPATCH
		: MARKED;

		track.r3.mode = MARKED
		& track.r9.mode != ALLOCATING & track.r9.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
        & track.point1.mode = AVAILABLE
		& track.seg5.mode = AVAILABLE
		& track.seg6.mode = AVAILABLE
		& track.seg7.mode = AVAILABLE
        & TRUE
        & track.seg3.occUp != FREE
		: ALLOCATING;

		track.r3.mode = ALLOCATING
		& track.r9.mode != ALLOCATING & track.r9.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
        & track.signal2.ACT = STOP
		& track.signal4.ACT = STOP
        & track.point1.ACT = NORMAL
        & track.point1.occSNR = FREE & track.point1.occNS = FREE & track.point1.occRS = FREE
		& track.seg5.occDown = FREE & track.seg5.occUp = FREE
		& track.seg6.occDown = FREE & track.seg6.occUp = FREE
		& track.seg7.occDown = FREE & track.seg7.occUp = FREE
        & track.point1.mode = EXLOCKED
		& track.seg5.mode = EXLOCKED
		& track.seg6.mode = EXLOCKED
		& track.seg7.mode = EXLOCKED
        & TRUE
		: LOCKED;

		track.r3.mode = LOCKED
		& track.signal2.ACT = GO
		& track.point1.occNS != FREE
		: OCCUPIED;

		track.r3.mode = OCCUPIED
		& track.seg7.occUp in {HEADOCC, COMPLETETRAINOCC}
		& track.seg7.mode = USED
		& track.seg7.prev = RELEASED
		: FREE;

		TRUE : track.r3.mode;
	esac;

	next(track.r4.transition) := case
		track.r4.transition = CAN_DISPATCH
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
