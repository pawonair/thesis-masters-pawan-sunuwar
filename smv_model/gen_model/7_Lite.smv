-------------------------------------------------------------------------------
-- Main Module --
-- Routes grant states in an interlocked layout
-------------------------------------------------------------------------------
MODULE main
VAR
	iSys : InterlockingSystem;

-- Fairness: all infinite executions are fair (required for non-vacuous LTL)
FAIRNESS TRUE
-------------------------------------------------------------------------------
