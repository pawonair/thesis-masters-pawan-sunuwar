	-- SEGMENTS OCCUPANCY NEXT --
	-- seg5
	next(seg5.occDown) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg5.occDown = FREE & seg6.occDown in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg5.occDown = FREE & seg5.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg5.occDown = FREE & seg5.mode != AVAILABLE
		& seg6.occDown = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg5.occDown = FREE & seg5.mode != AVAILABLE
		& seg6.occDown = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg5.occDown = FREE & seg5.mode != AVAILABLE
		& seg6.occDown = TAILOCC
		: ERROROCC;

		-- train head leaves or train collects here if head present and signal is GO
		seg5.occDown = HEADOCC & signal3.ACT = GO : {COMPLETETRAINOCC, TAILOCC};

		-- train collects here if head present and signal is STOP
		seg5.occDown = HEADOCC & signal3.ACT = STOP : COMPLETETRAINOCC;

		-- train stays here if train is present and signal is STOP
		seg5.occDown = COMPLETETRAINOCC & signal3.ACT = STOP : COMPLETETRAINOCC;

		-- train moves on with head if train is present and signal is GO
		seg5.occDown = COMPLETETRAINOCC & signal3.ACT = GO : TAILOCC;

		-- train tail leaves if tail is present
		seg5.occDown = TAILOCC : FREE;

		TRUE : seg5.occDown;
	esac;

	next(seg5.occUp) := case
		-- stays FREE if predecessor point has no train (per ACT position)
		seg5.occUp = FREE & ((point1.ACT = NORMAL & point1.occNS in {FREE, ERROROCC}) | (point1.ACT = REVERSE & point1.occRS in {FREE, ERROROCC})) : FREE;

		-- stays FREE if not allocated
		seg5.occUp = FREE & seg5.mode = AVAILABLE : FREE;

		-- non-deterministic head entry with point1.ACT = NORMAL
		seg5.occUp = FREE & seg5.mode != AVAILABLE
		& point1.ACT = NORMAL & point1.occNS = HEADOCC
		: {HEADOCC, FREE};

		-- deterministic head entry with point1.ACT = NORMAL
		seg5.occUp = FREE & seg5.mode != AVAILABLE
		& point1.ACT = NORMAL & point1.occNS = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC: tail without head with point1.ACT = NORMAL
		seg5.occUp = FREE & seg5.mode != AVAILABLE
		& point1.ACT = NORMAL & point1.occNS = TAILOCC
		: ERROROCC;

		-- non-deterministic head entry with point1.ACT = REVERSE
		seg5.occUp = FREE & seg5.mode != AVAILABLE
		& point1.ACT = REVERSE & point1.occRS = HEADOCC
		: {HEADOCC, FREE};

		-- deterministic head entry with point1.ACT = REVERSE
		seg5.occUp = FREE & seg5.mode != AVAILABLE
		& point1.ACT = REVERSE & point1.occRS = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC: tail without head with point1.ACT = REVERSE
		seg5.occUp = FREE & seg5.mode != AVAILABLE
		& point1.ACT = REVERSE & point1.occRS = TAILOCC
		: ERROROCC;

		-- train head leaves or train collects here if head present
		seg5.occUp = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		seg5.occUp = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		seg5.occUp = TAILOCC : FREE;

		TRUE : seg5.occUp;
	esac;

	-- seg6
	next(seg6.occDown) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg6.occDown = FREE & seg7.occDown in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg6.occDown = FREE & seg6.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg6.occDown = FREE & seg6.mode != AVAILABLE
		& seg7.occDown = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg6.occDown = FREE & seg6.mode != AVAILABLE
		& seg7.occDown = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg6.occDown = FREE & seg6.mode != AVAILABLE
		& seg7.occDown = TAILOCC
		: ERROROCC;

		-- train head leaves or train collects here if head present
		seg6.occDown = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		seg6.occDown = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		seg6.occDown = TAILOCC : FREE;

		TRUE : seg6.occDown;
	esac;

