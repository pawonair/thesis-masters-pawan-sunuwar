	& (seg7.occDown = COMPLETETRAINOCC -> (point2.occSNR != TAILOCC & seg6.occDown != HEADOCC))
	& (seg7.occDown = TAILOCC -> (point2.occSNR != TAILOCC & seg6.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
