	esac;

	-- SEGMENTS/SECTIONS PREV NEXT --
	next(seg5.prev) := case
		seg5.prev = PENDING
		& seg5.mode = USED
		-- previous element released with mode in AVAILABLE and prev in PENDING
		& (
		(
			r0.mode = OCCUPIED
			& (seg5.occDown = FREE & seg5.occUp = FREE)
			& (point1.mode = AVAILABLE | point1.mode = EXLOCKED)
			& point1.prev = PENDING
			& (point1.occSNR = FREE & point1.occNS = FREE & point1.occRS = FREE)
