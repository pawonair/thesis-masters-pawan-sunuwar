		& seg1.occDown in {HEADOCC, COMPLETETRAINOCC} & signal1.ACT = STOP
		: FREE;

		-- non-deterministic head entry if previous segment has head and signal is GO
		point3.occNS = FREE & point3.mode != AVAILABLE & point3.ACT = NORMAL
		& seg1.occDown = HEADOCC & signal1.ACT = GO
