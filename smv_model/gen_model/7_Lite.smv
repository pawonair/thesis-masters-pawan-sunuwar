	next(seg18.occDown) := case
		-- stays FREE if predecessor point has no train (per ACT position)
		seg18.occDown = FREE & ((point5.ACT = NORMAL & point5.occNS in {FREE, ERROROCC}) | (point5.ACT = REVERSE & point5.occRS in {FREE, ERROROCC})) : FREE;

		-- stays FREE if not allocated
		seg18.occDown = FREE & seg18.mode = AVAILABLE : FREE;

