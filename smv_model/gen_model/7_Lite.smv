-------------------------------------------------------------------------------
-- Signal Module --
-- Represents a signal in the track
-- Inputs:- id_in: frozen var, ID of this signal, number in range 0..15
--          CMD_in: command for the aspect of the signal
-------------------------------------------------------------------------------
MODULE Signal(id_in, CMD_in)
FROZENVAR
	id: 0..15;
VAR
	ACT : {STOP, GO};
ASSIGN
	init(id) := id_in;
	init(ACT) := STOP;
	next(ACT) := case
		ACT != CMD_in : CMD_in;
		TRUE : ACT;
	esac;
-------------------------------------------------------------------------------
-------------------------------------------------------------------------------
-- Point Module --
-- Represents a point and its track section/segment.
--      Track related variables are like in LinearSection mostly might
--      want to change this similar to Vu et al, to use 3 variables for
--      occupancy instead of 2 (require lots of other changes though).
-- Inputs:- id_in: frozen var, ID of this point, number in range 0..29
--          segID_in: frozen var, ID of the segment of the point,
--                        number in range 0..29
--          CMD_in: command for the aspect/position of the point,
--                        enum values "NORMAL" and "REVERSE"
-------------------------------------------------------------------------------
MODULE Point(id_in, segID_in, CMD_in)
FROZENVAR
	id : 0..29;
	segID : 0..29;
VAR
	occSNR : {FREE, HEADOCC, COMPLETETRAINOCC, TAILOCC, ERROROCC};
	occNS : {FREE, HEADOCC, COMPLETETRAINOCC, TAILOCC, ERROROCC};
	occRS : {FREE, HEADOCC, COMPLETETRAINOCC, TAILOCC, ERROROCC};
	ACT : {NORMAL, INTERMEDIATE, REVERSE};
	mode : {AVAILABLE, EXLOCKED, USED};
	prev : {PENDING, RELEASED};
ASSIGN
	init(id) := id_in;
	init(segID) := segID_in;
	init(ACT) := NORMAL;
	init(mode) := AVAILABLE;
	init(prev) := PENDING;

	next(ACT) := case
		ACT != CMD_in & ACT != INTERMEDIATE : INTERMEDIATE;
		-- if in INTERMEDIATE, change to CMD_in next
		ACT = INTERMEDIATE : CMD_in;
		TRUE : ACT;
	esac;
-------------------------------------------------------------------------------
-------------------------------------------------------------------------------
-- Linear Section Module --
-- Represents a section/segment in the track
-- Inputs:- id_in: track segment identifier
-------------------------------------------------------------------------------
MODULE Linear(id_in)
FROZENVAR
	id : 0..29;
VAR
	occDown : {FREE, HEADOCC, COMPLETETRAINOCC, TAILOCC, ERROROCC};
	occUp : {FREE, HEADOCC, COMPLETETRAINOCC, TAILOCC, ERROROCC};
	mode : {AVAILABLE, EXLOCKED, USED};
	prev : {PENDING, RELEASED};
ASSIGN
	init(id) := id_in;
	init(mode) := AVAILABLE;
	init(prev) := PENDING;
-------------------------------------------------------------------------------
-------------------------------------------------------------------------------
-- Route Module --
-- Represents a route in the interlocked layout
-- Inputs:- id_in: route identifier
-------------------------------------------------------------------------------
MODULE Route(id_in)
FROZENVAR
	id : 0..74;
VAR
	mode : {FREE, MARKED, ALLOCATING, LOCKED, OCCUPIED};
	transition : {CAN_DISPATCH, CAN_ALLOCATE, CAN_LOCK, CAN_OCCUPY};
ASSIGN
	init(id) := id_in;
	init(mode) := FREE;
	init(transition) := CAN_DISPATCH;
-------------------------------------------------------------------------------


-------------------------------------------------------------------------------
-- Track Section Module --
-- This bundles all segments/sections, points, train movement etc.
-------------------------------------------------------------------------------
MODULE TrackSection -- Segments/sections + point switching + signal comm
VAR
	r0 : Route(0);
	r1 : Route(1);
	r2 : Route(2);
	r3 : Route(3);
	r4 : Route(4);
	r5 : Route(5);
	r6 : Route(6);
	r7 : Route(7);
	r8 : Route(8);
	r9 : Route(9);
	r10 : Route(10);
	r11 : Route(11);
	r12 : Route(12);
	r13 : Route(13);
	r14 : Route(14);
	r15 : Route(15);

	seg5 : Linear(5);
	seg6 : Linear(6);
	seg7 : Linear(7);
	seg11 : Linear(11);
	seg10 : Linear(10);
	seg9 : Linear(9);
	seg3 : Linear(3);
	seg2 : Linear(2);
	seg1 : Linear(1);
	seg16 : Linear(16);
	seg15 : Linear(15);
	seg14 : Linear(14);
	seg18 : Linear(18);
	seg19 : Linear(19);
	seg20 : Linear(20);

	point1CMD : {NORMAL, REVERSE};
	point1 : Point(1, 4, point1CMD);

	point5CMD : {NORMAL, REVERSE};
	point5 : Point(5, 17, point5CMD);

	point2CMD : {NORMAL, REVERSE};
	point2 : Point(2, 8, point2CMD);

	point3CMD : {NORMAL, REVERSE};
	point3 : Point(3, 12, point3CMD);

	point6CMD : {NORMAL, REVERSE};
	point6 : Point(6, 21, point6CMD);

	point4CMD : {NORMAL, REVERSE};
	point4 : Point(4, 13, point4CMD);

	point7CMD : {NORMAL, REVERSE};
	point7 : Point(7, 22, point7CMD);


	signal8CMD : {GO, STOP};
	signal8 : Signal(8, signal8CMD);

	signal4CMD : {GO, STOP};
	signal4 : Signal(4, signal4CMD);

	signal9CMD : {GO, STOP};
	signal9 : Signal(9, signal9CMD);

	signal3CMD : {GO, STOP};
	signal3 : Signal(3, signal3CMD);

	signal1CMD : {GO, STOP};
	signal1 : Signal(1, signal1CMD);

	signal5CMD : {GO, STOP};
	signal5 : Signal(5, signal5CMD);

	signal2CMD : {GO, STOP};
	signal2 : Signal(2, signal2CMD);

	signal7CMD : {GO, STOP};
	signal7 : Signal(7, signal7CMD);

	signal10CMD : {GO, STOP};
	signal10 : Signal(10, signal10CMD);

	signal6CMD : {GO, STOP};
	signal6 : Signal(6, signal6CMD);

	signal11CMD : {GO, STOP};
	signal11 : Signal(11, signal11CMD);

	signal14CMD : {GO, STOP};
	signal14 : Signal(14, signal14CMD);


ASSIGN
	-- SEGMENTS OCCUPANCY INITIAL --
	init(seg5.occDown) := FREE;
	init(seg5.occUp) := FREE;
	init(seg6.occDown) := FREE;
	init(seg6.occUp) := FREE;
	init(seg7.occDown) := FREE;
	init(seg7.occUp) := FREE;
	init(seg11.occDown) := FREE;
	init(seg11.occUp) := FREE;
	init(seg10.occDown) := FREE;
	init(seg10.occUp) := FREE;
	init(seg9.occDown) := FREE;
	init(seg9.occUp) := FREE;
	init(seg3.occDown) := FREE;
	init(seg3.occUp) := COMPLETETRAINOCC;
	init(seg2.occDown) := FREE;
	init(seg2.occUp) := FREE;
	init(seg1.occDown) := FREE;
	init(seg1.occUp) := FREE;
	init(seg16.occDown) := FREE;
	init(seg16.occUp) := FREE;
	init(seg15.occDown) := FREE;
	init(seg15.occUp) := FREE;
	init(seg14.occDown) := FREE;
	init(seg14.occUp) := FREE;
	init(seg18.occDown) := COMPLETETRAINOCC;
	init(seg18.occUp) := FREE;
	init(seg19.occDown) := FREE;
	init(seg19.occUp) := FREE;
	init(seg20.occDown) := FREE;
	init(seg20.occUp) := FREE;

	-- SEGMENTS OCCUPANCY INITIAL --
	init(point1.occSNR) := FREE;
	init(point1.occNS) := FREE;
	init(point1.occRS) := FREE;
	init(point1CMD) := NORMAL;
	init(point5.occSNR) := FREE;
	init(point5.occNS) := FREE;
	init(point5.occRS) := FREE;
	init(point5CMD) := NORMAL;
	init(point2.occSNR) := FREE;
	init(point2.occNS) := FREE;
	init(point2.occRS) := FREE;
	init(point2CMD) := NORMAL;
	init(point3.occSNR) := FREE;
	init(point3.occNS) := FREE;
	init(point3.occRS) := FREE;
	init(point3CMD) := NORMAL;
	init(point6.occSNR) := FREE;
	init(point6.occNS) := FREE;
	init(point6.occRS) := FREE;
	init(point6CMD) := NORMAL;
	init(point4.occSNR) := FREE;
	init(point4.occNS) := FREE;
	init(point4.occRS) := FREE;
	init(point4CMD) := NORMAL;
	init(point7.occSNR) := FREE;
	init(point7.occNS) := FREE;
	init(point7.occRS) := FREE;
	init(point7CMD) := NORMAL;

	-- SIGNALS CMD INITIAL --
	init(signal8CMD) := STOP;
	init(signal4CMD) := STOP;
	init(signal9CMD) := STOP;
	init(signal3CMD) := STOP;
	init(signal1CMD) := STOP;
	init(signal5CMD) := STOP;
	init(signal2CMD) := STOP;
	init(signal7CMD) := STOP;
	init(signal10CMD) := STOP;
	init(signal6CMD) := STOP;
	init(signal11CMD) := STOP;
	init(signal14CMD) := STOP;

	-- NEXTS --
	-- SIGNALS CMD NEXT --
	next(signal8CMD) := case
		(
			r0.mode = LOCKED
			| r5.mode = LOCKED
		)
		: GO;

		(
			r0.mode = OCCUPIED
			| r5.mode = OCCUPIED
		)
		: STOP;

		TRUE : signal8CMD;
	esac;

	next(signal4CMD) := case
		(
			r1.mode = LOCKED
			| r7.mode = LOCKED
			| r8.mode = LOCKED
			| r9.mode = LOCKED
		)
		: GO;

		(
			r1.mode = OCCUPIED
			| r7.mode = OCCUPIED
			| r8.mode = OCCUPIED
			| r9.mode = OCCUPIED
		)
		: STOP;

		TRUE : signal4CMD;
	esac;

	next(signal9CMD) := case
		(
			r1.mode = LOCKED
			| r7.mode = LOCKED
		)
		: GO;

		(
			r1.mode = OCCUPIED
			| r7.mode = OCCUPIED
		)
		: STOP;

		TRUE : signal9CMD;
	esac;

	next(signal3CMD) := case
		(
			r0.mode = LOCKED
			| r3.mode = LOCKED
			| r4.mode = LOCKED
			| r5.mode = LOCKED
		)
		: GO;

		(
			r0.mode = OCCUPIED
			| r3.mode = OCCUPIED
			| r4.mode = OCCUPIED
			| r5.mode = OCCUPIED
		)
		: STOP;

		TRUE : signal3CMD;
	esac;

	next(signal1CMD) := case
		(
			r2.mode = LOCKED
			| r11.mode = LOCKED
		)
		: GO;

		(
			r2.mode = OCCUPIED
			| r11.mode = OCCUPIED
		)
		: STOP;

		TRUE : signal1CMD;
	esac;

	next(signal5CMD) := case
		(
			r8.mode = LOCKED
			| r9.mode = LOCKED
		)
		: GO;

		(
			r8.mode = OCCUPIED
			| r9.mode = OCCUPIED
		)
		: STOP;

		TRUE : signal5CMD;
	esac;

	next(signal2CMD) := case
		(
			r3.mode = LOCKED
			| r4.mode = LOCKED
		)
		: GO;

		(
			r3.mode = OCCUPIED
			| r4.mode = OCCUPIED
		)
		: STOP;

		TRUE : signal2CMD;
	esac;

	next(signal7CMD) := case
		(
			r6.mode = LOCKED
			| r10.mode = LOCKED
			| r12.mode = LOCKED
			| r13.mode = LOCKED
		)
		: GO;

		(
			r6.mode = OCCUPIED
			| r10.mode = OCCUPIED
			| r12.mode = OCCUPIED
			| r13.mode = OCCUPIED
		)
		: STOP;

		TRUE : signal7CMD;
	esac;

	next(signal10CMD) := case
		(
			r6.mode = LOCKED
			| r12.mode = LOCKED
			| r14.mode = LOCKED
			| r15.mode = LOCKED
		)
		: GO;

		(
			r6.mode = OCCUPIED
			| r12.mode = OCCUPIED
			| r14.mode = OCCUPIED
			| r15.mode = OCCUPIED
		)
		: STOP;

		TRUE : signal10CMD;
	esac;

	next(signal6CMD) := case
		(
			r2.mode = LOCKED
			| r10.mode = LOCKED
			| r11.mode = LOCKED
			| r13.mode = LOCKED
		)
		: GO;

		(
			r2.mode = OCCUPIED
			| r10.mode = OCCUPIED
			| r11.mode = OCCUPIED
			| r13.mode = OCCUPIED
		)
		: STOP;

		TRUE : signal6CMD;
	esac;

	next(signal11CMD) := case
		r14.mode = LOCKED: GO;
		r14.mode = OCCUPIED: STOP;
		TRUE : signal11CMD;
	esac;

	next(signal14CMD) := case
		r15.mode = LOCKED: GO;
		r15.mode = OCCUPIED: STOP;
		TRUE : signal14CMD;
	esac;


	-- POINTS CMD NEXT --
	next(point1CMD) := case
		r0.mode in {ALLOCATING, LOCKED, OCCUPIED} | r5.mode in {ALLOCATING, LOCKED, OCCUPIED} : REVERSE;
		TRUE : NORMAL;
	esac;

	next(point5CMD) := case
		r1.mode in {ALLOCATING, LOCKED, OCCUPIED} | r7.mode in {ALLOCATING, LOCKED, OCCUPIED} : REVERSE;
		TRUE : NORMAL;
	esac;

	next(point2CMD) := case
		r1.mode in {ALLOCATING, LOCKED, OCCUPIED} | r7.mode in {ALLOCATING, LOCKED, OCCUPIED} : REVERSE;
		TRUE : NORMAL;
	esac;

	next(point3CMD) := case
		r10.mode in {ALLOCATING, LOCKED, OCCUPIED} | r13.mode in {ALLOCATING, LOCKED, OCCUPIED} : REVERSE;
		TRUE : NORMAL;
	esac;

	next(point6CMD) := case
		r14.mode in {ALLOCATING, LOCKED, OCCUPIED} : REVERSE;
		TRUE : NORMAL;
	esac;

	next(point4CMD) := case
		r10.mode in {ALLOCATING, LOCKED, OCCUPIED} | r13.mode in {ALLOCATING, LOCKED, OCCUPIED} : REVERSE;
		TRUE : NORMAL;
	esac;

	next(point7CMD) := case
		r14.mode in {ALLOCATING, LOCKED, OCCUPIED} : REVERSE;
		TRUE : NORMAL;
	esac;


	-- SEGMENTS/SECTIONS MODE NEXT --
	next(seg5.mode) := case
		seg5.mode = AVAILABLE
		& (r0.mode = ALLOCATING | r1.mode = ALLOCATING | r3.mode = ALLOCATING | r9.mode = ALLOCATING)
		: EXLOCKED;

		seg5.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r0.mode = OCCUPIED
			& point1.mode = USED
			& seg6.mode = EXLOCKED
			& seg5.occDown = FREE & seg5.occUp = FREE
		)
		| (
			r1.mode = OCCUPIED
			& seg6.mode = USED
			& seg5.occDown in {HEADOCC, COMPLETETRAINOCC}
		)
		| (
			r3.mode = OCCUPIED
			& point1.mode = USED
			& seg6.mode = EXLOCKED
			& seg5.occDown = FREE & seg5.occUp = FREE
		)
		| (
			r9.mode = OCCUPIED
			& seg6.mode = USED
			& seg5.occDown in {HEADOCC, COMPLETETRAINOCC}
		)
		)
		: USED;

		seg5.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r0.mode = OCCUPIED
			& (seg6.mode = USED | seg6.prev = PENDING)
		)
		| (
			r1.mode = OCCUPIED
		)
		| (
			r3.mode = OCCUPIED
			& (seg6.mode = USED | seg6.prev = PENDING)
		)
		| (
			r9.mode = OCCUPIED
		)
		)
		& (seg5.occDown = FREE & seg5.occUp = FREE)
		& seg5.prev = RELEASED
		: AVAILABLE;

		TRUE : seg5.mode;
	esac;

	next(seg6.mode) := case
		seg6.mode = AVAILABLE
		& (r0.mode = ALLOCATING | r1.mode = ALLOCATING | r3.mode = ALLOCATING | r9.mode = ALLOCATING)
		: EXLOCKED;

		seg6.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r0.mode = OCCUPIED
			& seg5.mode = USED
			& seg7.mode = EXLOCKED
			& seg6.occDown = FREE & seg6.occUp = FREE
		)
		| (
			r1.mode = OCCUPIED
			& seg7.mode = USED
			& seg5.mode = EXLOCKED
			& seg6.occDown = FREE & seg6.occUp = FREE
		)
		| (
			r3.mode = OCCUPIED
			& seg5.mode = USED
			& seg7.mode = EXLOCKED
			& seg6.occDown = FREE & seg6.occUp = FREE
		)
		| (
			r9.mode = OCCUPIED
			& seg7.mode = USED
			& seg5.mode = EXLOCKED
			& seg6.occDown = FREE & seg6.occUp = FREE
		)
		)
		: USED;

		seg6.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r0.mode = OCCUPIED
			& (seg7.mode = USED | seg7.prev = PENDING)
		)
		| (
			r1.mode = OCCUPIED
			& (seg5.mode = USED | seg5.prev = PENDING)
		)
		| (
			r3.mode = OCCUPIED
			& (seg7.mode = USED | seg7.prev = PENDING)
		)
		| (
			r9.mode = OCCUPIED
			& (seg5.mode = USED | seg5.prev = PENDING)
		)
		)
		& (seg6.occDown = FREE & seg6.occUp = FREE)
		& seg6.prev = RELEASED
		: AVAILABLE;

		TRUE : seg6.mode;
	esac;

	next(seg7.mode) := case
		seg7.mode = AVAILABLE
		& (r0.mode = ALLOCATING | r1.mode = ALLOCATING | r3.mode = ALLOCATING | r9.mode = ALLOCATING)
		: EXLOCKED;

		seg7.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r0.mode = OCCUPIED
			& seg6.mode = USED
			& seg7.occUp in {HEADOCC, COMPLETETRAINOCC}
		)
		| (
			r1.mode = OCCUPIED
			& point2.mode = USED
			& seg6.mode = EXLOCKED
			& seg7.occDown = FREE & seg7.occUp = FREE
		)
		| (
			r3.mode = OCCUPIED
			& seg6.mode = USED
			& seg7.occUp in {HEADOCC, COMPLETETRAINOCC}
		)
		| (
			r9.mode = OCCUPIED
			& point2.mode = USED
			& seg6.mode = EXLOCKED
			& seg7.occDown = FREE & seg7.occUp = FREE
		)
		)
		: USED;

		seg7.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r0.mode = OCCUPIED
		)
		| (
			r1.mode = OCCUPIED
			& (seg6.mode = USED | seg6.prev = PENDING)
		)
		| (
			r3.mode = OCCUPIED
		)
		| (
			r9.mode = OCCUPIED
			& (seg6.mode = USED | seg6.prev = PENDING)
		)
		)
		& (seg7.occDown = FREE & seg7.occUp = FREE)
		& seg7.prev = RELEASED
		: AVAILABLE;

		TRUE : seg7.mode;
	esac;

	next(seg11.mode) := case
		seg11.mode = AVAILABLE
		& (r2.mode = ALLOCATING | r8.mode = ALLOCATING | r13.mode = ALLOCATING)
		: EXLOCKED;

		seg11.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r2.mode = OCCUPIED
			& point3.mode = USED
			& seg10.mode = EXLOCKED
			& seg11.occDown = FREE & seg11.occUp = FREE
		)
		| (
			r8.mode = OCCUPIED
			& seg10.mode = USED
			& seg11.occUp in {HEADOCC, COMPLETETRAINOCC}
		)
		| (
			r13.mode = OCCUPIED
			& point3.mode = USED
			& seg10.mode = EXLOCKED
			& seg11.occDown = FREE & seg11.occUp = FREE
		)
		)
		: USED;

		seg11.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r2.mode = OCCUPIED
			& (seg10.mode = USED | seg10.prev = PENDING)
		)
		| (
			r8.mode = OCCUPIED
		)
		| (
			r13.mode = OCCUPIED
			& (seg10.mode = USED | seg10.prev = PENDING)
		)
		)
		& (seg11.occDown = FREE & seg11.occUp = FREE)
		& seg11.prev = RELEASED
		: AVAILABLE;

		TRUE : seg11.mode;
	esac;

	next(seg10.mode) := case
		seg10.mode = AVAILABLE
		& (r2.mode = ALLOCATING | r8.mode = ALLOCATING | r13.mode = ALLOCATING)
		: EXLOCKED;

		seg10.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r2.mode = OCCUPIED
			& seg11.mode = USED
			& seg9.mode = EXLOCKED
			& seg10.occDown = FREE & seg10.occUp = FREE
		)
		| (
			r8.mode = OCCUPIED
			& seg9.mode = USED
			& seg11.mode = EXLOCKED
			& seg10.occDown = FREE & seg10.occUp = FREE
		)
		| (
			r13.mode = OCCUPIED
			& seg11.mode = USED
			& seg9.mode = EXLOCKED
			& seg10.occDown = FREE & seg10.occUp = FREE
		)
		)
		: USED;

		seg10.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r2.mode = OCCUPIED
			& (seg9.mode = USED | seg9.prev = PENDING)
		)
		| (
			r8.mode = OCCUPIED
			& (seg11.mode = USED | seg11.prev = PENDING)
		)
		| (
			r13.mode = OCCUPIED
			& (seg9.mode = USED | seg9.prev = PENDING)
		)
		)
		& (seg10.occDown = FREE & seg10.occUp = FREE)
		& seg10.prev = RELEASED
