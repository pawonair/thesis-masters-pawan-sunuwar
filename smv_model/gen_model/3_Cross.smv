		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train and signal is GO
		point2.occSNR = FREE & point2.mode != AVAILABLE & point2.ACT != INTERMEDIATE
		& seg7.occUp = COMPLETETRAINOCC & signal4.ACT = GO
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		-- and signal is GO
		point2.occSNR = FREE & point2.mode != AVAILABLE & point2.ACT != INTERMEDIATE
		& seg7.occUp = TAILOCC & signal4.ACT = GO
		: ERROROCC;

		-- ERROROCC if train present and aspect is INTERMEDIATE
		point2.occSNR != FREE & point2.ACT = INTERMEDIATE : ERROROCC;

		-- train head leaves or train collects here if head present
		point2.occSNR = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		point2.occSNR = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		point2.occSNR = TAILOCC : FREE;

		TRUE : point2.occSNR;
	esac;

	next(point2.occNS) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		point2.occNS = FREE & seg9.occDown in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		point2.occNS = FREE & point2.mode = AVAILABLE : FREE;

		-- train blocked at signal STOP regardless of predecessor state
		point2.occNS = FREE & point2.mode != AVAILABLE & point2.ACT = NORMAL
		& seg9.occDown in {HEADOCC, COMPLETETRAINOCC} & signal5.ACT = STOP
		: FREE;

		-- non-deterministic head entry if previous segment has head and signal is GO
		point2.occNS = FREE & point2.mode != AVAILABLE & point2.ACT = NORMAL
		& seg9.occDown = HEADOCC & signal5.ACT = GO
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train and signal is GO
		point2.occNS = FREE & point2.mode != AVAILABLE & point2.ACT = NORMAL
		& seg9.occDown = COMPLETETRAINOCC & signal5.ACT = GO
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		-- and signal is GO
		point2.occNS = FREE & point2.mode != AVAILABLE & point2.ACT = NORMAL
		& seg9.occDown = TAILOCC & signal5.ACT = GO
		: ERROROCC;

		-- ERROROCC if train present and aspect is INTERMEDIATE
		point2.occNS != FREE & point2.ACT = INTERMEDIATE : ERROROCC;

		-- train head leaves or train collects here if head present
		point2.occNS = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		point2.occNS = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		point2.occNS = TAILOCC : FREE;

		TRUE : point2.occNS;
	esac;

	next(point2.occRS) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		point2.occRS = FREE & point5.occRS in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		point2.occRS = FREE & point2.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		point2.occRS = FREE & point2.mode != AVAILABLE & point2.ACT = REVERSE
		& point5.occRS = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		point2.occRS = FREE & point2.mode != AVAILABLE & point2.ACT = REVERSE
		& point5.occRS = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		point2.occRS = FREE & point2.mode != AVAILABLE & point2.ACT = REVERSE
		& point5.occRS = TAILOCC
		: ERROROCC;

		-- ERROROCC if train present and aspect is INTERMEDIATE
		point2.occRS != FREE & point2.ACT = INTERMEDIATE : ERROROCC;

		-- train head leaves or train collects here if head present
		point2.occRS = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		point2.occRS = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		point2.occRS = TAILOCC : FREE;

		TRUE : point2.occRS;
	esac;

	-- point5
	next(point5.occSNR) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		point5.occSNR = FREE & seg18.occDown in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		point5.occSNR = FREE & point5.mode = AVAILABLE : FREE;

		-- train blocked at signal STOP regardless of predecessor state
		point5.occSNR = FREE & point5.mode != AVAILABLE & point5.ACT != INTERMEDIATE
		& seg18.occDown in {HEADOCC, COMPLETETRAINOCC} & signal9.ACT = STOP
		: FREE;

		-- non-deterministic head entry if previous segment has head and signal is GO
		point5.occSNR = FREE & point5.mode != AVAILABLE & point5.ACT != INTERMEDIATE
		& seg18.occDown = HEADOCC & signal9.ACT = GO
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train and signal is GO
		point5.occSNR = FREE & point5.mode != AVAILABLE & point5.ACT != INTERMEDIATE
		& seg18.occDown = COMPLETETRAINOCC & signal9.ACT = GO
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		-- and signal is GO
		point5.occSNR = FREE & point5.mode != AVAILABLE & point5.ACT != INTERMEDIATE
		& seg18.occDown = TAILOCC & signal9.ACT = GO
		: ERROROCC;

		-- ERROROCC if train present and aspect is INTERMEDIATE
		point5.occSNR != FREE & point5.ACT = INTERMEDIATE : ERROROCC;

		-- train head leaves or train collects here if head present
		point5.occSNR = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		point5.occSNR = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		point5.occSNR = TAILOCC : FREE;

		TRUE : point5.occSNR;
	esac;

	next(point5.occNS) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		point5.occNS = FREE & seg27.occUp in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		point5.occNS = FREE & point5.mode = AVAILABLE : FREE;

		-- train blocked at signal STOP regardless of predecessor state
		point5.occNS = FREE & point5.mode != AVAILABLE & point5.ACT = NORMAL
		& seg27.occUp in {HEADOCC, COMPLETETRAINOCC} & signal14.ACT = STOP
		: FREE;

		-- non-deterministic head entry if previous segment has head and signal is GO
		point5.occNS = FREE & point5.mode != AVAILABLE & point5.ACT = NORMAL
		& seg27.occUp = HEADOCC & signal14.ACT = GO
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train and signal is GO
		point5.occNS = FREE & point5.mode != AVAILABLE & point5.ACT = NORMAL
		& seg27.occUp = COMPLETETRAINOCC & signal14.ACT = GO
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		-- and signal is GO
		point5.occNS = FREE & point5.mode != AVAILABLE & point5.ACT = NORMAL
		& seg27.occUp = TAILOCC & signal14.ACT = GO
		: ERROROCC;

		-- ERROROCC if train present and aspect is INTERMEDIATE
		point5.occNS != FREE & point5.ACT = INTERMEDIATE : ERROROCC;

		-- train head leaves or train collects here if head present
		point5.occNS = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		point5.occNS = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		point5.occNS = TAILOCC : FREE;

		TRUE : point5.occNS;
	esac;

	next(point5.occRS) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		point5.occRS = FREE & point2.occRS in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		point5.occRS = FREE & point5.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		point5.occRS = FREE & point5.mode != AVAILABLE & point5.ACT = REVERSE
		& point2.occRS = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		point5.occRS = FREE & point5.mode != AVAILABLE & point5.ACT = REVERSE
		& point2.occRS = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		point5.occRS = FREE & point5.mode != AVAILABLE & point5.ACT = REVERSE
		& point2.occRS = TAILOCC
		: ERROROCC;

		-- ERROROCC if train present and aspect is INTERMEDIATE
		point5.occRS != FREE & point5.ACT = INTERMEDIATE : ERROROCC;

		-- train head leaves or train collects here if head present
		point5.occRS = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		point5.occRS = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		point5.occRS = TAILOCC : FREE;

		TRUE : point5.occRS;
	esac;


-- Train Movement --
INVAR
	(seg18.occUp = HEADOCC -> (seg19.occUp != HEADOCC))
	& (seg18.occUp = COMPLETETRAINOCC -> (seg19.occUp != HEADOCC))
	& (seg18.occUp = TAILOCC -> (seg19.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg18.occDown = HEADOCC -> (seg19.occDown in {TAILOCC, ERROROCC} & point5.occSNR != HEADOCC))
	& (seg18.occDown = COMPLETETRAINOCC -> (seg19.occDown != TAILOCC & point5.occSNR != HEADOCC))
	& (seg18.occDown = TAILOCC -> (seg19.occDown != TAILOCC & point5.occSNR in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg19.occUp = HEADOCC -> (seg18.occUp in {TAILOCC, ERROROCC} & seg20.occUp != HEADOCC))
	& (seg19.occUp = COMPLETETRAINOCC -> (seg18.occUp != TAILOCC & seg20.occUp != HEADOCC))
	& (seg19.occUp = TAILOCC -> (seg18.occUp != TAILOCC & seg20.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg19.occDown = HEADOCC -> (seg20.occDown in {TAILOCC, ERROROCC} & seg18.occDown != HEADOCC))
	& (seg19.occDown = COMPLETETRAINOCC -> (seg20.occDown != TAILOCC & seg18.occDown != HEADOCC))
	& (seg19.occDown = TAILOCC -> (seg20.occDown != TAILOCC & seg18.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg20.occUp = HEADOCC -> (seg19.occUp in {TAILOCC, ERROROCC}))
	& (seg20.occUp = COMPLETETRAINOCC -> (seg19.occUp != TAILOCC))
	& (seg20.occUp = TAILOCC -> (seg19.occUp != TAILOCC))
	& (seg20.occDown = HEADOCC -> (seg19.occDown != HEADOCC))
	& (seg20.occDown = COMPLETETRAINOCC -> (seg19.occDown != HEADOCC))
	& (seg20.occDown = TAILOCC -> (seg19.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg9.occUp = HEADOCC -> (point2.occNS in {TAILOCC, ERROROCC} & seg10.occUp != HEADOCC))
	& (seg9.occUp = COMPLETETRAINOCC -> (point2.occNS != TAILOCC & seg10.occUp != HEADOCC))
	& (seg9.occUp = TAILOCC -> (point2.occNS != TAILOCC & seg10.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg9.occDown = HEADOCC -> (seg10.occDown in {TAILOCC, ERROROCC} & point2.occSNR != HEADOCC))
	& (seg9.occDown = COMPLETETRAINOCC -> (seg10.occDown != TAILOCC & point2.occSNR != HEADOCC))
	& (seg9.occDown = TAILOCC -> (seg10.occDown != TAILOCC & point2.occSNR in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg10.occUp = HEADOCC -> (seg9.occUp in {TAILOCC, ERROROCC} & seg11.occUp != HEADOCC))
	& (seg10.occUp = COMPLETETRAINOCC -> (seg9.occUp != TAILOCC & seg11.occUp != HEADOCC))
	& (seg10.occUp = TAILOCC -> (seg9.occUp != TAILOCC & seg11.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg10.occDown = HEADOCC -> (seg11.occDown in {TAILOCC, ERROROCC} & seg9.occDown != HEADOCC))
	& (seg10.occDown = COMPLETETRAINOCC -> (seg11.occDown != TAILOCC & seg9.occDown != HEADOCC))
	& (seg10.occDown = TAILOCC -> (seg11.occDown != TAILOCC & seg9.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg11.occUp = HEADOCC -> (seg10.occUp in {TAILOCC, ERROROCC}))
	& (seg11.occUp = COMPLETETRAINOCC -> (seg10.occUp != TAILOCC))
	& (seg11.occUp = TAILOCC -> (seg10.occUp != TAILOCC))
	& (seg11.occDown = HEADOCC -> (seg10.occDown != HEADOCC))
	& (seg11.occDown = COMPLETETRAINOCC -> (seg10.occDown != HEADOCC))
	& (seg11.occDown = TAILOCC -> (seg10.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg7.occUp = HEADOCC -> (seg6.occUp in {TAILOCC, ERROROCC}))
	& (seg7.occUp = COMPLETETRAINOCC -> (seg6.occUp != TAILOCC))
	& (seg7.occUp = TAILOCC -> (seg6.occUp != TAILOCC))
	& (seg7.occDown = HEADOCC -> (point2.occSNR in {TAILOCC, ERROROCC} & seg6.occDown != HEADOCC))
	& (seg7.occDown = COMPLETETRAINOCC -> (point2.occSNR != TAILOCC & seg6.occDown != HEADOCC))
	& (seg7.occDown = TAILOCC -> (point2.occSNR != TAILOCC & seg6.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg6.occUp = HEADOCC -> (seg5.occUp in {TAILOCC, ERROROCC} & seg7.occUp != HEADOCC))
	& (seg6.occUp = COMPLETETRAINOCC -> (seg5.occUp != TAILOCC & seg7.occUp != HEADOCC))
	& (seg6.occUp = TAILOCC -> (seg5.occUp != TAILOCC & seg7.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg6.occDown = HEADOCC -> (seg7.occDown in {TAILOCC, ERROROCC} & seg5.occDown != HEADOCC))
	& (seg6.occDown = COMPLETETRAINOCC -> (seg7.occDown != TAILOCC & seg5.occDown != HEADOCC))
	& (seg6.occDown = TAILOCC -> (seg7.occDown != TAILOCC & seg5.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg5.occUp = HEADOCC -> (seg6.occUp != HEADOCC))
	& (seg5.occUp = COMPLETETRAINOCC -> (seg6.occUp != HEADOCC))
	& (seg5.occUp = TAILOCC -> (seg6.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg5.occDown = HEADOCC -> (seg6.occDown in {TAILOCC, ERROROCC}))
	& (seg5.occDown = COMPLETETRAINOCC -> (seg6.occDown != TAILOCC))
	& (seg5.occDown = TAILOCC -> (seg6.occDown != TAILOCC))
	& (seg27.occUp = HEADOCC -> (seg28.occUp in {TAILOCC, ERROROCC} & point5.occNS != HEADOCC))
	& (seg27.occUp = COMPLETETRAINOCC -> (seg28.occUp != TAILOCC & point5.occNS != HEADOCC))
	& (seg27.occUp = TAILOCC -> (seg28.occUp != TAILOCC & point5.occNS in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg27.occDown = HEADOCC -> (point5.occSNR in {TAILOCC, ERROROCC} & seg28.occDown != HEADOCC))
	& (seg27.occDown = COMPLETETRAINOCC -> (point5.occSNR != TAILOCC & seg28.occDown != HEADOCC))
	& (seg27.occDown = TAILOCC -> (point5.occSNR != TAILOCC & seg28.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg28.occUp = HEADOCC -> (seg29.occUp in {TAILOCC, ERROROCC} & seg27.occUp != HEADOCC))
	& (seg28.occUp = COMPLETETRAINOCC -> (seg29.occUp != TAILOCC & seg27.occUp != HEADOCC))
	& (seg28.occUp = TAILOCC -> (seg29.occUp != TAILOCC & seg27.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg28.occDown = HEADOCC -> (seg27.occDown in {TAILOCC, ERROROCC} & seg29.occDown != HEADOCC))
	& (seg28.occDown = COMPLETETRAINOCC -> (seg27.occDown != TAILOCC & seg29.occDown != HEADOCC))
	& (seg28.occDown = TAILOCC -> (seg27.occDown != TAILOCC & seg29.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg29.occUp = HEADOCC -> (seg28.occUp != HEADOCC))
	& (seg29.occUp = COMPLETETRAINOCC -> (seg28.occUp != HEADOCC))
	& (seg29.occUp = TAILOCC -> (seg28.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (seg29.occDown = HEADOCC -> (seg28.occDown in {TAILOCC, ERROROCC}))
	& (seg29.occDown = COMPLETETRAINOCC -> (seg28.occDown != TAILOCC))
	& (seg29.occDown = TAILOCC -> (seg28.occDown != TAILOCC))
	& (point2.occSNR = HEADOCC -> (seg7.occDown in {TAILOCC, ERROROCC} & seg9.occDown != HEADOCC & point5.occSNR != HEADOCC))
	& (point2.occSNR = COMPLETETRAINOCC -> (seg7.occDown != TAILOCC & seg9.occDown != HEADOCC & point5.occSNR != HEADOCC))
	& (point2.occSNR = TAILOCC -> (seg7.occDown != TAILOCC & (seg9.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC} | point5.occSNR in {HEADOCC, COMPLETETRAINOCC, ERROROCC})))
	& (point2.occNS = HEADOCC -> (seg9.occUp in {TAILOCC, ERROROCC} & seg7.occUp != HEADOCC))
	& (point2.occNS = COMPLETETRAINOCC -> (seg9.occUp != TAILOCC & seg7.occUp != HEADOCC))
	& (point2.occNS = TAILOCC -> (seg9.occUp != TAILOCC & seg7.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (point2.occRS = HEADOCC -> (point5.occRS in {TAILOCC, ERROROCC} & seg7.occUp != HEADOCC))
	& (point2.occRS = COMPLETETRAINOCC -> (point5.occRS != TAILOCC & seg7.occUp != HEADOCC))
	& (point2.occRS = TAILOCC -> (point5.occRS != TAILOCC & seg7.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (point5.occSNR = HEADOCC -> (seg18.occDown in {TAILOCC, ERROROCC} & seg27.occDown != HEADOCC & point2.occSNR != HEADOCC))
	& (point5.occSNR = COMPLETETRAINOCC -> (seg18.occDown != TAILOCC & seg27.occDown != HEADOCC & point2.occSNR != HEADOCC))
	& (point5.occSNR = TAILOCC -> (seg18.occDown != TAILOCC & (seg27.occDown in {HEADOCC, COMPLETETRAINOCC, ERROROCC} | point2.occSNR in {HEADOCC, COMPLETETRAINOCC, ERROROCC})))
	& (point5.occNS = HEADOCC -> (seg27.occUp in {TAILOCC, ERROROCC} & seg18.occUp != HEADOCC))
	& (point5.occNS = COMPLETETRAINOCC -> (seg27.occUp != TAILOCC & seg18.occUp != HEADOCC))
	& (point5.occNS = TAILOCC -> (seg27.occUp != TAILOCC & seg18.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))
	& (point5.occRS = HEADOCC -> (point2.occRS in {TAILOCC, ERROROCC} & seg18.occUp != HEADOCC))
	& (point5.occRS = COMPLETETRAINOCC -> (point2.occRS != TAILOCC & seg18.occUp != HEADOCC))
	& (point5.occRS = TAILOCC -> (point2.occRS != TAILOCC & seg18.occUp in {HEADOCC, COMPLETETRAINOCC, ERROROCC}))

-- Train Occupancy Error --
INVARSPEC
	NAME NoOccUpErrors := !(
		seg18.occUp = ERROROCC
		| seg19.occUp = ERROROCC
		| seg20.occUp = ERROROCC
		| seg9.occUp = ERROROCC
		| seg10.occUp = ERROROCC
		| seg11.occUp = ERROROCC
		| seg7.occUp = ERROROCC
		| seg6.occUp = ERROROCC
		| seg5.occUp = ERROROCC
		| seg27.occUp = ERROROCC
		| seg28.occUp = ERROROCC
		| seg29.occUp = ERROROCC
	);

INVARSPEC
	NAME NoOccDownErrors := !(
		seg18.occDown = ERROROCC
		| seg19.occDown = ERROROCC
		| seg20.occDown = ERROROCC
		| seg9.occDown = ERROROCC
		| seg10.occDown = ERROROCC
		| seg11.occDown = ERROROCC
		| seg7.occDown = ERROROCC
		| seg6.occDown = ERROROCC
		| seg5.occDown = ERROROCC
		| seg27.occDown = ERROROCC
		| seg28.occDown = ERROROCC
		| seg29.occDown = ERROROCC
	);

INVARSPEC
	NAME NoOccPointErrors := !(
		point2.occSNR = ERROROCC
		| point2.occRS = ERROROCC
		| point2.occNS = ERROROCC
		| point5.occSNR = ERROROCC
		| point5.occRS = ERROROCC
		| point5.occNS = ERROROCC
	);


-- Safety Invariants --
INVARSPEC
	NAME NoHeadToHeadSegmentCollisions := (
		(seg18.occDown != FREE -> seg18.occUp = FREE) & (seg18.occUp != FREE -> seg18.occDown = FREE)
		& (seg19.occDown != FREE -> seg19.occUp = FREE) & (seg19.occUp != FREE -> seg19.occDown = FREE)
		& (seg20.occDown != FREE -> seg20.occUp = FREE) & (seg20.occUp != FREE -> seg20.occDown = FREE)
		& (seg9.occDown != FREE -> seg9.occUp = FREE) & (seg9.occUp != FREE -> seg9.occDown = FREE)
		& (seg10.occDown != FREE -> seg10.occUp = FREE) & (seg10.occUp != FREE -> seg10.occDown = FREE)
		& (seg11.occDown != FREE -> seg11.occUp = FREE) & (seg11.occUp != FREE -> seg11.occDown = FREE)
		& (seg7.occDown != FREE -> seg7.occUp = FREE) & (seg7.occUp != FREE -> seg7.occDown = FREE)
		& (seg6.occDown != FREE -> seg6.occUp = FREE) & (seg6.occUp != FREE -> seg6.occDown = FREE)
		& (seg5.occDown != FREE -> seg5.occUp = FREE) & (seg5.occUp != FREE -> seg5.occDown = FREE)
		& (seg27.occDown != FREE -> seg27.occUp = FREE) & (seg27.occUp != FREE -> seg27.occDown = FREE)
		& (seg28.occDown != FREE -> seg28.occUp = FREE) & (seg28.occUp != FREE -> seg28.occDown = FREE)
		& (seg29.occDown != FREE -> seg29.occUp = FREE) & (seg29.occUp != FREE -> seg29.occDown = FREE)
	);

INVARSPEC
	NAME NoHeadToHeadPointCollisions := (
		(point2.occSNR != FREE -> (point2.occNS = FREE & point2.occRS = FREE))
        & (point2.occNS != FREE -> (point2.occSNR = FREE & point2.occRS = FREE))
        & (point2.occRS != FREE -> (point2.occSNR = FREE & point2.occNS = FREE))
		& (point5.occSNR != FREE -> (point5.occNS = FREE & point5.occRS = FREE))
        & (point5.occNS != FREE -> (point5.occSNR = FREE & point5.occRS = FREE))
        & (point5.occRS != FREE -> (point5.occSNR = FREE & point5.occNS = FREE))
	);

INVARSPEC
	NAME NoHeadToTailCollisionsDown := (
		(seg18.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg19.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg19.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg20.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg9.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg10.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg10.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg11.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg7.occDown in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point2.occSNR in {COMPLETETRAINOCC, HEADOCC})
			| point2.ACT = INTERMEDIATE
		)
		& (seg6.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg7.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg5.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg6.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg27.occDown in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point5.occNS in {COMPLETETRAINOCC, HEADOCC})
			| point5.ACT != NORMAL
		)
		& (seg28.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg27.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (seg29.occDown in {TAILOCC, COMPLETETRAINOCC}) -> !(seg28.occDown in {HEADOCC, COMPLETETRAINOCC})
	);
INVARSPEC
	NAME NoHeadToTailCollisionsUp := (
		(seg18.occUp in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point5.occSNR in {COMPLETETRAINOCC, HEADOCC})
			| point5.ACT = INTERMEDIATE
		)
		& (seg19.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg18.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg20.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg19.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg9.occUp in {TAILOCC, COMPLETETRAINOCC}) -> (
			!(point2.occNS in {COMPLETETRAINOCC, HEADOCC})
			| point2.ACT != NORMAL
		)
		& (seg10.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg9.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg11.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg10.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg7.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg6.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg6.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg5.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg27.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg28.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (seg28.occUp in {TAILOCC, COMPLETETRAINOCC}) -> !(seg29.occUp in {HEADOCC, COMPLETETRAINOCC})
	);

INVARSPEC
	NAME NoPointDerailments := (
		(
			(point2.occNS != FREE -> point2.ACT = NORMAL)
            & (point2.occRS != FREE -> point2.ACT = REVERSE)
            & (point2.occSNR != FREE -> point2.ACT != INTERMEDIATE)
		)
		& (
			(point5.occNS != FREE -> point5.ACT = NORMAL)
            & (point5.occRS != FREE -> point5.ACT = REVERSE)
            & (point5.occSNR != FREE -> point5.ACT != INTERMEDIATE)
		)
	);

INVARSPEC
	NAME NoPointHeadToTailCollisions := (
		(point2.occSNR in {TAILOCC, COMPLETETRAINOCC}) -> !(seg7.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (point2.occNS in {TAILOCC, COMPLETETRAINOCC}) -> !(seg9.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (point2.occRS in {TAILOCC, COMPLETETRAINOCC}) -> !(point5.occRS in {HEADOCC, COMPLETETRAINOCC})
		& (point5.occSNR in {TAILOCC, COMPLETETRAINOCC}) -> !(seg18.occDown in {HEADOCC, COMPLETETRAINOCC})
		& (point5.occNS in {TAILOCC, COMPLETETRAINOCC}) -> !(seg27.occUp in {HEADOCC, COMPLETETRAINOCC})
		& (point5.occRS in {TAILOCC, COMPLETETRAINOCC}) -> !(point2.occRS in {HEADOCC, COMPLETETRAINOCC})
	);

INVARSPEC
	NAME NoSegmentLockModeTransitionError := (
		(seg18.mode = EXLOCKED -> (r0.mode in {ALLOCATING, LOCKED, OCCUPIED} | r5.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg18.mode = USED -> (r0.mode = OCCUPIED | r5.mode = OCCUPIED))
		& (seg19.mode = EXLOCKED -> (r0.mode in {ALLOCATING, LOCKED, OCCUPIED} | r5.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg19.mode = USED -> (r0.mode = OCCUPIED | r5.mode = OCCUPIED))
		& (seg20.mode = EXLOCKED -> (r0.mode in {ALLOCATING, LOCKED, OCCUPIED} | r5.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg9.mode = EXLOCKED -> (r1.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg9.mode = USED -> (r1.mode = OCCUPIED))
		& (seg10.mode = EXLOCKED -> (r1.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg10.mode = USED -> (r1.mode = OCCUPIED))
		& (seg11.mode = EXLOCKED -> (r1.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg7.mode = EXLOCKED -> (r2.mode in {ALLOCATING, LOCKED, OCCUPIED} | r3.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg7.mode = USED -> (r2.mode = OCCUPIED | r3.mode = OCCUPIED))
		& (seg6.mode = EXLOCKED -> (r2.mode in {ALLOCATING, LOCKED, OCCUPIED} | r3.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg6.mode = USED -> (r2.mode = OCCUPIED | r3.mode = OCCUPIED))
		& (seg5.mode = EXLOCKED -> (r2.mode in {ALLOCATING, LOCKED, OCCUPIED} | r3.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg27.mode = EXLOCKED -> (r4.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg27.mode = USED -> (r4.mode = OCCUPIED))
		& (seg28.mode = EXLOCKED -> (r4.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (seg28.mode = USED -> (r4.mode = OCCUPIED))
		& (seg29.mode = EXLOCKED -> (r4.mode in {ALLOCATING, LOCKED, OCCUPIED}))
	);

INVARSPEC
	NAME NoPointLockModeTransitionError := (
		(point2.mode = EXLOCKED -> (r0.mode in {ALLOCATING, LOCKED, OCCUPIED} | r1.mode in {ALLOCATING, LOCKED, OCCUPIED} | r2.mode in {ALLOCATING, LOCKED, OCCUPIED} | r3.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (point2.mode = USED -> (r0.mode = OCCUPIED | r1.mode = OCCUPIED | r2.mode = OCCUPIED | r3.mode = OCCUPIED))
		& (point5.mode = EXLOCKED -> (r0.mode in {ALLOCATING, LOCKED, OCCUPIED} | r3.mode in {ALLOCATING, LOCKED, OCCUPIED} | r4.mode in {ALLOCATING, LOCKED, OCCUPIED} | r5.mode in {ALLOCATING, LOCKED, OCCUPIED}))
		& (point5.mode = USED -> (r0.mode = OCCUPIED | r3.mode = OCCUPIED | r4.mode = OCCUPIED | r5.mode = OCCUPIED))
	);

-- LTL Properties --
LTLSPEC
	NAME r0IsReleasedEventually :=
		G(r0.mode = OCCUPIED -> F(r0.mode = FREE));

LTLSPEC
	NAME r0TrainReachesSeg20UpEventuallyForever :=
		F(r0.mode = OCCUPIED) -> F(G(seg20.occUp = COMPLETETRAINOCC));

LTLSPEC
	NAME r0ElementReleaseWavePoint2ToPoint5 :=
		G((point5.mode = USED & point2.mode = AVAILABLE) -> F(point5.mode = AVAILABLE));

LTLSPEC
	NAME r0ElementReleaseWavePoint5ToSeg18 :=
		G((seg18.mode = USED & point5.mode = AVAILABLE) -> F(seg18.mode = AVAILABLE));

LTLSPEC
	NAME r0ElementReleaseWaveSeg18ToSeg19 :=
		G((seg19.mode = USED & seg18.mode = AVAILABLE) -> F(seg19.mode = AVAILABLE));

LTLSPEC
	NAME r1IsReleasedEventually :=
		G(r1.mode = OCCUPIED -> F(r1.mode = FREE));

LTLSPEC
	NAME r1TrainReachesSeg11UpEventuallyForever :=
		F(r1.mode = OCCUPIED) -> F(G(seg11.occUp = COMPLETETRAINOCC));

LTLSPEC
	NAME r1ElementReleaseWavePoint2ToSeg9 :=
		G((seg9.mode = USED & point2.mode = AVAILABLE) -> F(seg9.mode = AVAILABLE));

LTLSPEC
	NAME r1ElementReleaseWaveSeg9ToSeg10 :=
		G((seg10.mode = USED & seg9.mode = AVAILABLE) -> F(seg10.mode = AVAILABLE));

LTLSPEC
	NAME r2IsReleasedEventually :=
		G(r2.mode = OCCUPIED -> F(r2.mode = FREE));

LTLSPEC
	NAME r2TrainReachesSeg5DownEventuallyForever :=
		F(r2.mode = OCCUPIED) -> F(G(seg5.occDown = COMPLETETRAINOCC));

LTLSPEC
	NAME r2ElementReleaseWavePoint2ToSeg7 :=
		G((seg7.mode = USED & point2.mode = AVAILABLE) -> F(seg7.mode = AVAILABLE));

LTLSPEC
	NAME r2ElementReleaseWaveSeg7ToSeg6 :=
		G((seg6.mode = USED & seg7.mode = AVAILABLE) -> F(seg6.mode = AVAILABLE));

LTLSPEC
	NAME r3IsReleasedEventually :=
		G(r3.mode = OCCUPIED -> F(r3.mode = FREE));

LTLSPEC
	NAME r3TrainReachesSeg5DownEventuallyForever :=
		F(r3.mode = OCCUPIED) -> F(G(seg5.occDown = COMPLETETRAINOCC));

LTLSPEC
	NAME r3ElementReleaseWavePoint5ToPoint2 :=
		G((point2.mode = USED & point5.mode = AVAILABLE) -> F(point2.mode = AVAILABLE));

LTLSPEC
	NAME r3ElementReleaseWavePoint2ToSeg7 :=
		G((seg7.mode = USED & point2.mode = AVAILABLE) -> F(seg7.mode = AVAILABLE));

LTLSPEC
	NAME r3ElementReleaseWaveSeg7ToSeg6 :=
		G((seg6.mode = USED & seg7.mode = AVAILABLE) -> F(seg6.mode = AVAILABLE));

LTLSPEC
	NAME r4IsReleasedEventually :=
		G(r4.mode = OCCUPIED -> F(r4.mode = FREE));

LTLSPEC
	NAME r4TrainReachesSeg29DownEventuallyForever :=
		F(r4.mode = OCCUPIED) -> F(G(seg29.occDown = COMPLETETRAINOCC));

LTLSPEC
	NAME r4ElementReleaseWavePoint5ToSeg27 :=
		G((seg27.mode = USED & point5.mode = AVAILABLE) -> F(seg27.mode = AVAILABLE));

LTLSPEC
	NAME r4ElementReleaseWaveSeg27ToSeg28 :=
		G((seg28.mode = USED & seg27.mode = AVAILABLE) -> F(seg28.mode = AVAILABLE));

LTLSPEC
	NAME r5IsReleasedEventually :=
		G(r5.mode = OCCUPIED -> F(r5.mode = FREE));

LTLSPEC
	NAME r5TrainReachesSeg20UpEventuallyForever :=
		F(r5.mode = OCCUPIED) -> F(G(seg20.occUp = COMPLETETRAINOCC));

LTLSPEC
	NAME r5ElementReleaseWavePoint5ToSeg18 :=
		G((seg18.mode = USED & point5.mode = AVAILABLE) -> F(seg18.mode = AVAILABLE));

LTLSPEC
	NAME r5ElementReleaseWaveSeg18ToSeg19 :=
		G((seg19.mode = USED & seg18.mode = AVAILABLE) -> F(seg19.mode = AVAILABLE));

-- Route mutual exclusion --
LTLSPEC
	NAME r0AndR5MutuallyExclusive :=
		G(!(r0.mode = OCCUPIED & r5.mode = OCCUPIED));

LTLSPEC
	NAME r0AndR3MutuallyExclusive :=
		G(!(r0.mode = OCCUPIED & r3.mode = OCCUPIED));

LTLSPEC
	NAME r0AndR1MutuallyExclusive :=
		G(!(r0.mode = OCCUPIED & r1.mode = OCCUPIED));

LTLSPEC
	NAME r0AndR4MutuallyExclusive :=
		G(!(r0.mode = OCCUPIED & r4.mode = OCCUPIED));

LTLSPEC
	NAME r0AndR2MutuallyExclusive :=
		G(!(r0.mode = OCCUPIED & r2.mode = OCCUPIED));

LTLSPEC
	NAME r1AndR3MutuallyExclusive :=
		G(!(r1.mode = OCCUPIED & r3.mode = OCCUPIED));

LTLSPEC
	NAME r1AndR2MutuallyExclusive :=
		G(!(r1.mode = OCCUPIED & r2.mode = OCCUPIED));

LTLSPEC
	NAME r2AndR3MutuallyExclusive :=
		G(!(r2.mode = OCCUPIED & r3.mode = OCCUPIED));

LTLSPEC
	NAME r3AndR5MutuallyExclusive :=
		G(!(r3.mode = OCCUPIED & r5.mode = OCCUPIED));

LTLSPEC
	NAME r3AndR4MutuallyExclusive :=
		G(!(r3.mode = OCCUPIED & r4.mode = OCCUPIED));

LTLSPEC
	NAME r4AndR5MutuallyExclusive :=
		G(!(r4.mode = OCCUPIED & r5.mode = OCCUPIED));

-- Sanity checks: add manually based on extras_config.yml initial train positions
-- LTLSPEC NAME SanityCheckPos := F(G(<start_seg>.occ<Dir> = FREE & ...));
-- LTLSPEC NAME SanityCheckNeg := !(F(G(<start_seg>.occ<Dir> = FREE & ...)));

-------------------------------------------------------------------------------
-- Interlocking System Moduel --
-- Represents a route state transitions for the train movement
-------------------------------------------------------------------------------
MODULE InterlockingSystem 
VAR
	track : TrackSection;
ASSIGN
	next(track.r0.transition) := case
		track.r0.transition = CAN_DISPATCH
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
        & track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.point5.occSNR = FREE & track.point5.occNS = FREE & track.point5.occRS = FREE
		& track.seg18.occDown = FREE & track.seg18.occUp = FREE
		& track.seg19.occDown = FREE & track.seg19.occUp = FREE
		& track.seg20.occDown = FREE & track.seg20.occUp = FREE
        & track.point2.mode = AVAILABLE
		& track.point5.mode = AVAILABLE
		& track.seg18.mode = AVAILABLE
		& track.seg19.mode = AVAILABLE
		& track.seg20.mode = AVAILABLE
        & TRUE
		: CAN_ALLOCATE;

		track.r0.transition = CAN_ALLOCATE
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
        & track.signal4.ACT = STOP
		& track.signal10.ACT = STOP
        & track.point2.ACT = REVERSE
		& track.point5.ACT = REVERSE
        & track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.point5.occSNR = FREE & track.point5.occNS = FREE & track.point5.occRS = FREE
		& track.seg18.occDown = FREE & track.seg18.occUp = FREE
		& track.seg19.occDown = FREE & track.seg19.occUp = FREE
		& track.seg20.occDown = FREE & track.seg20.occUp = FREE
        & track.point2.mode = EXLOCKED
		& track.point5.mode = EXLOCKED
		& track.seg18.mode = EXLOCKED
		& track.seg19.mode = EXLOCKED
		& track.seg20.mode = EXLOCKED
        & TRUE
		: CAN_LOCK;

		track.r0.transition = CAN_LOCK
		& track.r0.mode = LOCKED
		& track.signal4.ACT = GO
		& track.point2.occRS != FREE
		: CAN_OCCUPY;

		track.r0.transition = CAN_OCCUPY
		& track.r0.mode = FREE
		: CAN_DISPATCH;

		TRUE : track.r0.transition;
	esac;

	next(track.r0.mode) := case
		track.r0.mode = FREE
		& track.r0.transition = CAN_DISPATCH
		: MARKED;

		track.r0.mode = MARKED
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
        & track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.point5.occSNR = FREE & track.point5.occNS = FREE & track.point5.occRS = FREE
		& track.seg18.occDown = FREE & track.seg18.occUp = FREE
		& track.seg19.occDown = FREE & track.seg19.occUp = FREE
		& track.seg20.occDown = FREE & track.seg20.occUp = FREE
        & track.point2.mode = AVAILABLE
		& track.point5.mode = AVAILABLE
		& track.seg18.mode = AVAILABLE
		& track.seg19.mode = AVAILABLE
		& track.seg20.mode = AVAILABLE
        & TRUE
		: ALLOCATING;

		track.r0.mode = ALLOCATING
		& track.r5.mode != ALLOCATING & track.r5.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r1.mode != ALLOCATING & track.r1.mode != LOCKED
		& track.r4.mode != ALLOCATING & track.r4.mode != LOCKED
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
        & track.signal4.ACT = STOP
		& track.signal10.ACT = STOP
        & track.point2.ACT = REVERSE
		& track.point5.ACT = REVERSE
        & track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.point5.occSNR = FREE & track.point5.occNS = FREE & track.point5.occRS = FREE
		& track.seg18.occDown = FREE & track.seg18.occUp = FREE
		& track.seg19.occDown = FREE & track.seg19.occUp = FREE
		& track.seg20.occDown = FREE & track.seg20.occUp = FREE
        & track.point2.mode = EXLOCKED
		& track.point5.mode = EXLOCKED
		& track.seg18.mode = EXLOCKED
		& track.seg19.mode = EXLOCKED
		& track.seg20.mode = EXLOCKED
        & TRUE
		: LOCKED;

		track.r0.mode = LOCKED
		& track.signal4.ACT = GO
		& track.point2.occRS != FREE
		: OCCUPIED;

		track.r0.mode = OCCUPIED
		& track.seg20.occUp in {HEADOCC, COMPLETETRAINOCC}
		& track.seg20.mode = USED
		& track.seg20.prev = RELEASED
		: FREE;

		TRUE : track.r0.mode;
	esac;

	next(track.r1.transition) := case
		track.r1.transition = CAN_DISPATCH
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
        & track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.seg9.occDown = FREE & track.seg9.occUp = FREE
		& track.seg10.occDown = FREE & track.seg10.occUp = FREE
		& track.seg11.occDown = FREE & track.seg11.occUp = FREE
        & track.point2.mode = AVAILABLE
		& track.seg9.mode = AVAILABLE
		& track.seg10.mode = AVAILABLE
		& track.seg11.mode = AVAILABLE
        & TRUE
		: CAN_ALLOCATE;

		track.r1.transition = CAN_ALLOCATE
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
        & track.signal4.ACT = STOP
		& track.signal6.ACT = STOP
        & track.point2.ACT = NORMAL
        & track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.seg9.occDown = FREE & track.seg9.occUp = FREE
		& track.seg10.occDown = FREE & track.seg10.occUp = FREE
		& track.seg11.occDown = FREE & track.seg11.occUp = FREE
        & track.point2.mode = EXLOCKED
		& track.seg9.mode = EXLOCKED
		& track.seg10.mode = EXLOCKED
		& track.seg11.mode = EXLOCKED
        & TRUE
		: CAN_LOCK;

		track.r1.transition = CAN_LOCK
		& track.r1.mode = LOCKED
		& track.signal4.ACT = GO
		& track.point2.occNS != FREE
		: CAN_OCCUPY;

		track.r1.transition = CAN_OCCUPY
		& track.r1.mode = FREE
		: CAN_DISPATCH;

		TRUE : track.r1.transition;
	esac;

	next(track.r1.mode) := case
		track.r1.mode = FREE
		& track.r1.transition = CAN_DISPATCH
		: MARKED;

		track.r1.mode = MARKED
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
        & track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.seg9.occDown = FREE & track.seg9.occUp = FREE
		& track.seg10.occDown = FREE & track.seg10.occUp = FREE
		& track.seg11.occDown = FREE & track.seg11.occUp = FREE
        & track.point2.mode = AVAILABLE
		& track.seg9.mode = AVAILABLE
		& track.seg10.mode = AVAILABLE
		& track.seg11.mode = AVAILABLE
        & TRUE
		: ALLOCATING;

		track.r1.mode = ALLOCATING
		& track.r0.mode != ALLOCATING & track.r0.mode != LOCKED
		& track.r3.mode != ALLOCATING & track.r3.mode != LOCKED
		& track.r2.mode != ALLOCATING & track.r2.mode != LOCKED
        & track.signal4.ACT = STOP
		& track.signal6.ACT = STOP
        & track.point2.ACT = NORMAL
        & track.point2.occSNR = FREE & track.point2.occNS = FREE & track.point2.occRS = FREE
		& track.seg9.occDown = FREE & track.seg9.occUp = FREE
		& track.seg10.occDown = FREE & track.seg10.occUp = FREE
		& track.seg11.occDown = FREE & track.seg11.occUp = FREE
        & track.point2.mode = EXLOCKED
		& track.seg9.mode = EXLOCKED
		& track.seg10.mode = EXLOCKED
		& track.seg11.mode = EXLOCKED
        & TRUE
		: LOCKED;

		track.r1.mode = LOCKED
		& track.signal4.ACT = GO
		& track.point2.occNS != FREE
		: OCCUPIED;

		track.r1.mode = OCCUPIED
		& track.seg11.occUp in {HEADOCC, COMPLETETRAINOCC}
		& track.seg11.mode = USED
