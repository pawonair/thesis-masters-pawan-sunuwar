-------------------------------------------------------------------------------
-- Signal Module --
-- Represents a signal in the track
-- Inputs:- id_in: frozen var, ID of this signal, number in range 0..15
--          CMD_in: command for the aspect of the signal
-------------------------------------------------------------------------------
MODULE Signal(id_in, CMD_in)
FROZENVAR
	id: 0..15;
VAR
	ACT : {STOP, GO};
ASSIGN
	init(id) := id_in;
	init(ACT) := STOP;
	next(ACT) := case
		ACT != CMD_in : CMD_in;
		TRUE : ACT;
	esac;
-------------------------------------------------------------------------------
-------------------------------------------------------------------------------
-- Point Module --
-- Represents a point and its track section/segment.
--      Track related variables are like in LinearSection mostly might
--      want to change this similar to Vu et al, to use 3 variables for
--      occupancy instead of 2 (require lots of other changes though).
-- Inputs:- id_in: frozen var, ID of this point, number in range 0..29
--          segID_in: frozen var, ID of the segment of the point,
--                        number in range 0..29
--          CMD_in: command for the aspect/position of the point,
--                        enum values "NORMAL" and "REVERSE"
-------------------------------------------------------------------------------
MODULE Point(id_in, segID_in, CMD_in)
FROZENVAR
	id : 0..29;
	segID : 0..29;
VAR
	occSNR : {FREE, HEADOCC, COMPLETETRAINOCC, TAILOCC, ERROROCC};
	occNS : {FREE, HEADOCC, COMPLETETRAINOCC, TAILOCC, ERROROCC};
	occRS : {FREE, HEADOCC, COMPLETETRAINOCC, TAILOCC, ERROROCC};
	ACT : {NORMAL, INTERMEDIATE, REVERSE};
	mode : {AVAILABLE, EXLOCKED, USED};
	prev : {PENDING, RELEASED};
ASSIGN
	init(id) := id_in;
	init(segID) := segID_in;
	init(ACT) := NORMAL;
	init(mode) := AVAILABLE;
	init(prev) := PENDING;

	next(ACT) := case
		ACT != CMD_in & ACT != INTERMEDIATE : INTERMEDIATE;
		-- if in INTERMEDIATE, change to CMD_in next
		ACT = INTERMEDIATE : CMD_in;
		TRUE : ACT;
	esac;
-------------------------------------------------------------------------------
-------------------------------------------------------------------------------
-- Linear Section Module --
-- Represents a section/segment in the track
-- Inputs:- id_in: track segment identifier
-------------------------------------------------------------------------------
MODULE Linear(id_in)
FROZENVAR
	id : 0..29;
VAR
	occDown : {FREE, HEADOCC, COMPLETETRAINOCC, TAILOCC, ERROROCC};
	occUp : {FREE, HEADOCC, COMPLETETRAINOCC, TAILOCC, ERROROCC};
	mode : {AVAILABLE, EXLOCKED, USED};
	prev : {PENDING, RELEASED};
ASSIGN
	init(id) := id_in;
	init(mode) := AVAILABLE;
	init(prev) := PENDING;
-------------------------------------------------------------------------------
-------------------------------------------------------------------------------
-- Route Module --
-- Represents a route in the interlocked layout
-- Inputs:- id_in: route identifier
-------------------------------------------------------------------------------
MODULE Route(id_in)
FROZENVAR
	id : 0..74;
VAR
	mode : {FREE, MARKED, ALLOCATING, LOCKED, OCCUPIED};
	transition : {CAN_DISPATCH, CAN_ALLOCATE, CAN_LOCK, CAN_OCCUPY};
ASSIGN
	init(id) := id_in;
	init(mode) := FREE;
	init(transition) := CAN_DISPATCH;
-------------------------------------------------------------------------------


-------------------------------------------------------------------------------
-- Track Section Module --
-- This bundles all segments/sections, points, train movement etc.
-------------------------------------------------------------------------------
MODULE TrackSection -- Segments/sections + point switching + signal comm
VAR
	r0 : Route(0);
	r1 : Route(1);
	r2 : Route(2);
	r3 : Route(3);
	r4 : Route(4);
	r5 : Route(5);

	seg18 : Linear(18);
	seg19 : Linear(19);
	seg20 : Linear(20);
	seg9 : Linear(9);
	seg10 : Linear(10);
	seg11 : Linear(11);
	seg7 : Linear(7);
	seg6 : Linear(6);
	seg5 : Linear(5);
	seg27 : Linear(27);
	seg28 : Linear(28);
	seg29 : Linear(29);

	point2CMD : {NORMAL, REVERSE};
	point2 : Point(2, 8, point2CMD);

	point5CMD : {NORMAL, REVERSE};
	point5 : Point(5, 17, point5CMD);


	signal4CMD : {GO, STOP};
	signal4 : Signal(4, signal4CMD);

	signal10CMD : {GO, STOP};
	signal10 : Signal(10, signal10CMD);

	signal6CMD : {GO, STOP};
	signal6 : Signal(6, signal6CMD);

	signal5CMD : {GO, STOP};
	signal5 : Signal(5, signal5CMD);

	signal3CMD : {GO, STOP};
	signal3 : Signal(3, signal3CMD);

	signal9CMD : {GO, STOP};
	signal9 : Signal(9, signal9CMD);

	signal15CMD : {GO, STOP};
	signal15 : Signal(15, signal15CMD);

	signal14CMD : {GO, STOP};
	signal14 : Signal(14, signal14CMD);


ASSIGN
	-- SEGMENTS OCCUPANCY INITIAL --
	init(seg18.occDown) := FREE;
	init(seg18.occUp) := FREE;
	init(seg19.occDown) := FREE;
	init(seg19.occUp) := FREE;
	init(seg20.occDown) := FREE;
	init(seg20.occUp) := FREE;
	init(seg9.occDown) := FREE;
	init(seg9.occUp) := FREE;
	init(seg10.occDown) := FREE;
	init(seg10.occUp) := FREE;
	init(seg11.occDown) := FREE;
	init(seg11.occUp) := FREE;
	init(seg7.occDown) := FREE;
	init(seg7.occUp) := FREE;
	init(seg6.occDown) := FREE;
	init(seg6.occUp) := FREE;
	init(seg5.occDown) := COMPLETETRAINOCC;
	init(seg5.occUp) := FREE;
	init(seg27.occDown) := FREE;
	init(seg27.occUp) := COMPLETETRAINOCC;
	init(seg28.occDown) := FREE;
	init(seg28.occUp) := FREE;
	init(seg29.occDown) := FREE;
	init(seg29.occUp) := FREE;

	-- SEGMENTS OCCUPANCY INITIAL --
	init(point2.occSNR) := FREE;
	init(point2.occNS) := FREE;
	init(point2.occRS) := FREE;
	init(point2CMD) := NORMAL;
	init(point5.occSNR) := FREE;
	init(point5.occNS) := FREE;
	init(point5.occRS) := FREE;
	init(point5CMD) := NORMAL;

	-- SIGNALS CMD INITIAL --
	init(signal4CMD) := STOP;
	init(signal10CMD) := STOP;
	init(signal6CMD) := STOP;
	init(signal5CMD) := STOP;
	init(signal3CMD) := STOP;
	init(signal9CMD) := STOP;
	init(signal15CMD) := STOP;
	init(signal14CMD) := STOP;

	-- NEXTS --
	-- SIGNALS CMD NEXT --
	next(signal4CMD) := case
		(
			r0.mode = LOCKED
			| r1.mode = LOCKED
			| r2.mode = LOCKED
			| r3.mode = LOCKED
		)
		: GO;

		(
			r0.mode = OCCUPIED
			| r1.mode = OCCUPIED
			| r2.mode = OCCUPIED
			| r3.mode = OCCUPIED
		)
		: STOP;

		TRUE : signal4CMD;
	esac;

	next(signal10CMD) := case
		TRUE : signal10CMD;
	esac;

	next(signal6CMD) := case
		TRUE : signal6CMD;
	esac;

	next(signal5CMD) := case
		(
			r1.mode = LOCKED
			| r2.mode = LOCKED
		)
		: GO;

		(
			r1.mode = OCCUPIED
			| r2.mode = OCCUPIED
		)
		: STOP;

		TRUE : signal5CMD;
	esac;

	next(signal3CMD) := case
		TRUE : signal3CMD;
	esac;

	next(signal9CMD) := case
		(
			r0.mode = LOCKED
			| r3.mode = LOCKED
			| r4.mode = LOCKED
			| r5.mode = LOCKED
		)
		: GO;

		(
			r0.mode = OCCUPIED
			| r3.mode = OCCUPIED
			| r4.mode = OCCUPIED
			| r5.mode = OCCUPIED
		)
		: STOP;

		TRUE : signal9CMD;
	esac;

	next(signal15CMD) := case
		TRUE : signal15CMD;
	esac;

	next(signal14CMD) := case
		(
			r4.mode = LOCKED
			| r5.mode = LOCKED
		)
		: GO;

		(
			r4.mode = OCCUPIED
			| r5.mode = OCCUPIED
		)
		: STOP;

		TRUE : signal14CMD;
	esac;


	-- POINTS CMD NEXT --
	next(point2CMD) := case
		r0.mode in {ALLOCATING, LOCKED, OCCUPIED} | r3.mode in {ALLOCATING, LOCKED, OCCUPIED} : REVERSE;
		TRUE : NORMAL;
	esac;

	next(point5CMD) := case
		r0.mode in {ALLOCATING, LOCKED, OCCUPIED} | r3.mode in {ALLOCATING, LOCKED, OCCUPIED} : REVERSE;
		TRUE : NORMAL;
	esac;


	-- SEGMENTS/SECTIONS MODE NEXT --
	next(seg18.mode) := case
		seg18.mode = AVAILABLE
		& (r0.mode = ALLOCATING | r5.mode = ALLOCATING)
		: EXLOCKED;

		seg18.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r0.mode = OCCUPIED
			& point5.mode = USED
			& seg19.mode = EXLOCKED
			& seg18.occDown = FREE & seg18.occUp = FREE
		)
		| (
			r5.mode = OCCUPIED
			& point5.mode = USED
			& seg19.mode = EXLOCKED
			& seg18.occDown = FREE & seg18.occUp = FREE
		)
		)
		: USED;

		seg18.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r0.mode = OCCUPIED
			& (seg19.mode = USED | seg19.prev = PENDING)
		)
		| (
			r5.mode = OCCUPIED
			& (seg19.mode = USED | seg19.prev = PENDING)
		)
		)
		& (seg18.occDown = FREE & seg18.occUp = FREE)
		& seg18.prev = RELEASED
		: AVAILABLE;

		TRUE : seg18.mode;
	esac;

	next(seg19.mode) := case
		seg19.mode = AVAILABLE
		& (r0.mode = ALLOCATING | r5.mode = ALLOCATING)
		: EXLOCKED;

		seg19.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r0.mode = OCCUPIED
			& seg18.mode = USED
			& seg20.mode = EXLOCKED
			& seg19.occDown = FREE & seg19.occUp = FREE
		)
		| (
			r5.mode = OCCUPIED
			& seg18.mode = USED
			& seg20.mode = EXLOCKED
			& seg19.occDown = FREE & seg19.occUp = FREE
		)
		)
		: USED;

		seg19.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r0.mode = OCCUPIED
			& (seg20.mode = USED | seg20.prev = PENDING)
		)
		| (
			r5.mode = OCCUPIED
			& (seg20.mode = USED | seg20.prev = PENDING)
		)
		)
		& (seg19.occDown = FREE & seg19.occUp = FREE)
		& seg19.prev = RELEASED
		: AVAILABLE;

		TRUE : seg19.mode;
	esac;

	next(seg20.mode) := case
		seg20.mode = AVAILABLE
		& (r0.mode = ALLOCATING | r5.mode = ALLOCATING)
		: EXLOCKED;

		seg20.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r0.mode = OCCUPIED
			& seg19.mode = USED
			& seg20.occUp in {HEADOCC, COMPLETETRAINOCC}
		)
		| (
			r5.mode = OCCUPIED
			& seg19.mode = USED
			& seg20.occUp in {HEADOCC, COMPLETETRAINOCC}
		)
		)
		: USED;

		seg20.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r0.mode = OCCUPIED
		)
		| (
			r5.mode = OCCUPIED
		)
		)
		& (seg20.occDown = FREE & seg20.occUp = FREE)
		& seg20.prev = RELEASED
		: AVAILABLE;

		TRUE : seg20.mode;
	esac;

	next(seg9.mode) := case
		seg9.mode = AVAILABLE
		& (r1.mode = ALLOCATING)
		: EXLOCKED;

		seg9.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
			r1.mode = OCCUPIED
			& point2.mode = USED
			& seg10.mode = EXLOCKED
			& seg9.occDown = FREE & seg9.occUp = FREE
		)
		: USED;

		seg9.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
			r1.mode = OCCUPIED
			& (seg10.mode = USED | seg10.prev = PENDING)
		)
		& (seg9.occDown = FREE & seg9.occUp = FREE)
		& seg9.prev = RELEASED
		: AVAILABLE;

		TRUE : seg9.mode;
	esac;

	next(seg10.mode) := case
		seg10.mode = AVAILABLE
		& (r1.mode = ALLOCATING)
		: EXLOCKED;

		seg10.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
			r1.mode = OCCUPIED
			& seg9.mode = USED
			& seg11.mode = EXLOCKED
			& seg10.occDown = FREE & seg10.occUp = FREE
		)
		: USED;

		seg10.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
			r1.mode = OCCUPIED
			& (seg11.mode = USED | seg11.prev = PENDING)
		)
		& (seg10.occDown = FREE & seg10.occUp = FREE)
		& seg10.prev = RELEASED
		: AVAILABLE;

		TRUE : seg10.mode;
	esac;

	next(seg11.mode) := case
		seg11.mode = AVAILABLE
		& (r1.mode = ALLOCATING)
		: EXLOCKED;

		seg11.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
			r1.mode = OCCUPIED
			& seg10.mode = USED
			& seg11.occUp in {HEADOCC, COMPLETETRAINOCC}
		)
		: USED;

		seg11.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
			r1.mode = OCCUPIED
		)
		& (seg11.occDown = FREE & seg11.occUp = FREE)
		& seg11.prev = RELEASED
		: AVAILABLE;

		TRUE : seg11.mode;
	esac;

	next(seg7.mode) := case
		seg7.mode = AVAILABLE
		& (r2.mode = ALLOCATING | r3.mode = ALLOCATING)
		: EXLOCKED;

		seg7.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r2.mode = OCCUPIED
			& point2.mode = USED
			& seg6.mode = EXLOCKED
			& seg7.occDown = FREE & seg7.occUp = FREE
		)
		| (
			r3.mode = OCCUPIED
			& point2.mode = USED
			& seg6.mode = EXLOCKED
			& seg7.occDown = FREE & seg7.occUp = FREE
		)
		)
		: USED;

		seg7.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r2.mode = OCCUPIED
			& (seg6.mode = USED | seg6.prev = PENDING)
		)
		| (
			r3.mode = OCCUPIED
			& (seg6.mode = USED | seg6.prev = PENDING)
		)
		)
		& (seg7.occDown = FREE & seg7.occUp = FREE)
		& seg7.prev = RELEASED
		: AVAILABLE;

		TRUE : seg7.mode;
	esac;

	next(seg6.mode) := case
		seg6.mode = AVAILABLE
		& (r2.mode = ALLOCATING | r3.mode = ALLOCATING)
		: EXLOCKED;

		seg6.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r2.mode = OCCUPIED
			& seg7.mode = USED
			& seg5.mode = EXLOCKED
			& seg6.occDown = FREE & seg6.occUp = FREE
		)
		| (
			r3.mode = OCCUPIED
			& seg7.mode = USED
			& seg5.mode = EXLOCKED
			& seg6.occDown = FREE & seg6.occUp = FREE
		)
		)
		: USED;

		seg6.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r2.mode = OCCUPIED
			& (seg5.mode = USED | seg5.prev = PENDING)
		)
		| (
			r3.mode = OCCUPIED
			& (seg5.mode = USED | seg5.prev = PENDING)
		)
		)
		& (seg6.occDown = FREE & seg6.occUp = FREE)
		& seg6.prev = RELEASED
		: AVAILABLE;

		TRUE : seg6.mode;
	esac;

	next(seg5.mode) := case
		seg5.mode = AVAILABLE
		& (r2.mode = ALLOCATING | r3.mode = ALLOCATING)
		: EXLOCKED;

		seg5.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r2.mode = OCCUPIED
			& seg6.mode = USED
			& seg5.occDown in {HEADOCC, COMPLETETRAINOCC}
		)
		| (
			r3.mode = OCCUPIED
			& seg6.mode = USED
			& seg5.occDown in {HEADOCC, COMPLETETRAINOCC}
		)
		)
		: USED;

		seg5.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r2.mode = OCCUPIED
		)
		| (
			r3.mode = OCCUPIED
		)
		)
		& (seg5.occDown = FREE & seg5.occUp = FREE)
		& seg5.prev = RELEASED
		: AVAILABLE;

		TRUE : seg5.mode;
	esac;

	next(seg27.mode) := case
		seg27.mode = AVAILABLE
		& (r4.mode = ALLOCATING)
		: EXLOCKED;

		seg27.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
			r4.mode = OCCUPIED
			& point5.mode = USED
			& seg28.mode = EXLOCKED
			& seg27.occDown = FREE & seg27.occUp = FREE
		)
		: USED;

		seg27.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
			r4.mode = OCCUPIED
			& (seg28.mode = USED | seg28.prev = PENDING)
		)
		& (seg27.occDown = FREE & seg27.occUp = FREE)
		& seg27.prev = RELEASED
		: AVAILABLE;

		TRUE : seg27.mode;
	esac;

	next(seg28.mode) := case
		seg28.mode = AVAILABLE
		& (r4.mode = ALLOCATING)
		: EXLOCKED;

		seg28.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
			r4.mode = OCCUPIED
			& seg27.mode = USED
			& seg29.mode = EXLOCKED
			& seg28.occDown = FREE & seg28.occUp = FREE
		)
		: USED;

		seg28.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
			r4.mode = OCCUPIED
			& (seg29.mode = USED | seg29.prev = PENDING)
		)
		& (seg28.occDown = FREE & seg28.occUp = FREE)
		& seg28.prev = RELEASED
		: AVAILABLE;

		TRUE : seg28.mode;
	esac;

	next(seg29.mode) := case
		seg29.mode = AVAILABLE
		& (r4.mode = ALLOCATING)
		: EXLOCKED;

		seg29.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
			r4.mode = OCCUPIED
			& seg28.mode = USED
			& seg29.occDown in {HEADOCC, COMPLETETRAINOCC}
		)
		: USED;

		seg29.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
			r4.mode = OCCUPIED
		)
		& (seg29.occDown = FREE & seg29.occUp = FREE)
		& seg29.prev = RELEASED
		: AVAILABLE;

		TRUE : seg29.mode;
	esac;

	next(point2.mode) := case
		point2.mode = AVAILABLE
		& (r0.mode = ALLOCATING | r1.mode = ALLOCATING | r2.mode = ALLOCATING | r3.mode = ALLOCATING)
		: EXLOCKED;

		point2.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r0.mode = OCCUPIED
			& point5.mode = EXLOCKED
			& point2.ACT = REVERSE
			& point2.occSNR = FREE & point2.occNS = FREE & point2.occRS = FREE
		)
		| (
			r1.mode = OCCUPIED
			& seg9.mode = EXLOCKED
			& point2.ACT = NORMAL
			& point2.occSNR = FREE & point2.occNS = FREE & point2.occRS = FREE
		)
		| (
			r2.mode = OCCUPIED
			& seg7.mode = EXLOCKED
			& point2.ACT = NORMAL
			& point2.occSNR = FREE & point2.occNS = FREE & point2.occRS = FREE
		)
		| (
			r3.mode = OCCUPIED
			& point5.mode = USED
			& seg7.mode = EXLOCKED
			& point2.ACT = REVERSE
			& point2.occSNR = FREE & point2.occNS = FREE & point2.occRS = FREE
		)
		)
		: USED;

		point2.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r0.mode = OCCUPIED
			& ((point5.mode = USED | point5.prev = PENDING) & point5.ACT = REVERSE)
			& point2.ACT = REVERSE
		)
		| (
			r1.mode = OCCUPIED
			& (seg9.mode = USED | seg9.prev = PENDING)
			& point2.ACT = NORMAL
		)
		| (
			r2.mode = OCCUPIED
			& (seg7.mode = USED | seg7.prev = PENDING)
			& point2.ACT = NORMAL
		)
		| (
			r3.mode = OCCUPIED
			& (seg7.mode = USED | seg7.prev = PENDING)
			& point2.ACT = REVERSE
		)
		)
		& (point2.occSNR = FREE & point2.occNS = FREE & point2.occRS = FREE)
		& point2.prev = RELEASED
		: AVAILABLE;

		TRUE : point2.mode;
	esac;

	next(point5.mode) := case
		point5.mode = AVAILABLE
		& (r0.mode = ALLOCATING | r3.mode = ALLOCATING | r4.mode = ALLOCATING | r5.mode = ALLOCATING)
		: EXLOCKED;

		point5.mode = EXLOCKED
		-- previous element in USED and next element in EXLOCKED
		& (
		(
			r0.mode = OCCUPIED
			& point2.mode = USED
			& seg18.mode = EXLOCKED
			& point5.ACT = REVERSE
			& point5.occSNR = FREE & point5.occNS = FREE & point5.occRS = FREE
		)
		| (
			r3.mode = OCCUPIED
			& point2.mode = EXLOCKED
			& point5.ACT = REVERSE
			& point5.occSNR = FREE & point5.occNS = FREE & point5.occRS = FREE
		)
		| (
			r4.mode = OCCUPIED
			& seg27.mode = EXLOCKED
			& point5.ACT = NORMAL
			& point5.occSNR = FREE & point5.occNS = FREE & point5.occRS = FREE
		)
		| (
			r5.mode = OCCUPIED
			& seg18.mode = EXLOCKED
			& point5.ACT = NORMAL
			& point5.occSNR = FREE & point5.occNS = FREE & point5.occRS = FREE
		)
		)
		: USED;

		point5.mode = USED
		-- next element mode in USED or next element prev in PENDING
		& (
		(
			r0.mode = OCCUPIED
			& (seg18.mode = USED | seg18.prev = PENDING)
			& point5.ACT = REVERSE
		)
		| (
			r3.mode = OCCUPIED
			& ((point2.mode = USED | point2.prev = PENDING) & point2.ACT = REVERSE)
			& point5.ACT = REVERSE
		)
		| (
			r4.mode = OCCUPIED
			& (seg27.mode = USED | seg27.prev = PENDING)
			& point5.ACT = NORMAL
		)
		| (
			r5.mode = OCCUPIED
			& (seg18.mode = USED | seg18.prev = PENDING)
			& point5.ACT = NORMAL
		)
		)
		& (point5.occSNR = FREE & point5.occNS = FREE & point5.occRS = FREE)
		& point5.prev = RELEASED
		: AVAILABLE;

		TRUE : point5.mode;
	esac;

	-- SEGMENTS/SECTIONS PREV NEXT --
	next(seg18.prev) := case
		seg18.prev = PENDING
		& seg18.mode = USED
		-- previous element released with mode in AVAILABLE and prev in PENDING
		& (
		(
			r0.mode = OCCUPIED
			& (seg18.occDown = FREE & seg18.occUp = FREE)
			& (point5.mode = AVAILABLE | point5.mode = EXLOCKED)
			& point5.prev = PENDING
			& (point5.occSNR = FREE & point5.occNS = FREE & point5.occRS = FREE)
		)
		| (
			r5.mode = OCCUPIED
			& (seg18.occDown = FREE & seg18.occUp = FREE)
			& (point5.mode = AVAILABLE | point5.mode = EXLOCKED)
			& point5.prev = PENDING
			& (point5.occSNR = FREE & point5.occNS = FREE & point5.occRS = FREE)
		)
		)
		: RELEASED;

		seg18.prev = RELEASED & seg18.mode = AVAILABLE : PENDING;

		TRUE : seg18.prev;
	esac;

	next(seg19.prev) := case
		seg19.prev = PENDING
		& seg19.mode = USED
		-- previous element released with mode in AVAILABLE and prev in PENDING
		& (
		(
			r0.mode = OCCUPIED
			& (seg19.occDown = FREE & seg19.occUp = FREE)
			& (seg18.mode = AVAILABLE | seg18.mode = EXLOCKED)
			& seg18.prev = PENDING
			& (seg18.occDown = FREE & seg18.occUp = FREE)
		)
		| (
			r5.mode = OCCUPIED
			& (seg19.occDown = FREE & seg19.occUp = FREE)
			& (seg18.mode = AVAILABLE | seg18.mode = EXLOCKED)
			& seg18.prev = PENDING
			& (seg18.occDown = FREE & seg18.occUp = FREE)
		)
		)
		: RELEASED;

		seg19.prev = RELEASED & seg19.mode = AVAILABLE : PENDING;

		TRUE : seg19.prev;
	esac;

	next(seg20.prev) := case
		seg20.prev = PENDING
		& seg20.mode = USED
		-- previous element released with mode in AVAILABLE and prev in PENDING
		& (
		(
			r0.mode = OCCUPIED
			& seg20.occUp in {HEADOCC, COMPLETETRAINOCC}
			& (seg19.mode = AVAILABLE | seg19.mode = EXLOCKED)
			& seg19.prev = PENDING
			& (seg19.occDown = FREE & seg19.occUp = FREE)
		)
		| (
			r5.mode = OCCUPIED
			& seg20.occUp in {HEADOCC, COMPLETETRAINOCC}
			& (seg19.mode = AVAILABLE | seg19.mode = EXLOCKED)
			& seg19.prev = PENDING
			& (seg19.occDown = FREE & seg19.occUp = FREE)
		)
		)
		: RELEASED;

		seg20.prev = RELEASED & seg20.mode = AVAILABLE : PENDING;

		TRUE : seg20.prev;
	esac; -- End segment

	next(seg9.prev) := case
		seg9.prev = PENDING
		& seg9.mode = USED
		-- previous element released with mode in AVAILABLE and prev in PENDING
		& (
			r1.mode = OCCUPIED
			& (seg9.occDown = FREE & seg9.occUp = FREE)
			& (point2.mode = AVAILABLE | point2.mode = EXLOCKED)
			& point2.prev = PENDING
			& (point2.occSNR = FREE & point2.occNS = FREE & point2.occRS = FREE)
		)
		: RELEASED;

