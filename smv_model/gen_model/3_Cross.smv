	next(seg7.prev) := case
		seg7.prev = PENDING
		& seg7.mode = USED
		-- previous element released with mode in AVAILABLE and prev in PENDING
		& (
		(
			r2.mode = OCCUPIED
			& (seg7.occDown = FREE & seg7.occUp = FREE)
			& (point2.mode = AVAILABLE | point2.mode = EXLOCKED)
			& point2.prev = PENDING
			& (point2.occSNR = FREE & point2.occNS = FREE & point2.occRS = FREE)
		)
		| (
			r3.mode = OCCUPIED
			& (seg7.occDown = FREE & seg7.occUp = FREE)
			& (point2.mode = AVAILABLE | point2.mode = EXLOCKED)
			& point2.prev = PENDING
			& (point2.occSNR = FREE & point2.occNS = FREE & point2.occRS = FREE)
		)
		)
		: RELEASED;

