	next(seg29.prev) := case
		seg29.prev = PENDING
		& seg29.mode = USED
		-- previous element released with mode in AVAILABLE and prev in PENDING
		& (
			r4.mode = OCCUPIED
			& seg29.occDown in {HEADOCC, COMPLETETRAINOCC}
			& (seg28.mode = AVAILABLE | seg28.mode = EXLOCKED)
			& seg28.prev = PENDING
			& (seg28.occDown = FREE & seg28.occUp = FREE)
		)
		: RELEASED;

		seg29.prev = RELEASED & seg29.mode = AVAILABLE : PENDING;

		TRUE : seg29.prev;
	esac; -- End segment

	next(point2.prev) := case
		point2.prev = PENDING
		& point2.mode = USED
		-- previous element released with mode in AVAILABLE and prev in PENDING
		& (
		(
			r0.mode = OCCUPIED
			& (point2.occSNR = FREE & point2.occNS = FREE & point2.occRS = FREE)
			& point2.ACT = REVERSE
		)
		| (
			r1.mode = OCCUPIED
			& (point2.occSNR = FREE & point2.occNS = FREE & point2.occRS = FREE)
			& point2.ACT = NORMAL
		)
		| (
			r2.mode = OCCUPIED
			& (point2.occSNR = FREE & point2.occNS = FREE & point2.occRS = FREE)
			& point2.ACT = NORMAL
		)
		| (
			r3.mode = OCCUPIED
			& (point2.occSNR = FREE & point2.occNS = FREE & point2.occRS = FREE)
			& (point5.mode = AVAILABLE | point5.mode = EXLOCKED)
			& point5.prev = PENDING
			& (point5.occSNR = FREE & point5.occNS = FREE & point5.occRS = FREE)
			& point2.ACT = REVERSE
		)
		)
		: RELEASED;

		point2.prev = RELEASED & point2.mode = AVAILABLE : PENDING;

		TRUE : point2.prev;
	esac;

	next(point5.prev) := case
		point5.prev = PENDING
		& point5.mode = USED
		-- previous element released with mode in AVAILABLE and prev in PENDING
		& (
		(
			r0.mode = OCCUPIED
			& (point5.occSNR = FREE & point5.occNS = FREE & point5.occRS = FREE)
			& (point2.mode = AVAILABLE | point2.mode = EXLOCKED)
			& point2.prev = PENDING
			& (point2.occSNR = FREE & point2.occNS = FREE & point2.occRS = FREE)
			& point5.ACT = REVERSE
		)
		| (
			r3.mode = OCCUPIED
			& (point5.occSNR = FREE & point5.occNS = FREE & point5.occRS = FREE)
			& point5.ACT = REVERSE
		)
		| (
			r4.mode = OCCUPIED
			& (point5.occSNR = FREE & point5.occNS = FREE & point5.occRS = FREE)
			& point5.ACT = NORMAL
		)
		| (
			r5.mode = OCCUPIED
			& (point5.occSNR = FREE & point5.occNS = FREE & point5.occRS = FREE)
			& point5.ACT = NORMAL
		)
		)
		: RELEASED;

		point5.prev = RELEASED & point5.mode = AVAILABLE : PENDING;

		TRUE : point5.prev;
	esac;

	-- SEGMENTS OCCUPANCY NEXT --
	-- seg18
	next(seg18.occDown) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg18.occDown = FREE & seg19.occDown in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg18.occDown = FREE & seg18.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg18.occDown = FREE & seg18.mode != AVAILABLE
		& seg19.occDown = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg18.occDown = FREE & seg18.mode != AVAILABLE
		& seg19.occDown = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg18.occDown = FREE & seg18.mode != AVAILABLE
		& seg19.occDown = TAILOCC
		: ERROROCC;

		-- train head leaves or train collects here if head present and signal is GO
		seg18.occDown = HEADOCC & signal9.ACT = GO : {COMPLETETRAINOCC, TAILOCC};

		-- train collects here if head present and signal is STOP
		seg18.occDown = HEADOCC & signal9.ACT = STOP : COMPLETETRAINOCC;

		-- train stays here if train is present and signal is STOP
		seg18.occDown = COMPLETETRAINOCC & signal9.ACT = STOP : COMPLETETRAINOCC;

		-- train moves on with head if train is present and signal is GO
		seg18.occDown = COMPLETETRAINOCC & signal9.ACT = GO : TAILOCC;

		-- train tail leaves if tail is present
		seg18.occDown = TAILOCC : FREE;

		TRUE : seg18.occDown;
	esac;

	next(seg18.occUp) := case
		-- stays FREE if predecessor point has no train (per ACT position)
		seg18.occUp = FREE & ((point5.ACT = NORMAL & point5.occNS in {FREE, ERROROCC}) | (point5.ACT = REVERSE & point5.occRS in {FREE, ERROROCC})) : FREE;

		-- stays FREE if not allocated
		seg18.occUp = FREE & seg18.mode = AVAILABLE : FREE;

		-- non-deterministic head entry with point5.ACT = NORMAL
		seg18.occUp = FREE & seg18.mode != AVAILABLE
		& point5.ACT = NORMAL & point5.occNS = HEADOCC
		: {HEADOCC, FREE};

		-- deterministic head entry with point5.ACT = NORMAL
		seg18.occUp = FREE & seg18.mode != AVAILABLE
		& point5.ACT = NORMAL & point5.occNS = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC: tail without head with point5.ACT = NORMAL
		seg18.occUp = FREE & seg18.mode != AVAILABLE
		& point5.ACT = NORMAL & point5.occNS = TAILOCC
		: ERROROCC;

		-- non-deterministic head entry with point5.ACT = REVERSE
		seg18.occUp = FREE & seg18.mode != AVAILABLE
		& point5.ACT = REVERSE & point5.occRS = HEADOCC
		: {HEADOCC, FREE};

		-- deterministic head entry with point5.ACT = REVERSE
		seg18.occUp = FREE & seg18.mode != AVAILABLE
		& point5.ACT = REVERSE & point5.occRS = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC: tail without head with point5.ACT = REVERSE
		seg18.occUp = FREE & seg18.mode != AVAILABLE
		& point5.ACT = REVERSE & point5.occRS = TAILOCC
		: ERROROCC;

		-- train head leaves or train collects here if head present
		seg18.occUp = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		seg18.occUp = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		seg18.occUp = TAILOCC : FREE;

		TRUE : seg18.occUp;
	esac;

	-- seg19
	next(seg19.occDown) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg19.occDown = FREE & seg20.occDown in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg19.occDown = FREE & seg19.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg19.occDown = FREE & seg19.mode != AVAILABLE
		& seg20.occDown = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg19.occDown = FREE & seg19.mode != AVAILABLE
		& seg20.occDown = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg19.occDown = FREE & seg19.mode != AVAILABLE
		& seg20.occDown = TAILOCC
		: ERROROCC;

		-- train head leaves or train collects here if head present
		seg19.occDown = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		seg19.occDown = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		seg19.occDown = TAILOCC : FREE;

		TRUE : seg19.occDown;
	esac;

	next(seg19.occUp) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg19.occUp = FREE & seg18.occUp in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg19.occUp = FREE & seg19.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg19.occUp = FREE & seg19.mode != AVAILABLE
		& seg18.occUp = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg19.occUp = FREE & seg19.mode != AVAILABLE
		& seg18.occUp = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg19.occUp = FREE & seg19.mode != AVAILABLE
		& seg18.occUp = TAILOCC
		: ERROROCC;

		-- train head leaves or train collects here if head present
		seg19.occUp = HEADOCC : {COMPLETETRAINOCC, TAILOCC};

		-- train moves on with head if train is present
		seg19.occUp = COMPLETETRAINOCC : TAILOCC;

		-- train tail leaves if tail is present
		seg19.occUp = TAILOCC : FREE;

		TRUE : seg19.occUp;
	esac;

	-- seg20
	next(seg20.occDown) := case
		-- stays FREE as no train can enter from out of bounds
		seg20.occDown = FREE : FREE;

		-- ERROROCC if head of a train is here, as the tail has no previous segment
		seg20.occDown = HEADOCC : ERROROCC;

		-- stays COMPLETETRAINOCC if the segment is not in USED mode
		seg20.occDown = COMPLETETRAINOCC & seg20.mode != USED : COMPLETETRAINOCC;

		-- train moves on with head if train is present
		seg20.occDown = COMPLETETRAINOCC & seg20.mode = USED : TAILOCC;

		-- train tail leaves if tail is present
		seg20.occDown = TAILOCC : FREE;

		TRUE : seg20.occDown;
	esac;

	next(seg20.occUp) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg20.occUp = FREE & seg19.occUp in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg20.occUp = FREE & seg20.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg20.occUp = FREE & seg20.mode != AVAILABLE
		& seg19.occUp = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg20.occUp = FREE & seg20.mode != AVAILABLE
		& seg19.occUp = COMPLETETRAINOCC
		: HEADOCC;

		-- ERROROCC if previous segment has tail but this segment has no head
		seg20.occUp = FREE & seg20.mode != AVAILABLE
		& seg19.occUp = TAILOCC
		: ERROROCC;

		-- train collects here if head present and signal is STOP
		seg20.occUp = HEADOCC & signal10.ACT = STOP : COMPLETETRAINOCC;

		-- ERROROCC if train head present and signal is GO
		seg20.occUp = HEADOCC & signal10.ACT = GO : ERROROCC;

		-- train stays here and signal is STOP
		seg20.occUp = COMPLETETRAINOCC & signal10.ACT = STOP : COMPLETETRAINOCC;

		-- ERROROCC if train in COMPLETETRAINOCC and signal is GO
		seg20.occUp = COMPLETETRAINOCC & signal10.ACT = GO : ERROROCC;

		-- ERROROCC if train tail is present
		seg20.occUp = TAILOCC : ERROROCC;

		TRUE : seg20.occUp;
	esac;

	-- seg9
	next(seg9.occDown) := case
		-- stays FREE if previous segment doesnt have a train or has ERROR
		seg9.occDown = FREE & seg10.occDown in {FREE, ERROROCC} : FREE;

		-- stays FREE if not allocated to a route
		seg9.occDown = FREE & seg9.mode = AVAILABLE : FREE;

		-- train head may enter if previous segment has head of a train
		seg9.occDown = FREE & seg9.mode != AVAILABLE
		& seg10.occDown = HEADOCC
		: {HEADOCC, FREE};

		-- train head enters if previous segment has complete train
		seg9.occDown = FREE & seg9.mode != AVAILABLE
		& seg10.occDown = COMPLETETRAINOCC
		: HEADOCC;

