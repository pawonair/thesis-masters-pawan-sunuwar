	esac;

	next(seg5.prev) := case
		seg5.prev = PENDING
		& seg5.mode = USED
		-- previous element released with mode in AVAILABLE and prev in PENDING
		& (
		(
			r2.mode = OCCUPIED
			& seg5.occDown in {HEADOCC, COMPLETETRAINOCC}
			& (seg6.mode = AVAILABLE | seg6.mode = EXLOCKED)
			& seg6.prev = PENDING
			& (seg6.occDown = FREE & seg6.occUp = FREE)
		)
		| (
			r3.mode = OCCUPIED
			& seg5.occDown in {HEADOCC, COMPLETETRAINOCC}
			& (seg6.mode = AVAILABLE | seg6.mode = EXLOCKED)
			& seg6.prev = PENDING
			& (seg6.occDown = FREE & seg6.occUp = FREE)
		)
		)
		: RELEASED;

